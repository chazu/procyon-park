"HTTP API server for Procyon Park.
 Exposes the BBS tuplespace over HTTP as JSON endpoints."

ApiServer subclass: Object
  instanceVars: httpServer bbs port dispatcher dashboardSSE
                adminList skewSeconds enforceSignatures signatureVerifier
                queueMaxPending inviteStore notificationHub
                watchCache watchCacheExpiry

  classMethod: on: portNumber bbs: aBBS [
    ^super new initPort: portNumber bbs: aBBS dispatcher: nil
  ]

  classMethod: on: portNumber bbs: aBBS dispatcher: aDispatcher [
    ^super new initPort: portNumber bbs: aBBS dispatcher: aDispatcher
  ]

  method: initPort: portNumber bbs: aBBS dispatcher: aDispatcher [
    port := portNumber.
    bbs := aBBS.
    dispatcher := aDispatcher.
    dashboardSSE := DashboardSSE on: bbs.
    httpServer := HttpServer new: port.
    self loadSecurityConfig.
    signatureVerifier := SignatureVerifier on: bbs.
    inviteStore := InviteStore new bbs: bbs.
    "Notification pub/sub fan-out replaces the legacy 20×scanAll long-poll
     loop in handleNotificationStream:. See docs/scout-perf-survey-2026-04-28.md §2."
    notificationHub := NotificationHub new.
    bbs notificationListener: [:tuple | notificationHub publish: tuple].
    "§6 watch-set TTL cache. watchWorkflowsFor: is called per HTTP
     request (handleNotificationStream:, handleNotifications:) and runs
     a full scanAll: 'watch'. Cache the resolved Array per identity for
     2 seconds — long enough to amortize bursts of polls from the same
     client, short enough that newly-added watches are picked up
     promptly."
    watchCache := Dictionary new.
    watchCacheExpiry := Dictionary new.
    self registerRoutes
  ]

  method: adminList [ ^adminList ]
  method: skewSeconds [ ^skewSeconds ]
  method: enforceSignatures [ ^enforceSignatures ]

  method: loadSecurityConfig [
    "Read ~/.config/pp/server.toml for [admin].admins, [security].skew_seconds,
     and [security].enforce_signatures. Missing file or malformed TOML leaves
     defaults: adminList=[], skew=120, enforceSignatures=true.
     The default flipped to true with the wave-3 rollout of the multiplayer
     identity epic — every mutating endpoint now requires a valid ed25519
     signature out of the box. Operators who explicitly want the legacy
     anonymous path back must set [security].enforce_signatures = false."
    | home path config adminCfg secCfg queueCfg qMax |
    adminList := Array new: 0.
    skewSeconds := 120.
    enforceSignatures := true.
    queueMaxPending := nil.
    home := System env: 'HOME'.
    home isNil ifTrue: [home := ''].
    path := home, '/.config/pp/server.toml'.
    (File exists: path) ifTrue: [
      [
        config := Toml decodeFile: path.
        adminCfg := config at: 'admin' ifAbsent: [nil].
        adminCfg notNil ifTrue: [
          adminList := adminCfg at: 'admins' ifAbsent: [Array new: 0]
        ].
        secCfg := config at: 'security' ifAbsent: [nil].
        secCfg notNil ifTrue: [
          skewSeconds := secCfg at: 'skew_seconds' ifAbsent: [120].
          enforceSignatures := secCfg at: 'enforce_signatures' ifAbsent: [true]
        ].
        "D6.11 / §4.10: opt-in queue backpressure. [queue].max_pending caps
         the number of pending task tuples; creation endpoints respond 429
         once the current depth reaches it. Absent / nil / non-positive
         values disable the guard (opt-in)."
        queueCfg := config at: 'queue' ifAbsent: [nil].
        queueCfg notNil ifTrue: [
          qMax := queueCfg at: 'max_pending' ifAbsent: [nil].
          (qMax notNil and: [qMax isKindOf: Number])
            ifTrue: [
              qMax > 0 ifTrue: [queueMaxPending := qMax]
            ]
        ]
      ] on: Exception do: [:e |
        ('Warning: could not load server.toml: ', e messageText) println
      ]
    ].
    (adminList isEmpty and: [(bbs scanAll: 'identity') isEmpty]) ifTrue: [
      self bootstrapIfNeeded
    ]
  ]

  method: bootstrapIfNeeded [
    "First-run convenience: create a 'local' identity, make it admin,
     and seed a matching identity tuple. Skipped if the user already
     has a current pointer (they've run `pp identity init` manually
     but not registered the pubkey as admin)."
    | home idDir currentPointer identRecord pubHex tomlPath tomlContents payload now admins configDir |
    home := System env: 'HOME'.
    home isNil ifTrue: [home := ''].
    idDir := home, '/.config/pp/identity'.
    currentPointer := idDir, '/current'.
    (File exists: currentPointer) ifTrue: [
      '' println.
      'Warning: local identity exists but is not registered as admin.' println.
      '  Add its pubkey to ~/.config/pp/server.toml under [admin].admins' println.
      ^self
    ].
    "Generate 'local' identity via IdentityStore."
    (IdentityStore init: 'local' force: false) ifFalse: [^self].
    identRecord := IdentityStore load: 'local'.
    identRecord isNil ifTrue: [^self].
    pubHex := identRecord at: 'pubHex'.
    "Write server.toml."
    configDir := home, '/.config/pp'.
    Shell run: 'mkdir -p "', configDir, '"'.
    tomlPath := configDir, '/server.toml'.
    tomlContents := '[admin]', (String with: Character lf),
                    'admins = ["', pubHex, '"]', (String with: Character lf),
                    '', (String with: Character lf),
                    '[security]', (String with: Character lf),
                    'enforce_signatures = true', (String with: Character lf),
                    'skew_seconds = 120', (String with: Character lf).
    File writeFileContents: tomlPath contents: tomlContents mode: 8r644.
    "Seed pinned identity tuple matching handleUserAdd's shape
     (category=identity, scope=/, identity=user:<name>)."
    now := DateTime now epochSeconds.
    payload := Dictionary new.
    payload at: 'pubkey' put: pubHex.
    payload at: 'created_at' put: now.
    payload at: 'status' put: 'active'.
    bbs upsertPinned: 'identity'
        scope: '/'
        identity: 'user:local'
        payload: payload
        actor: nil.
    "Re-read adminList so this server process picks it up without restart."
    admins := Array new: 0.
    admins := admins copyWith: pubHex.
    adminList := admins.
    enforceSignatures := true.
    skewSeconds := 120.
    '' println.
    ('Procyon Park bootstrapped as ''local'' (admin pubkey: ', pubHex, ')') println.
    ('  Local identity: ', idDir, '/local.key') println.
    ('  Config: ', tomlPath) println.
    '' println
  ]

  method: bbs [ ^bbs ]

  method: start [
    | staticDir |
    ('Procyon Park API starting on port ', port printString) println.
    "Register SSE and static routes here (outside registerRoutes chain to avoid bytecode limits)"
    staticDir := (System env: 'HOME'), '/.pp/static'.
    httpServer serveStatic: '/dashboard/' from: staticDir.
    httpServer sseRoute: '/api/sse/dashboard' handler: [:conn :req |
      self handleSSEDashboard: conn request: req
    ].
    self startSSETick.
    httpServer start
  ]

  method: stop [
    httpServer stop
  ]

  "--- Route Registration ---"

  method: registerRoutes [
    "Health"
    self get: '/api/health' do: [:req | self handleHealth: req].

    "Core tuplespace operations"
    self signedRouteOnly: '/api/out' do: [:req :actorCtx | self handleOut: req actor: actorCtx].
    self signedPost: '/api/inp' fields: #('category' 'scope' 'identity') do: [:body :actorCtx |
      | tuple d |
      tuple := bbs inp: (body at: 'category') scope: (body at: 'scope') identity: (body at: 'identity').
      d := Dictionary new. d at: 'tuple' put: tuple.
      self okResponse: d
    ].
    "rdp and scan are read-only — leave unsigned per F1.4/NF6."
    self post: '/api/rdp' fields: #('category' 'scope' 'identity') do: [:body |
      | tuple d |
      tuple := bbs rdp: (body at: 'category') scope: (body at: 'scope') identity: (body at: 'identity').
      d := Dictionary new. d at: 'tuple' put: tuple.
      self okResponse: d
    ].
    self post: '/api/scan' fields: #('category') do: [:body |
      | tuples d |
      (body includesKey: 'scope')
        ifTrue: [tuples := bbs scan: (body at: 'category') scope: (body at: 'scope')]
        ifFalse: [tuples := bbs scanAll: (body at: 'category')].
      tuples := self applyScanFilters: tuples body: body.
      d := Dictionary new. d at: 'tuples' put: tuples. d at: 'count' put: tuples size.
      self okResponse: d
    ].

    "Convenience endpoints"
    self signedPost: '/api/observe' fields: #('scope' 'identity' 'detail') do: [:body :actorCtx |
      | id witnessedBy witnessErr agentIdentity |
      witnessedBy := body at: 'witnessed_by' ifAbsent: [nil].
      agentIdentity := body at: 'agent_identity' ifAbsent: [nil].
      witnessErr := self validateWitness: witnessedBy.
      witnessErr notNil ifTrue: [
        self errorResponse: 400 message: witnessErr
      ] ifFalse: [
        id := bbs observe: (body at: 'scope')
                 identity: (body at: 'identity')
                 detail: (body at: 'detail')
                 tags: (body at: 'tags' ifAbsent: [#()])
                 task: (body at: 'task' ifAbsent: [''])
                 actor: (self actorOf: actorCtx)
                 witnessedBy: witnessedBy
                 agentIdentity: agentIdentity.
        self okResponse: (self okWithId: id)
      ]
    ].
    self signedPost: '/api/decide' fields: #('scope' 'identity' 'detail') do: [:body :actorCtx |
      | id |
      id := bbs decide: (body at: 'scope')
               identity: (body at: 'identity')
               detail: (body at: 'detail')
               rationale: (body at: 'rationale' ifAbsent: [''])
               task: (body at: 'task' ifAbsent: [''])
               actor: (self actorOf: actorCtx)
               agentIdentity: (body at: 'agent_identity' ifAbsent: [nil]).
      self okResponse: (self okWithId: id)
    ].
    self signedPost: '/api/event' fields: #('scope' 'identity') do: [:body :actorCtx |
      | id |
      id := bbs emitEvent: (body at: 'scope')
                identity: (body at: 'identity')
                type: (body at: 'type' ifAbsent: ['generic'])
                summary: (body at: 'summary' ifAbsent: [''])
                actor: (self actorOf: actorCtx)
                agentIdentity: (body at: 'agent_identity' ifAbsent: [nil]).
      self okResponse: (self okWithId: id)
    ].
    self signedPost: '/api/notify' fields: #('message') do: [:body :actorCtx |
      | id observers |
      observers := body at: 'observers' ifAbsent: [nil].
      (observers notNil and: [(observers isKindOf: Array) not]) ifTrue: [observers := nil].
      id := bbs notify: (body at: 'message')
               scope: (body at: 'scope' ifAbsent: ['system'])
               severity: (body at: 'severity' ifAbsent: ['info'])
               actor: (self actorOf: actorCtx)
               observers: observers.
      self okResponse: (self okWithId: id)
    ].
    self signedPost: '/api/dismiss' fields: #('task_id' 'scope') do: [:body :actorCtx |
      | d actor |
      actor := self actorOf: actorCtx.
      bbs emitEvent: (body at: 'scope')
          identity: 'task-complete:', (body at: 'task_id')
          type: 'task-complete'
          summary: 'Agent dismissed'
          actor: actor.
      bbs notify: ('Agent completed task: ', (body at: 'task_id'))
          scope: (body at: 'scope')
          severity: 'info'
          actor: actor.
      d := Dictionary new. d at: 'status' put: 'dismissed'.
      self okResponse: d
    ].
    self get: '/api/notifications' do: [:req | self handleNotifications: req].
    self asyncGet: '/api/notifications/stream' do: [:req | self handleNotificationStream: req].
    self registerWorkflowRoutes
  ]

  method: registerWorkflowRoutes [
    "Workflow, task, and work item routes (split from registerRoutes to avoid method-size limit)."
    self signedPost: '/api/plan' fields: #('scope' 'identity' 'subtasks') do: [:body :actorCtx |
      | scope identity subtasks planPayload d |
      scope := body at: 'scope'. identity := body at: 'identity'. subtasks := body at: 'subtasks'.
      planPayload := Dictionary new.
      planPayload at: 'detail' put: 'Plan: ', identity.
      planPayload at: 'subtasks' put: subtasks.
      planPayload at: 'task' put: (body at: 'task' ifAbsent: ['']).
      bbs outPinned: 'decision' scope: scope identity: 'plan:', identity payload: planPayload actor: (self actorOf: actorCtx).
      d := Dictionary new.
      d at: 'status' put: 'ok'. d at: 'plan_id' put: identity. d at: 'subtasks' put: subtasks size.
      self okResponse: d
    ].
    self signedPost: '/api/workflow/start' fields: #('template' 'scope') do: [:body :actorCtx |
      | instanceId d overrideAffinity bp |
      bp := self queueBackpressureResponse.
      dispatcher isNil ifTrue: [
        self errorResponse: 500 message: 'No dispatcher configured'
      ] ifFalse: [bp notNil ifTrue: [bp] ifFalse: [
        [
          "F4.3: optional affinity override in the request body takes precedence
           over CUE per-transition and workflow-root defaults. Only pass through
           when the caller supplied a Dictionary — silently ignore malformed
           shapes so the server remains strict-by-default."
          overrideAffinity := body at: 'affinity' ifAbsent: [nil].
          (overrideAffinity notNil and: [overrideAffinity isKindOf: Dictionary]) ifFalse: [
            overrideAffinity := nil
          ].
          instanceId := dispatcher
            instantiateWorkflow: (body at: 'template')
            scope: (body at: 'scope')
            params: (body at: 'params' ifAbsent: [Dictionary new])
            launchedBy: (self actorOf: actorCtx)
            overrideAffinity: overrideAffinity.
          d := Dictionary new. d at: 'status' put: 'ok'. d at: 'workflow_id' put: instanceId.
          self okResponse: d
        ] on: Exception do: [:e |
          self errorResponse: 400 message: e messageText
        ]
      ]]
    ].
    self signedRouteOnly: '/api/workflow/status' do: [:req :actorCtx | self handleWorkflowStatus: req].
    self signedRouteOnly: '/api/workflow/cancel' do: [:req :actorCtx | self handleWorkflowCancel: req actor: actorCtx].
    self signedRouteOnly: '/api/workflow/watch' do: [:req :actorCtx | self handleWorkflowWatch: req actor: actorCtx].
    self signedRouteOnly: '/api/workflow/unwatch' do: [:req :actorCtx | self handleWorkflowUnwatch: req actor: actorCtx].
    self registerTaskRoutes
  ]

  method: registerTaskRoutes [
    "Task, signal, and work item routes."
    self signedPost: '/api/task/create' fields: #('scope' 'identity' 'role' 'description') do: [:body :actorCtx |
      self handleTaskCreate: body actor: actorCtx
    ].
    self signedPost: '/api/tasks/complete' fields: #('task_id' 'worker_id' 'claim_id' 'status') do: [:body :actorCtx |
      self handleTaskComplete: body actor: actorCtx
    ].
    self signedPost: '/api/tasks/renew' fields: #('task_id' 'worker_id' 'claim_id' 'scope') do: [:body :actorCtx |
      self handleTaskRenew: body actor: actorCtx
    ].
    self signedPost: '/api/signal' fields: #('scope' 'identity' 'payload') do: [:body :actorCtx |
      | id |
      id := bbs upsertSignal: (body at: 'scope') identity: (body at: 'identity') payload: (body at: 'payload') actor: (self actorOf: actorCtx).
      self okResponse: (self okWithId: id)
    ].
    self registerDashboardRoutes
  ]

  method: registerDashboardRoutes [
    "Work item routes."
    self signedRouteOnly: '/api/workitem/create' do: [:req :actorCtx | self handleWorkitemCreate: req actor: actorCtx].
    self signedRouteOnly: '/api/workitem/update' do: [:req :actorCtx | self handleWorkitemUpdate: req actor: actorCtx].
    self signedRouteOnly: '/api/workitem/comment' do: [:req :actorCtx | self handleWorkitemComment: req actor: actorCtx].
    self registerDashboardRoutes2
  ]

  method: registerDashboardRoutes2 [
    "More work item routes + dashboard."
    self signedRouteOnly: '/api/workitem/run' do: [:req :actorCtx | self handleWorkitemRun: req actor: actorCtx].
    self get: '/api/dashboard' do: [:req | self handleDashboard: req].
    self get: '/api/history' do: [:req | self handleHistory: req].
    self registerUserRoutes
  ]

  method: registerUserRoutes [
    "Admin-gated user management + self-serve key rotation."
    self signedPost: '/api/user/add' fields: #('name' 'pubkey') do: [:body :actorCtx |
      self handleUserAdd: body actor: actorCtx
    ].
    self signedPost: '/api/user/revoke' fields: #('name') do: [:body :actorCtx |
      self handleUserRevoke: body actor: actorCtx
    ].
    "Rotate is NOT admin-gated — its own signed handler does old-pub verification."
    httpServer route: '/api/user/rotate' method: 'POST' handler: [:req |
      self handleUserRotate: req
    ].
    self registerInviteRoutes.
    self registerWorkerRoutes
  ]

  method: registerInviteRoutes [
    "Invite flow: create is admin-gated; claim is unsigned because
     the invitee has no identity yet."
    self signedPost: '/api/invite/create' fields: #('name') do: [:body :actorCtx |
      | ttl created response |
      actorCtx isAdmin ifFalse: [
        ^self errorResponse: 401 message: 'admin signature required'
      ].
      ttl := body at: 'ttl_seconds' ifAbsent: [600].
      created := inviteStore
        create: (body at: 'name')
        ttl: ttl
        createdBy: actorCtx actor.
      response := Dictionary new.
      response at: 'name' put: (created at: 'name').
      response at: 'token' put: (created at: 'token').
      response at: 'expires_at' put: (created at: 'expires_at').
      self okResponse: response
    ].
    self post: '/api/invite/claim' fields: #('name' 'token' 'pubkey') do: [:body |
      | result response |
      result := inviteStore
        claim: (body at: 'name')
        token: (body at: 'token')
        pubkey: (body at: 'pubkey').
      result isNil ifTrue: [
        ^self errorResponse: 400 message: 'invalid or expired invite'
      ].
      response := Dictionary new.
      response at: 'name' put: (body at: 'name').
      response at: 'status' put: 'registered'.
      self okResponse: response
    ]
  ]

  method: registerWorkerRoutes [
    "Worker lifecycle routes — birth certificate (D6.13) and friends.
     Register is a signed POST where the operator's human key signs a
     request whose body contains the worker attestation. The request-level
     signature (X-PP-Actor=<operator user>, X-PP-Signature over the
     canonical bytes) IS the attestation signature: the body's bytes
     include worker_pubkey/operator_pubkey/nonce, so SignatureVerifier's
     sha256(body) check binds the attestation to the operator's key."
    self signedPost: '/api/worker/register'
         fields: #('worker_pubkey' 'operator_pubkey' 'nonce' 'manifest' 'name')
         do: [:body :actorCtx | self handleWorkerRegister: body actor: actorCtx].
    self signedPost: '/api/worker/heartbeat'
         fields: #('name')
         do: [:body :actorCtx | self handleWorkerHeartbeat: body actor: actorCtx].
    self signedPost: '/api/worker/drain'
         fields: #('name')
         do: [:body :actorCtx | self handleWorkerDrain: body actor: actorCtx].
    self registerTaskClaimRoutes
  ]

  method: registerTaskClaimRoutes [
    "Task lifecycle routes invoked by workers: claim, renew, complete.
     Split from registerWorkerRoutes to stay under the method-size limit."
    self signedPost: '/api/tasks/claim'
         fields: #('task_id' 'worker_id' 'claim_id')
         do: [:body :actorCtx | self handleTaskClaim: body actor: actorCtx].
    self signedPost: '/api/tasks/available'
         fields: #('worker_id')
         do: [:body :actorCtx | self handleTasksAvailable: body actor: actorCtx].
    self registerBBSWriteRoutes
  ]

  method: registerBBSWriteRoutes [
    "Unsigned BBS write routes for local CLI ops (pp bbs put / pp bbs rm).
     Mirrors the unsigned posture of /api/rdp and /api/scan — these are
     intended for local inspection/ops; auth hardening tracked separately.
     Both use synchronous-flush BBS variants so the on-disk state is
     durable before the HTTP response returns (kill-test invariant)."
    self post: '/api/bbs/put'
         fields: #('category' 'scope' 'identity' 'payload')
         do: [:body | self handleBBSPut: body].
    self post: '/api/bbs/rm'
         fields: #('category' 'scope' 'identity')
         do: [:body | self handleBBSRm: body]
  ]

  method: handleBBSPut: body [
    "POST /api/bbs/put — UPSERT a tuple with sync-flush durability.
     Body: {category, scope, identity, payload, modality?, pinned?, ttl?}.
     The server picks the tuple id; any client-supplied id is ignored.
     If a tuple with the same composite key already exists it is consumed
     (inp:) before the replacement is written (out:); created=false in
     that case, true otherwise. Returns 400 on validation failure with
     the valid category list when the category is unknown."
    | category scope identity payload modality pinned ttl
      existing existed id resp validList errBody |
    category := body at: 'category'.
    scope := body at: 'scope'.
    identity := body at: 'identity'.
    payload := body at: 'payload'.

    "Validate category against the canonical list."
    (Categories isValid: category) ifFalse: [
      validList := Categories valid.
      errBody := Dictionary new.
      errBody at: 'error' put: 'Invalid category: ', category printString.
      errBody at: 'valid_categories' put: validList.
      ^self jsonResponse: 400 body: errBody
    ].

    "Required-field type sanity (requireFields: only checks presence)."
    ((scope isKindOf: String) and: [scope isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'scope must be a non-empty string'
    ].
    ((identity isKindOf: String) and: [identity isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'identity must be a non-empty string'
    ].
    (payload isKindOf: Dictionary) ifFalse: [
      ^self errorResponse: 400 message: 'payload must be a JSON object'
    ].

    "Resolve modality. Explicit modality wins; else pinned/ttl flags;
     else default to 'persistent' for pinned-by-default categories
     (Categories isPinned:), 'linear' otherwise."
    modality := body at: 'modality' ifAbsent: [nil].
    pinned := body at: 'pinned' ifAbsent: [false].
    ttl := body at: 'ttl' ifAbsent: [0].
    modality isNil ifTrue: [
      pinned = true ifTrue: [modality := 'persistent']
      ifFalse: [
        ttl > 0
          ifTrue: [modality := 'affine']
          ifFalse: [
            modality := (Categories isPinned: category)
              ifTrue: ['persistent']
              ifFalse: ['linear']
          ]
      ]
    ].
    (#('persistent' 'linear' 'affine') includes: modality) ifFalse: [
      ^self errorResponse: 400 message: 'invalid modality: ', modality printString
    ].
    (modality = 'affine' and: [ttl <= 0]) ifTrue: [
      ^self errorResponse: 400 message: 'modality=affine requires ttl > 0'
    ].

    "UPSERT: consume any existing tuple with the same composite key.
     The two operations both go through the BBS internal mutex; gross
     atomicity is best-effort under the existing locking model."
    existing := bbs findInIndex: category scope: scope identity: identity.
    existed := existing notNil.
    existed ifTrue: [
      bbs inp: category scope: scope identity: identity
    ].

    "Write the new tuple; the BBS assigns the id (UUID equivalent).
     Sync-flush below ensures durability before we ack the caller."
    modality = 'persistent' ifTrue: [
      id := bbs outPinned: category scope: scope identity: identity payload: payload actor: nil
    ] ifFalse: [
      modality = 'affine' ifTrue: [
        id := bbs outAffine: category scope: scope identity: identity payload: payload ttl: ttl actor: nil
      ] ifFalse: [
        id := bbs out: category scope: scope identity: identity payload: payload actor: nil
      ]
    ].
    bbs flushIfDirty.

    resp := Dictionary new.
    resp at: 'id' put: id.
    resp at: 'status' put: 'ok'.
    resp at: 'created' put: existed not.
    ^self okResponse: resp
  ]

  method: handleBBSRm: body [
    "POST /api/bbs/rm — consume a tuple by composite key, sync-flush.
     Body: {category, scope, identity}. Idempotent: returns
     {status:'ok', removed:false} when no matching tuple exists."
    | category scope identity result resp validList errBody |
    category := body at: 'category'.
    scope := body at: 'scope'.
    identity := body at: 'identity'.

    (Categories isValid: category) ifFalse: [
      validList := Categories valid.
      errBody := Dictionary new.
      errBody at: 'error' put: 'Invalid category: ', category printString.
      errBody at: 'valid_categories' put: validList.
      ^self jsonResponse: 400 body: errBody
    ].
    ((scope isKindOf: String) and: [scope isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'scope must be a non-empty string'
    ].
    ((identity isKindOf: String) and: [identity isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'identity must be a non-empty string'
    ].

    result := bbs inp: category scope: scope identity: identity.
    bbs flushIfDirty.

    resp := Dictionary new.
    resp at: 'status' put: 'ok'.
    resp at: 'removed' put: result notNil.
    ^self okResponse: resp
  ]

  method: handleWorkerDrain: body actor: actorCtx [
    "Handle POST /api/worker/drain.

     Body: {name}. Request must be signed by the worker keypair whose
     actor header is 'worker:<name>' where <name> matches body.name.
     Flips payload.drain to true on the affine worker tuple while
     preserving all other payload fields and refreshes the TTL so the
     tuple survives its natural expiry long enough for the in-flight
     task to complete.

     Gates:
       - actorCtx verified=false       → 401 (or 503 when enforcement off)
       - actorCtx.actor != worker:name → 403 (cross-worker drain refused)
       - worker tuple missing/expired  → 410 (nothing to drain)

     Idempotent: invoking drain twice on an already-drained worker
     returns 200 and leaves drain=true. Note: once drain=true is
     visible on the tuple, SignatureVerifier refuses further signed
     requests from that worker, so the public idempotency window is
     bounded by the first successful call at the HTTP layer. The
     handler itself, invoked directly (as in tests), remains pure
     idempotent."
    | name identity existing payload newPayload ttl heartbeat guard d |

    guard := self requireVerified: actorCtx for: 'worker drain'.
    guard notNil ifTrue: [^guard].

    name := body at: 'name'.
    (name isString and: [name isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'name must be a non-empty string'
    ].

    identity := Identity worker: name.

    "Require the caller's actor header to name the same worker. A verified
     user: or admin: actor cannot drain a worker they don't own."
    guard := self requireWorkerActor: actorCtx name: name verb: 'drain'.
    guard notNil ifTrue: [^guard].

    existing := bbs rdp: 'worker' scope: '/' identity: identity.
    existing isNil ifTrue: [
      ^self errorResponse: 410 message: 'worker tuple not found (expired or never registered): ', identity
    ].

    payload := existing at: 'payload' ifAbsent: [Dictionary new].
    newPayload := Dictionary new.
    payload keysAndValuesDo: [:k :v | newPayload at: k put: v].
    newPayload at: 'drain' put: true.
    newPayload at: 'drain_requested_at' put: DateTime now epochSeconds.

    heartbeat := self workerHeartbeatInterval.
    ttl := heartbeat * 3.

    bbs outAffine: 'worker' scope: '/' identity: identity
        payload: newPayload ttl: ttl actor: identity.

    d := Dictionary new.
    d at: 'ok' put: true.
    d at: 'identity' put: identity.
    ^self okResponse: d
  ]

  method: handleWorkerRegister: body actor: actorCtx [
    "Handle POST /api/worker/register.

     Body: {worker_pubkey, operator_pubkey, nonce, manifest, name}.
     manifest must be a Dictionary carrying slots/models/repos/roles/operator/accept_from.

     Auth gates:
       - actorCtx must be verified; anonymous fallback → 503 when
         signatures are unenforced, 401 when enforcement is on.
       - The authenticated actor must be a user: identity whose registered
         pubkey equals body.operator_pubkey. Any mismatch → 403.
       - Duplicate worker name claimed by a different operator → 409.

     Success writes an affine worker tuple with ttl = 3 * heartbeatInterval
     (default 30s → 90s).

     Refresh semantics (F2.2): if a worker tuple with this name already
     exists AND its operator_pubkey matches the request's operator_pubkey,
     the call is idempotent — the existing payload is consumed, the
     manifest is replaced with the new one, and the drain flag and
     registered_at timestamp are preserved. The TTL resets to now + ttl.
     This lets operators push an updated manifest (e.g. after adding a
     repo clone) without interrupting any in-flight claim or lease work,
     and without losing an operator-initiated drain. A mismatched
     operator_pubkey continues to return 409 (impersonation guard)."
    | workerPub operatorPub nonce manifest name manifestErr existing existingOp existingPayload payload identity ttl heartbeat now opIdentityTuple opPayload actor drainFlag regAt isRefresh guard |

    guard := self requireVerified: actorCtx for: 'worker registration'.
    guard notNil ifTrue: [^guard].

    workerPub := body at: 'worker_pubkey'.
    operatorPub := body at: 'operator_pubkey'.
    nonce := body at: 'nonce'.
    manifest := body at: 'manifest'.
    name := body at: 'name'.

    (workerPub isString and: [workerPub size = 64]) ifFalse: [
      ^self errorResponse: 400 message: 'worker_pubkey must be 64 hex chars'
    ].
    (operatorPub isString and: [operatorPub isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'operator_pubkey must be a non-empty hex string'
    ].
    (nonce isString and: [nonce isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'nonce must be a non-empty string'
    ].
    (manifest isKindOf: Dictionary) ifFalse: [
      ^self errorResponse: 400 message: 'manifest must be a dict'
    ].
    manifestErr := self validateWorkerManifest: manifest.
    manifestErr notNil ifTrue: [^self errorResponse: 400 message: manifestErr].
    (name isString and: [name isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'name must be a non-empty string'
    ].

    "Bind attestation: body.operator_pubkey must equal the registered pubkey
     of the authenticated actor. Admin-pubkey signers cannot register a
     worker — they have no user: identity whose pubkey to compare."
    opIdentityTuple := bbs rdp: 'identity' scope: '/' identity: actorCtx actor.
    opIdentityTuple isNil ifTrue: [
      ^self errorResponse: 403 message: 'operator identity not found: ', actorCtx actor
    ].
    opPayload := opIdentityTuple at: 'payload' ifAbsent: [Dictionary new].
    (opPayload at: 'status' ifAbsent: ['active']) = 'active' ifFalse: [
      ^self errorResponse: 403 message: 'operator identity is not active'
    ].
    (opPayload at: 'pubkey' ifAbsent: [nil]) = operatorPub ifFalse: [
      ^self errorResponse: 403 message: 'operator_pubkey does not match authenticated actor'
    ].

    identity := Identity worker: name.
    existing := bbs rdp: 'worker' scope: '/' identity: identity.
    isRefresh := false.
    drainFlag := false.
    regAt := nil.
    existing notNil ifTrue: [
      existingPayload := existing at: 'payload' ifAbsent: [Dictionary new].
      existingOp := existingPayload at: 'operator_pubkey' ifAbsent: [nil].
      (existingOp notNil and: [existingOp = operatorPub]) ifFalse: [
        ^self errorResponse: 409
                 message: 'worker name ', name, ' already claimed by a different operator'
      ].
      "Same operator re-registering — refresh path. Preserve drain and
       registered_at; the outAffine: write below overwrites the old tuple
       atomically (no separate inp: needed)."
      isRefresh := true.
      drainFlag := existingPayload at: 'drain' ifAbsent: [false].
      regAt := existingPayload at: 'registered_at' ifAbsent: [nil]
    ].

    "TTL = 3 * heartbeatInterval. Default heartbeat 30s → ttl 90s."
    heartbeat := self workerHeartbeatInterval.
    ttl := heartbeat * 3.

    now := DateTime now epochSeconds.
    regAt isNil ifTrue: [regAt := now].
    payload := Dictionary new.
    payload at: 'worker_pubkey' put: workerPub.
    payload at: 'operator_pubkey' put: operatorPub.
    payload at: 'manifest' put: manifest.
    payload at: 'drain' put: drainFlag.
    payload at: 'registered_at' put: regAt.
    isRefresh ifTrue: [payload at: 'refreshed_at' put: now].

    actor := identity.
    bbs outAffine: 'worker' scope: '/' identity: identity payload: payload ttl: ttl actor: actor.

    ^self okResponse: (self okWithIdentity: identity)
  ]

  method: validateWorkerManifest: manifest [
    "Require the canonical manifest fields (D6.13). Returns error or nil."
    #('slots' 'models' 'repos' 'roles' 'operator' 'accept_from') do: [:f |
      (manifest includesKey: f) ifFalse: [
        ^'manifest missing required field: ', f
      ]
    ].
    ^nil
  ]

  method: workerHeartbeatInterval [
    "Worker heartbeat interval in seconds. Future work: read from server.toml
     [worker].heartbeat_interval. Default: 30s → 3x = 90s tuple TTL."
    ^30
  ]

  method: handleWorkerHeartbeat: body actor: actorCtx [
    "Handle POST /api/worker/heartbeat.

     Body: {name, manifest?}. Signed with the worker's key
     (X-PP-Actor: worker:<name>).

     Semantics:
       - actorCtx must be verified and carry a worker: identity whose
         name matches body.name. Mismatch → 403.
       - Current worker tuple must exist and not be expired. Missing /
         expired → 410 (client must re-register).
       - If body includes a manifest dict, validate and merge it into
         the stored payload (preserving the drain flag and other
         operator-set fields).
       - Re-issue the affine tuple with the same identity, carrying the
         merged payload and a fresh 3 * heartbeat_interval TTL. BBS
         outAffine: now provides true overwrite semantics, so a single
         outAffine: call replaces the prior tuple atomically.
       - On success: 200 {ok:true, ttl:N}."
    | name identity existing payload newPayload newManifest manifestErr ttl heartbeat result guard |

    guard := self requireVerified: actorCtx for: 'worker heartbeat'.
    guard notNil ifTrue: [^guard].

    name := body at: 'name'.
    (name isString and: [name isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'name must be a non-empty string'
    ].

    identity := Identity worker: name.

    "Caller must have authenticated as this very worker."
    guard := self requireWorkerActor: actorCtx name: name verb: 'heartbeat'.
    guard notNil ifTrue: [^guard].

    existing := bbs rdp: 'worker' scope: '/' identity: identity.
    existing isNil ifTrue: [
      ^self errorResponse: 410
               message: 'worker tuple missing or expired — re-register'
    ].

    payload := existing at: 'payload' ifAbsent: [Dictionary new].
    newPayload := Dictionary new.
    payload keysAndValuesDo: [:k :v | newPayload at: k put: v].

    newManifest := body at: 'manifest' ifAbsent: [nil].
    newManifest notNil ifTrue: [
      (newManifest isKindOf: Dictionary) ifFalse: [
        ^self errorResponse: 400 message: 'manifest must be a dict'
      ].
      manifestErr := self validateWorkerManifest: newManifest.
      manifestErr notNil ifTrue: [^self errorResponse: 400 message: manifestErr].
      "Drain flag is preserved — do not let a manifest refresh clear it."
      newPayload at: 'manifest' put: newManifest
    ].

    newPayload at: 'heartbeat_at' put: DateTime now epochSeconds.

    heartbeat := self workerHeartbeatInterval.
    ttl := heartbeat * 3.

    bbs outAffine: 'worker' scope: '/' identity: identity
        payload: newPayload ttl: ttl actor: identity.

    result := Dictionary new.
    result at: 'ok' put: true.
    result at: 'ttl' put: ttl.
    ^self okResponse: result
  ]

  method: handleTaskCreate: body actor: actorCtx [
    "Handle /api/task/create — extracted to avoid method-size limit in route registration."
    | taskPayload id wfInst instanceId transId childSignalPayload parts actor bp |
    bp := self queueBackpressureResponse.
    bp notNil ifTrue: [^bp].
    actor := self actorOf: actorCtx.
    taskPayload := Dictionary new.
    taskPayload at: 'role' put: (body at: 'role').
    taskPayload at: 'status' put: 'pending'.
    taskPayload at: 'description' put: (body at: 'description').
    (body includesKey: 'workdir') ifTrue: [taskPayload at: 'workdir' put: (body at: 'workdir')].
    (body includesKey: 'workflow_instance') ifTrue: [taskPayload at: 'workflow_instance' put: (body at: 'workflow_instance')].
    (body includesKey: 'repo') ifTrue: [taskPayload at: 'repo' put: (body at: 'repo')].
    "Observational agent_identity (<human>/<workflow-instance>/<role>) —
     additive to the verified launched_by/actor signer; pp audit consumes
     this in a follow-up story."
    (body includesKey: 'agent_identity') ifTrue: [
      taskPayload at: 'agent_identity' put: (body at: 'agent_identity')
    ].
    "D6.5 multiplayer/claim vocabulary: lease + retry bookkeeping. Stamped
     with nil/0 defaults at creation; updated by /api/task/claim,
     /api/task/renew, and the dispatcher's failure path."
    taskPayload at: 'claim_id' put: nil.
    taskPayload at: 'worker_id' put: nil.
    taskPayload at: 'claim_expires_at' put: nil.
    taskPayload at: 'renewed_at' put: nil.
    taskPayload at: 'missed_renewals' put: 0.
    taskPayload at: 'retry_count' put: 0.
    taskPayload at: 'max_retries' put: 3.
    taskPayload at: 'last_failure_reason' put: nil.
    "Stamp launched_by with the verified signer (nil when anonymous so the
     key stays absent, preserving byte-compat)."
    id := bbs out: 'task' scope: (body at: 'scope') identity: (body at: 'identity') payload: taskPayload actor: actor launchedBy: actor executedBy: nil.
    "If spawned by another task (workflow_instance contains :task:), record parent-child link"
    (body includesKey: 'workflow_instance') ifTrue: [
      wfInst := body at: 'workflow_instance'.
      (wfInst includes: ':task:') ifTrue: [
        parts := wfInst split: ':task:'.
        instanceId := parts at: 0.
        transId := parts at: 1.
        childSignalPayload := Dictionary new.
        childSignalPayload at: 'child_task_id' put: (body at: 'identity').
        childSignalPayload at: 'child_scope' put: (body at: 'scope').
        bbs upsertSignal: instanceId identity: (Identity childTask: transId child: (body at: 'identity')) payload: childSignalPayload actor: actor
      ]
    ].
    self okResponse: (self okWithId: id)
  ]

  method: handleTaskClaim: body actor: actorCtx [
    "Handle POST /api/tasks/claim.

     Body: {task_id, worker_id, claim_id, lease_seconds?}. Must be signed by
     the worker keypair whose actor header is 'worker:<worker_id>'. Flips
     task status from 'pending' to 'claimed' atomically via BBS>>update:
     (BBS.mag:289, pattern from Scheduler.mag:58).

     D6.12 idempotency:
       - matching (task_id, claim_id, worker_id) already claimed → 200 no-op
       - status != pending with different claim/worker           → 409 conflict
       - pending → stamp claim and return 200 {claim_expires_at, retry_count}

     Lease: task.max_runtime overrides body.lease_seconds, which defaults to
     600s (D6.2). Emits a 'claim' event tuple on success."
    | taskId workerId claimId leaseSeconds task scope
      outcome now result expectedActor d workerTuple wPayload wManifest
      acceptFrom launchedBy guard |

    guard := self requireVerified: actorCtx for: 'task claim'.
    guard notNil ifTrue: [^guard].

    taskId := body at: 'task_id'.
    workerId := body at: 'worker_id'.
    claimId := body at: 'claim_id'.
    leaseSeconds := body at: 'lease_seconds' ifAbsent: [600].
    "Validate string fields. `isString` is not defined on String in
     Maggie (latent bug in the pre-existing checks); use isKindOf: instead."
    ((taskId isKindOf: String) and: [taskId isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'task_id must be a non-empty string'
    ].
    ((workerId isKindOf: String) and: [workerId isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'worker_id must be a non-empty string'
    ].
    ((claimId isKindOf: String) and: [claimId isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'claim_id must be a non-empty string'
    ].

    expectedActor := Identity worker: workerId.
    guard := self requireWorkerActor: actorCtx name: workerId verb: 'claim'.
    guard notNil ifTrue: [^guard].

    "Locate the task tuple — body carries no scope, so use O(1) byCatIdent lookup."
    task := bbs findByCategory: 'task' identity: taskId.
    task isNil ifTrue: [
      ^self errorResponse: 404 message: 'task not found: ', taskId
    ].
    scope := task at: 'scope'.

    "F3.1/F2.7 authoritative gate: re-check affinity + accept_from against
     the REGISTERED worker manifest. The /api/tasks/available offer is a
     hint; between offer and claim the manifest may have refreshed or the
     task's launched_by/affinity may differ from what was offered. Never
     trust claim-body declared fields here — always read from the stored
     worker tuple."
    workerTuple := bbs rdp: 'worker' scope: '/' identity: expectedActor.
    workerTuple isNil ifTrue: [
      ^self errorResponse: 410 message: 'worker tuple missing or expired — re-register'
    ].
    wPayload := workerTuple at: 'payload' ifAbsent: [Dictionary new].
    wManifest := wPayload at: 'manifest' ifAbsent: [Dictionary new].
    acceptFrom := wManifest at: 'accept_from' ifAbsent: [#()].
    launchedBy := task at: 'launched_by' ifAbsent: [nil].
    (self affinityMatchesTask: task manifest: wManifest workerId: workerId) ifFalse: [
      d := Dictionary new.
      d at: 'error' put: 'affinity mismatch: worker ineligible for this task'.
      ^self jsonResponse: 403 body: d
    ].
    (self acceptFromAllows: acceptFrom launchedBy: launchedBy) ifFalse: [
      d := Dictionary new.
      d at: 'error' put: 'accept_from refuses launched_by: ', launchedBy printString.
      ^self jsonResponse: 403 body: d
    ].

    "Capture outcome from inside the atomic block. outcome at: 0 = action,
     at: 1/2 = action-specific payload (expires/executed_by, retry/status)."
    outcome := Array new: 3.
    outcome at: 0 put: 'unknown'.
    now := DateTime now epochSeconds.

    result := bbs update: 'task' scope: scope identity: taskId do: [:p |
      | curStatus curClaim curWorker maxRt effectiveLease expiresAt |
      curStatus := p at: 'status' ifAbsent: [''].
      curClaim := p at: 'claim_id' ifAbsent: [nil].
      curWorker := p at: 'worker_id' ifAbsent: [nil].

      (curStatus = 'claimed' and: [curClaim = claimId and: [curWorker = workerId]])
        ifTrue: [
          "D6.12: matching (task, claim, worker) → idempotent replay."
          outcome at: 0 put: 'replay'.
          outcome at: 1 put: (p at: 'claim_expires_at' ifAbsent: [nil]).
          outcome at: 2 put: (p at: 'retry_count' ifAbsent: [0])
        ]
        ifFalse: [
          curStatus = 'pending'
            ifTrue: [
              "Winner: stamp claim fields atomically."
              maxRt := p at: 'max_runtime' ifAbsent: [nil].
              effectiveLease := maxRt isNil
                ifTrue: [leaseSeconds]
                ifFalse: [maxRt].
              expiresAt := now + effectiveLease.
              p at: 'status' put: 'claimed'.
              p at: 'worker_id' put: workerId.
              p at: 'claim_id' put: claimId.
              p at: 'executed_by' put: expectedActor.
              p at: 'claim_expires_at' put: expiresAt.
              p at: 'renewed_at' put: now.
              p at: 'missed_renewals' put: 0.
              outcome at: 0 put: 'claimed'.
              outcome at: 1 put: expiresAt.
              outcome at: 2 put: (p at: 'retry_count' ifAbsent: [0])
            ]
            ifFalse: [
              "D6.12: non-pending with non-matching identity → 409 conflict."
              outcome at: 0 put: 'conflict'.
              outcome at: 1 put: (p at: 'executed_by' ifAbsent: [nil]).
              outcome at: 2 put: curStatus
            ]
        ]
    ].

    result isNil ifTrue: [
      ^self errorResponse: 404 message: 'task not found: ', taskId
    ].

    (outcome at: 0) = 'conflict' ifTrue: [
      d := Dictionary new.
      d at: 'error' put: 'task already claimed'.
      d at: 'executed_by' put: (outcome at: 1).
      d at: 'status' put: (outcome at: 2).
      ^self jsonResponse: 409 body: d
    ].

    (outcome at: 0) = 'claimed' ifTrue: [
      bbs emitEvent: scope
          identity: 'claim:', taskId
          type: 'claim'
          summary: expectedActor, ' claimed ', taskId
          actor: expectedActor
    ].

    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: 'claim_expires_at' put: (outcome at: 1).
    d at: 'retry_count' put: (outcome at: 2).
    ^self okResponse: d
  ]

  method: repoNameMatches: name inRepos: repos [
    "Return true iff any entry in the manifest.repos array refers to
     the named repo. Supports both the canonical Dictionary form
     {name, path, head} (CliWorker parseRepos:) and legacy flat-string
     entries used in older tests."
    repos do: [:r |
      | rname |
      (r isKindOf: Dictionary)
        ifTrue: [rname := r at: 'name' ifAbsent: [nil]]
        ifFalse: [rname := r].
      rname = name ifTrue: [^true]
    ].
    ^false
  ]

  method: affinityMatchesTask: t manifest: mfst workerId: wid [
    "F3.1 affinity match. Returns true when task t's payload.affinity
     is compatible with the worker described by (mfst, wid). Supported
     affinity shapes (all keys AND together when multiple are present):
       - absent / nil / {team: true} → any worker (default broadcast).
       - {launcher_only: true}       → task.launched_by == manifest.operator.
       - {workers: [...]}            → 'worker:<wid>' ∈ list.
       - {model: m}                  → manifest.models includes m.
       - {repo: name@commit}         → manifest.repos has entry named
                                       <name>. The @commit portion is
                                       ADVISORY per requirements §6.5
                                       (commit drift logs a warning but
                                       does not fail the match)."
    | affinity tp launchedBy op models repos workers repoSpec repoParts repoName repoCommit |
    tp := t at: 'payload' ifAbsent: [Dictionary new].
    affinity := tp at: 'affinity' ifAbsent: [nil].
    affinity isNil ifTrue: [^true].
    (affinity isKindOf: Dictionary) ifFalse: [^true].
    (affinity at: 'team' ifAbsent: [false]) = true ifTrue: [^true].

    (affinity at: 'launcher_only' ifAbsent: [false]) = true ifTrue: [
      launchedBy := t at: 'launched_by' ifAbsent: [nil].
      op := mfst at: 'operator' ifAbsent: [nil].
      (launchedBy isNil or: [op isNil or: [(launchedBy = op) not]]) ifTrue: [^false]
    ].

    workers := affinity at: 'workers' ifAbsent: [nil].
    workers notNil ifTrue: [
      (workers includes: ('worker:', wid)) ifFalse: [^false]
    ].

    (affinity includesKey: 'model') ifTrue: [
      models := mfst at: 'models' ifAbsent: [#()].
      (models includes: (affinity at: 'model')) ifFalse: [^false]
    ].

    (affinity includesKey: 'repo') ifTrue: [
      repoSpec := affinity at: 'repo'.
      repoParts := repoSpec split: '@'.
      repoName := repoParts at: 0.
      repoCommit := repoParts size > 1 ifTrue: [repoParts at: 1] ifFalse: [nil].
      repos := mfst at: 'repos' ifAbsent: [#()].
      (self repoNameMatches: repoName inRepos: repos) ifFalse: [^false].
      "Advisory commit check (requirements §6.5 unresolved): log drift,
       still treat as a match."
      repoCommit notNil ifTrue: [
        ('Note: affinity commit check is advisory (', repoSpec, ')') println
      ]
    ].

    ^true
  ]

  method: acceptFromAllows: acceptFrom launchedBy: actor [
    "F2.7 accept_from enforcement. acceptFrom MUST be sourced from the
     REGISTERED worker manifest tuple — never from the claim request
     body. Semantics:
       - nil or empty list → permissive (CLI default today is #('*') so
         the empty case only arises in synthesized tests).
       - contains '*'      → wildcard, allow any launched_by.
       - otherwise         → require actor ∈ acceptFrom (string equality
         on the full identity, e.g. 'user:alice')."
    (acceptFrom isNil or: [acceptFrom isEmpty]) ifTrue: [^true].
    (acceptFrom includes: '*') ifTrue: [^true].
    actor isNil ifTrue: [^false].
    ^acceptFrom includes: actor
  ]

  method: handleTasksAvailable: body actor: actorCtx [
    "Handle POST /api/tasks/available.

     Body: {worker_id}. Worker-signed (X-PP-Actor must resolve to
     worker:<worker_id>). Server scans pending task tuples and returns
     the subset that match the worker's manifest:
       - task.role must appear in manifest.roles
       - task.repo (required) must appear in manifest.repos
       - task.model (optional) must appear in manifest.models when set
     Affinity (§4.4, F3.1) and accept_from (F2.7) are also enforced here
     as filtering hints; /api/tasks/claim re-checks authoritatively since
     the offer→claim gap is a race window. Response is capped at ~20 tasks
     and returned synchronously (no long-poll for v1)."
    | workerId expectedActor actorHeader workerTuple payload manifest
      roles repos models acceptFrom allTasks cap out d tp status role repo model guard |

    guard := self requireVerified: actorCtx for: 'tasks/available'.
    guard notNil ifTrue: [^guard].

    workerId := body at: 'worker_id'.
    ((workerId isKindOf: String) and: [workerId isEmpty not]) ifFalse: [
      ^self errorResponse: 400 message: 'worker_id must be a non-empty string'
    ].

    expectedActor := Identity worker: workerId.
    actorHeader := actorCtx actor.
    actorHeader = expectedActor ifFalse: [
      ^self errorResponse: 403
             message: 'tasks/available requires ', expectedActor, ' signer (got ', actorHeader printString, ')'
    ].

    workerTuple := bbs rdp: 'worker' scope: '/' identity: expectedActor.
    workerTuple isNil ifTrue: [
      ^self errorResponse: 410 message: 'worker tuple missing or expired — re-register'
    ].

    payload := workerTuple at: 'payload' ifAbsent: [Dictionary new].
    manifest := payload at: 'manifest' ifAbsent: [Dictionary new].
    roles := manifest at: 'roles' ifAbsent: [#()].
    repos := manifest at: 'repos' ifAbsent: [#()].
    models := manifest at: 'models' ifAbsent: [#()].
    acceptFrom := manifest at: 'accept_from' ifAbsent: [#()].

    allTasks := bbs scanAll: 'task'.
    cap := 20.
    out := Array new: 0.
    allTasks do: [:t |
      out size < cap ifTrue: [
        tp := t at: 'payload' ifAbsent: [Dictionary new].
        status := tp at: 'status' ifAbsent: [''].
        role := tp at: 'role' ifAbsent: [nil].
        repo := tp at: 'repo' ifAbsent: [nil].
        model := tp at: 'model' ifAbsent: [nil].
        ((status = 'pending')
          and: [(role notNil and: [roles includes: role])
          and: [(repo notNil and: [repos includes: repo])
          and: [(model isNil or: [models includes: model])
          and: [(self affinityMatchesTask: t manifest: manifest workerId: workerId)
          and: [self acceptFromAllows: acceptFrom launchedBy: (t at: 'launched_by' ifAbsent: [nil])]]]]])
          ifTrue: [out := out copyWith: t]
      ]
    ].

    d := Dictionary new.
    d at: 'tasks' put: out.
    d at: 'count' put: out size.
    ^self okResponse: d
  ]

  method: handleTaskComplete: body actor: actorCtx [
    "Handle POST /api/tasks/complete — D6.5 claim/lease completion.

     Body: {task_id, worker_id, claim_id, status in {completed, failed}, reason?}.

     Semantics:
       (1) If stored payload.claim_id != request claim_id: treat as LATE
           COMPLETION (F3.4). Emit an event tuple with identity
           late-completion:<task_id> carrying {worker_id, claim_id,
           submitted_status}. Return 409 with current executed_by. Do NOT
           clobber state.
       (2) On claim match, status=completed: set status=completed, clear
           claim_expires_at.
       (3) status=failed AND reason=repo-not-available (D6.5 carveout):
           flip back to pending, clear worker_id/claim_id/executed_by/
           claim_expires_at, DO NOT bump retry_count, set
           last_failure_reason=repo-not-available.
       (4) status=failed with any other reason: set status=failed,
           last_failure_reason=reason, DO NOT touch retry_count. Reaper
           owns retry_count; regular failures are terminal unless the
           repo-not-available carveout applies.
     Emits a completion event tuple on branches (2)/(3)/(4)."
    | taskId workerId claimId status reason task scope payload storedClaimId executedBy eventPayload actorStr updated d eventType guard |

    guard := self requireVerified: actorCtx for: 'task complete'.
    guard notNil ifTrue: [^guard].

    taskId := body at: 'task_id'.
    workerId := body at: 'worker_id'.
    claimId := body at: 'claim_id'.
    status := body at: 'status'.
    reason := body at: 'reason' ifAbsent: [nil].

    (status = 'completed' or: [status = 'failed']) ifFalse: [
      ^self errorResponse: 400 message: 'status must be completed or failed'
    ].

    task := bbs findByCategory: 'task' identity: taskId.
    task isNil ifTrue: [^self errorResponse: 404 message: 'task not found: ', taskId].
    scope := task at: 'scope'.
    payload := task at: 'payload'.
    storedClaimId := payload at: 'claim_id' ifAbsent: [nil].

    actorStr := self actorOf: actorCtx.

    "Late-completion branch (F3.4). Stored claim must exist AND mismatch."
    (storedClaimId notNil and: [(storedClaimId = claimId) not]) ifTrue: [
      executedBy := payload at: 'executed_by' ifAbsent: [nil].
      eventPayload := Dictionary new.
      eventPayload at: 'type' put: 'late-completion'.
      eventPayload at: 'worker_id' put: workerId.
      eventPayload at: 'claim_id' put: claimId.
      eventPayload at: 'submitted_status' put: status.
      bbs out: 'event' scope: scope
          identity: 'late-completion:', taskId
          payload: eventPayload actor: actorStr.
      d := Dictionary new.
      d at: 'error' put: 'late completion: task already reclaimed'.
      d at: 'executed_by' put: executedBy.
      ^self jsonResponse: 409 body: d
    ].

    "Atomic update via BBS>>update: — rewrites the linear task tuple."
    updated := bbs update: 'task' scope: scope identity: taskId do: [:p |
      status = 'completed' ifTrue: [
        p at: 'status' put: 'completed'.
        p at: 'claim_expires_at' put: nil.
        p at: 'completed_at' put: DateTime now epochSeconds
      ] ifFalse: [
        "status = 'failed'"
        reason = 'repo-not-available' ifTrue: [
          "D6.5 carveout: recycle back to pending without burning a retry."
          p at: 'status' put: 'pending'.
          p at: 'worker_id' put: nil.
          p at: 'claim_id' put: nil.
          p at: 'executed_by' put: nil.
          p at: 'claim_expires_at' put: nil.
          p at: 'last_failure_reason' put: 'repo-not-available'
        ] ifFalse: [
          "Regular failure: terminal. Reaper owns retry_count."
          p at: 'status' put: 'failed'.
          p at: 'last_failure_reason' put: (reason isNil ifTrue: ['unknown'] ifFalse: [reason]).
          p at: 'failed_at' put: DateTime now epochSeconds
        ]
      ]
    ].
    updated isNil ifTrue: [^self errorResponse: 404 message: 'task not found: ', taskId].

    "Emit completion event tuple."
    status = 'completed'
      ifTrue: [eventType := 'task-completed']
      ifFalse: [eventType := 'task-failed'].
    eventPayload := Dictionary new.
    eventPayload at: 'type' put: eventType.
    eventPayload at: 'worker_id' put: workerId.
    eventPayload at: 'claim_id' put: claimId.
    eventPayload at: 'status' put: status.
    reason notNil ifTrue: [eventPayload at: 'reason' put: reason].
    bbs out: 'event' scope: scope
        identity: 'task-complete:', taskId
        payload: eventPayload actor: actorStr.

    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: 'task_id' put: taskId.
    ^self okResponse: d
  ]

  method: handleTaskRenew: body actor: actorCtx [
    "Handle POST /api/tasks/renew (D6.x lease renewal).

     Body: {task_id, worker_id, claim_id, scope}. The (claim_id, worker_id)
     pair is the per-claim capability stamped on /api/task/claim. We use
     BBS>>update: to atomically inspect and (on match) extend the lease:

       - Match: set claim_expires_at = now + lease, renewed_at = now,
         missed_renewals = 0. Lease defaults to 600s; if the task payload
         carries a positive numeric max_runtime, that value is used as the
         lease window instead. retry_count is intentionally NOT modified.
       - Mismatch (different claim_id and/or worker_id, including the
         post-reap+reclaim case where a new worker now owns the task):
         payload is left intact; respond 409 with the current executed_by.
       - No tuple by (scope, task_id): 404."
    | scope taskId workerId claimId existing mismatch newExpires now lease
      maxRuntime updateId currentExecutedBy currentClaim currentWorker err result |
    scope := body at: 'scope'.
    taskId := body at: 'task_id'.
    workerId := body at: 'worker_id'.
    claimId := body at: 'claim_id'.

    existing := bbs rdp: 'task' scope: scope identity: taskId.
    existing isNil ifTrue: [
      ^self errorResponse: 404 message: 'task not found: ', taskId printString
    ].

    mismatch := false.
    newExpires := nil.
    currentClaim := nil.
    currentWorker := nil.
    currentExecutedBy := existing at: 'executed_by' ifAbsent: [nil].
    updateId := bbs update: 'task' scope: scope identity: taskId do: [:p |
      currentClaim := p at: 'claim_id' ifAbsent: [nil].
      currentWorker := p at: 'worker_id' ifAbsent: [nil].
      (currentClaim = claimId and: [currentWorker = workerId])
        ifTrue: [
          lease := 600.
          (p includesKey: 'max_runtime') ifTrue: [
            maxRuntime := p at: 'max_runtime'.
            (maxRuntime notNil and: [maxRuntime > 0])
              ifTrue: [lease := maxRuntime]
          ].
          now := DateTime now epochSeconds.
          newExpires := now + lease.
          p at: 'claim_expires_at' put: newExpires.
          p at: 'renewed_at' put: now.
          p at: 'missed_renewals' put: 0
        ]
        ifFalse: [mismatch := true]
    ].
    updateId isNil ifTrue: [
      ^self errorResponse: 404 message: 'task not found: ', taskId printString
    ].

    mismatch ifTrue: [
      err := Dictionary new.
      err at: 'error' put: 'claim mismatch'.
      err at: 'task_id' put: taskId.
      err at: 'executed_by' put: (currentExecutedBy isNil ifTrue: [currentWorker] ifFalse: [currentExecutedBy]).
      err at: 'claim_id' put: currentClaim.
      err at: 'worker_id' put: currentWorker.
      ^self jsonResponse: 409 body: err
    ].

    result := Dictionary new.
    result at: 'ok' put: true.
    result at: 'task_id' put: taskId.
    result at: 'claim_expires_at' put: newExpires.
    result at: 'renewed_at' put: now.
    result at: 'lease_seconds' put: lease.
    ^self okResponse: result
  ]

  "--- Helpers ---"

  method: applyScanFilters: tuples body: body [
    "Apply optional actor/worker/workflow filters to scan results.
     Each filter ANDs with the others. Filters look up payload fields:
       body 'actor'    -> payload 'actor'
       body 'worker'   -> payload 'executed_by'
       body 'workflow' -> payload 'workflow_instance'
     Tuples missing the relevant payload key never match. Returns the
     filtered collection (or the original when no filters are present)."
    | result wantActor wantWorker wantWf |
    result := tuples.
    (body includesKey: 'actor') ifTrue: [
      wantActor := body at: 'actor'.
      result := result select: [:t |
        ((t at: 'payload' ifAbsent: [Dictionary new]) at: 'actor' ifAbsent: [nil]) = wantActor
      ]
    ].
    (body includesKey: 'worker') ifTrue: [
      wantWorker := body at: 'worker'.
      result := result select: [:t |
        ((t at: 'payload' ifAbsent: [Dictionary new]) at: 'executed_by' ifAbsent: [nil]) = wantWorker
      ]
    ].
    (body includesKey: 'workflow') ifTrue: [
      wantWf := body at: 'workflow'.
      result := result select: [:t |
        ((t at: 'payload' ifAbsent: [Dictionary new]) at: 'workflow_instance' ifAbsent: [nil]) = wantWf
      ]
    ].
    ^result
  ]

  method: jsonResponse: statusCode body: dict [
    | resp |
    resp := HttpResponse new: statusCode body: (Json encode: dict).
    resp contentType: 'application/json'.
    ^resp
  ]

  method: okResponse: dict [
    ^self jsonResponse: 200 body: dict
  ]

  method: queueMaxPending [ ^queueMaxPending ]

  method: countPendingTasks [
    "Count task tuples whose payload.status = 'pending'. Used for
     D6.11 / §4.10 queue backpressure."
    | tasks n |
    n := 0.
    tasks := bbs scanAll: 'task'.
    tasks do: [:t |
      | p status |
      p := t at: 'payload'.
      status := p at: 'status' ifAbsent: [''].
      status = 'pending' ifTrue: [n := n + 1]
    ].
    ^n
  ]

  method: queueBackpressureResponse [
    "If [queue].max_pending is configured and the current pending-task
     depth meets or exceeds it, return a 429 HttpResponse carrying
     {error, code=queue_full, depth, max_pending}. Otherwise nil."
    | depth d |
    queueMaxPending isNil ifTrue: [^nil].
    depth := self countPendingTasks.
    depth < queueMaxPending ifTrue: [^nil].
    d := Dictionary new.
    d at: 'error' put: 'queue full'.
    d at: 'code' put: 'queue_full'.
    d at: 'depth' put: depth.
    d at: 'max_pending' put: queueMaxPending.
    ^self jsonResponse: 429 body: d
  ]

  method: errorResponse: statusCode message: msg [
    | d |
    d := Dictionary new.
    d at: 'error' put: msg.
    ^self jsonResponse: statusCode body: d
  ]

  method: parseBody: req [
    "Parse JSON request body into a Dictionary. Returns nil on parse failure."
    | result |
    result := nil.
    [result := Json decode: req body] on: Exception do: [:e | result := nil].
    ^result
  ]

  method: requireFields: fields in: dict [
    "Check that all required fields are present. Returns error message or nil."
    fields do: [:f |
      (dict includesKey: f) ifFalse: [
        ^'Missing required field: ', f
      ]
    ].
    ^nil
  ]

  method: post: path fields: fields do: aBlock [
    "Register a POST route with auto JSON parsing and field validation.
     aBlock receives the parsed body Dictionary."
    httpServer route: path method: 'POST' handler: [:req |
      | body err |
      body := self parseBody: req.
      body isNil ifTrue: [self errorResponse: 400 message: 'Invalid JSON'] ifFalse: [
        err := self requireFields: fields in: body.
        err notNil ifTrue: [self errorResponse: 400 message: err] ifFalse: [
          aBlock value: body
        ]
      ]
    ]
  ]

  method: signedPost: path fields: fields do: aBlock [
    "Register a mutating POST route that requires a valid ed25519 signature
     when [security].enforce_signatures is true. aBlock receives
     (body, actorCtx). When enforcement is off, actorCtx is an anonymous
     placeholder so existing behavior is preserved bit-for-bit (tuples gain
     an actor='anonymous' stamp only when actor: is non-nil)."
    httpServer route: path method: 'POST' handler: [:req |
      | body err actorCtx |
      body := self parseBody: req.
      body isNil ifTrue: [self errorResponse: 400 message: 'Invalid JSON'] ifFalse: [
        err := self requireFields: fields in: body.
        err notNil ifTrue: [self errorResponse: 400 message: err] ifFalse: [
          actorCtx := signatureVerifier verify: req adminList: adminList skewSeconds: skewSeconds.
          (enforceSignatures and: [actorCtx isNil])
            ifTrue: [self errorResponse: 401 message: 'Signature verification failed']
            ifFalse: [
              actorCtx isNil ifTrue: [actorCtx := ActorContext anonymous].
              aBlock value: body value: actorCtx
            ]
        ]
      ]
    ]
  ]

  method: signedRouteOnly: path do: aBlock [
    "Register a raw mutating POST route that requires a valid signature when
     enforcement is enabled. aBlock receives (req, actorCtx)."
    httpServer route: path method: 'POST' handler: [:req |
      | actorCtx |
      actorCtx := signatureVerifier verify: req adminList: adminList skewSeconds: skewSeconds.
      (enforceSignatures and: [actorCtx isNil])
        ifTrue: [self errorResponse: 401 message: 'Signature verification failed']
        ifFalse: [
          actorCtx isNil ifTrue: [actorCtx := ActorContext anonymous].
          aBlock value: req value: actorCtx
        ]
    ]
  ]

  method: validateWitness: witnessedBy [
    "Validate a client-supplied witnessed_by field (D6.1).
     nil is valid (witness omitted). Otherwise, witnessedBy must name an
     existing identity tuple (category=identity, scope='/', identity=<value>)
     whose status is not 'revoked'. Returns an error message string on
     failure, or nil on success. Uses the same lookup path as
     SignatureVerifier>>verify:... to guarantee a single source of truth."
    | idTuple payload status |
    witnessedBy isNil ifTrue: [^nil].
    (witnessedBy isString and: [witnessedBy isEmpty not]) ifFalse: [
      ^'Invalid witnessed_by: must be a non-empty string'
    ].
    idTuple := bbs rdp: 'identity' scope: '/' identity: witnessedBy.
    idTuple isNil ifTrue: [
      ^'Invalid witnessed_by: no identity registered for ', witnessedBy
    ].
    payload := idTuple at: 'payload' ifAbsent: [Dictionary new].
    status := payload at: 'status' ifAbsent: ['active'].
    status = 'revoked' ifTrue: [
      ^'Invalid witnessed_by: identity ', witnessedBy, ' is revoked'
    ].
    ^nil
  ]

  method: actorOf: actorCtx [
    "Return the actor string to stamp on BBS writes, or nil when the context
     is anonymous (so on-disk tuples remain byte-identical to pre-signing)."
    actorCtx isNil ifTrue: [^nil].
    actorCtx verified ifFalse: [^nil].
    ^actorCtx actor
  ]

  method: requireVerified: actorCtx for: aVerb [
    "Shared preamble for signed worker endpoints. Returns nil to allow the
     caller to proceed, or an HttpResponse the caller must short-circuit
     return. When signatures are enforced, an unverified context yields
     401; when unenforced, 503 with a verb-specific message so operators
     understand which endpoint is gated on enforce_signatures=true."
    actorCtx verified ifFalse: [
      enforceSignatures
        ifTrue: [^self errorResponse: 401 message: 'signature verification failed']
        ifFalse: [^self errorResponse: 503
                         message: 'enforce_signatures must be true for ', aVerb]
    ].
    ^nil
  ]

  method: requireWorkerActor: actorCtx name: aName verb: aVerb [
    "Shared guard: the verified actor must equal worker:<aName>. Returns nil
     to allow the caller to proceed, or a 403 HttpResponse the caller must
     short-circuit return. Error string is normalised across all call sites
     into one shape: '<verb> requires <expected> signer (got <actor>)'."
    | expected actorStr |
    expected := Identity worker: aName.
    actorStr := actorCtx actor.
    actorStr = expected ifFalse: [
      ^self errorResponse: 403
             message: aVerb, ' requires ', expected, ' signer (got ', actorStr printString, ')'
    ].
    ^nil
  ]

  method: get: path do: aBlock [
    "Register a GET route. aBlock receives the request."
    httpServer route: path method: 'GET' handler: [:req | aBlock value: req]
  ]

  method: asyncGet: path do: aBlock [
    "Register a GET route whose handler runs in a forked goroutine, not the
     dispatch queue. Use for handlers that block inside Maggie (e.g. the
     long-poll notification stream) so they cannot stall other requests."
    httpServer asyncRoute: path method: 'GET' handler: [:req | aBlock value: req]
  ]

  method: makeResult: key value: val [
    | d |
    d := Dictionary new.
    d at: key put: val.
    ^d
  ]

  method: okStatus [
    | d |
    d := Dictionary new.
    d at: 'status' put: 'ok'.
    ^d
  ]

  method: okWithId: anId [
    | d |
    d := Dictionary new.
    d at: 'id' put: anId.
    d at: 'status' put: 'ok'.
    ^d
  ]

  method: okWithIdentity: anIdentity [
    | d |
    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: 'identity' put: anIdentity.
    ^d
  ]

  method: okWithCount: key count: aCount [
    | d |
    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: key put: aCount.
    ^d
  ]

  method: okWithWorkflow: wfId type: aType [
    | d |
    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: 'workflow_id' put: wfId.
    d at: 'type' put: aType.
    ^d
  ]

  "--- Health ---"

  method: handleHealth: req [
    | d metrics |
    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: 'tuples' put: bbs size.
    d at: 'uptime' put: bbs uptime.
    metrics := self computeMetrics.
    metrics keysAndValuesDo: [:k :v | d at: k put: v].
    ^self okResponse: d
  ]

  method: computeMetrics [
    "Compute scheduler/task metrics for the health endpoint."
    | d tasks events now pending active completedDurations totalDur errCount scheduler pinnedWorkitems |
    d := Dictionary new.
    now := DateTime now epochSeconds.

    "Scheduler slot metrics — if dispatcher is attached"
    dispatcher notNil ifTrue: [
      scheduler := dispatcher scheduler.
      scheduler notNil ifTrue: [
        d at: 'active_slots' put: scheduler activeCount.
        d at: 'max_slots' put: scheduler maxSlots
      ]
    ] ifFalse: [
      d at: 'active_slots' put: 0.
      d at: 'max_slots' put: 0
    ].

    "Task counts and average duration"
    pending := 0.
    active := 0.
    totalDur := 0.
    completedDurations := 0.
    tasks := bbs scanAll: 'task'.
    tasks do: [:t |
      | p status dispatchedAt completedAt |
      p := t at: 'payload'.
      status := p at: 'status' ifAbsent: [''].
      status = 'pending' ifTrue: [pending := pending + 1].
      (status = 'dispatched' or: [status = 'running']) ifTrue: [active := active + 1].
      status = 'completed' ifTrue: [
        dispatchedAt := p at: 'dispatched_at' ifAbsent: [nil].
        completedAt := p at: 'completed_at' ifAbsent: [nil].
        (dispatchedAt notNil and: [completedAt notNil]) ifTrue: [
          totalDur := totalDur + (completedAt - dispatchedAt).
          completedDurations := completedDurations + 1
        ]
      ]
    ].
    d at: 'pending_tasks' put: pending.
    d at: 'active_tasks' put: active.
    completedDurations > 0
      ifTrue: [d at: 'avg_task_duration_s' put: (totalDur // completedDurations)]
      ifFalse: [d at: 'avg_task_duration_s' put: 0].

    "Error count in last hour — task-failed or scope-violation events"
    errCount := 0.
    events := bbs scanAll: 'event'.
    events do: [:e |
      | ep etype ts |
      ep := e at: 'payload'.
      etype := ep at: 'type' ifAbsent: [''].
      ts := e at: 'created_at' ifAbsent: [0].
      ((etype = 'task-failed' or: [etype = 'scope-violation']) and:
        [(now - ts) <= 3600]) ifTrue: [
        errCount := errCount + 1
      ]
    ].
    d at: 'error_count_last_hour' put: errCount.

    ^d
  ]

  "--- Core Operations ---"

  method: handleOut: req actor: actorCtx [
    | body err id category payload pinned ttl actor |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].

    err := self requireFields: #('category' 'scope' 'identity') in: body.
    err notNil ifTrue: [^self errorResponse: 400 message: err].

    category := body at: 'category'.
    (Categories isValid: category) ifFalse: [
      ^self errorResponse: 400 message: 'Invalid category: ', category
    ].

    payload := body at: 'payload' ifAbsent: [Dictionary new].
    pinned := body at: 'pinned' ifAbsent: [false].
    ttl := body at: 'ttl' ifAbsent: [0].
    actor := self actorOf: actorCtx.

    pinned ifTrue: [
      id := bbs outPinned: category scope: (body at: 'scope') identity: (body at: 'identity') payload: payload actor: actor
    ] ifFalse: [
      ttl > 0
        ifTrue: [
          id := bbs outAffine: category scope: (body at: 'scope') identity: (body at: 'identity') payload: payload ttl: ttl actor: actor
        ]
        ifFalse: [
          id := bbs out: category scope: (body at: 'scope') identity: (body at: 'identity') payload: payload actor: actor
        ]
    ].

    ^self okResponse: (self okWithId: id)
  ]

  "--- Convenience Endpoints ---"

  method: handleNotifications: req [
    | since notifications filtered d identity watchSet |
    since := req queryParam: 'since'.
    since isNil ifTrue: [since := 0] ifFalse: [since := since asInteger].

    identity := self notifyIdentityFor: req.
    watchSet := self watchWorkflowsFor: identity.

    notifications := bbs scanAll: 'notification'.
    filtered := notifications select: [:n |
      ((n at: 'created_at' ifAbsent: [0]) >= since)
        and: [self notification: n visibleTo: identity watches: watchSet]
    ].

    d := Dictionary new.
    d at: 'notifications' put: filtered.
    d at: 'count' put: filtered size.
    ^self okResponse: d
  ]

  method: notifyIdentityFor: req [
    "Resolve the signed caller identity for a GET request. Returns the
     actor string (e.g. 'user:alice') or nil when the request cannot be
     verified. In --local (enforceSignatures=false) mode, verification
     failures fall through as nil — callers then broadcast all
     notifications to preserve legacy behaviour."
    | actorCtx |
    actorCtx := signatureVerifier verify: req adminList: adminList skewSeconds: skewSeconds.
    actorCtx isNil ifTrue: [
      actorCtx := signatureVerifier verifySSE: req adminList: adminList skewSeconds: skewSeconds
    ].
    actorCtx isNil ifTrue: [^nil].
    ^actorCtx actor
  ]

  method: watchWorkflowsFor: identity [
    "Collect the set of workflow_ids the given identity has an active watch
     tuple for. Returns an empty Array for nil/empty identities.

     §6 short-TTL per-identity cache: handleNotificationStream: and
     handleNotifications: each call this once per request and the result
     is reused immediately within the request — but back-to-back polls
     from the same client redo the full scanAll: 'watch'. Cache for 2 s."
    | watches result prefix now expires cached |
    (identity isNil or: [identity isEmpty]) ifTrue: [^Array new: 0].
    now := DateTime now epochSeconds.
    expires := watchCacheExpiry at: identity ifAbsent: [nil].
    (expires notNil and: [now < expires]) ifTrue: [
      cached := watchCache at: identity ifAbsent: [nil].
      cached notNil ifTrue: [^cached]
    ].
    watches := bbs scanAll: 'watch'.
    result := Array new: 0.
    prefix := identity, ':'.
    watches do: [:w |
      | p wfId wid owner matches |
      p := w at: 'payload' ifAbsent: [Dictionary new].
      wid := w at: 'identity' ifAbsent: [''].
      wfId := p at: 'workflow_id' ifAbsent: [nil].
      (wfId isNil and: [wid startsWith: prefix]) ifTrue: [
        "Fallback: parse identity tuple '<user>:<wfId>'."
        wfId := StringUtil stripPrefix: prefix from: wid
      ].
      owner := p at: 'user' ifAbsent: [nil].
      matches := (owner = identity) or: [wid startsWith: prefix].
      (matches and: [wfId notNil and: [wfId isEmpty not]]) ifTrue: [
        result := result copyWith: wfId
      ]
    ].
    watchCache at: identity put: result.
    watchCacheExpiry at: identity put: now + 2.
    "Bound cache size — wholesale clear on overflow."
    watchCache size > 1024 ifTrue: [
      watchCache := Dictionary new.
      watchCacheExpiry := Dictionary new
    ].
    ^result
  ]

  method: notification: n visibleTo: identity watches: watchSet [
    "§4.8 (F8.1) per-identity visibility. When identity is nil (unsigned
     --local mode) every notification is visible. Otherwise, include
     iff: identity equals launched_by, OR identity appears in the
     payload observers array, OR the watchSet contains the notification's
     workflow_id (derived from scope='wf-...' or payload.workflow_instance)."
    | p launchedBy observers scope workflow |
    identity isNil ifTrue: [^true].
    launchedBy := n at: 'launched_by' ifAbsent: [nil].
    launchedBy = identity ifTrue: [^true].
    p := n at: 'payload' ifAbsent: [Dictionary new].
    observers := p at: 'observers' ifAbsent: [nil].
    (observers notNil and: [observers isKindOf: Array]) ifTrue: [
      observers do: [:o | o = identity ifTrue: [^true]]
    ].
    watchSet isEmpty ifFalse: [
      scope := n at: 'scope' ifAbsent: [''].
      scope isNil ifTrue: [scope := ''].
      workflow := (scope startsWith: 'wf-')
        ifTrue: [scope]
        ifFalse: [p at: 'workflow_instance' ifAbsent: ['']].
      (workflow notNil and: [workflow isEmpty not]) ifTrue: [
        watchSet do: [:w | w = workflow ifTrue: [^true]]
      ]
    ].
    ^false
  ]

  method: handleNotificationStream: req [
    "GET /api/notifications/stream?since=<epoch>&wait=<0|1> — long-polling notification stream.
     Returns notifications since the given epoch. If none found and wait!=0, holds
     the request for up to 10 seconds.

     Implementation: an initial `scanAll: 'notification'` returns any
     backlog matching `since`. If empty and wait>0 the handler subscribes
     to the NotificationHub and sleeps on its own per-subscriber pending
     queue (no further BBS scans). When a new notification is written,
     BBS pushes it through the hub which evaluates each subscriber's
     filter once and appends to the matching pending queues. This
     replaces the prior 20× (scanAll:notification + scanAll:watch) loop
     under the BBS mutex; see docs/scout-perf-survey-2026-04-28.md §2."
    | since wait notifications filtered mapped d i obj p identity watchSet sub filterBlock pending |
    since := req queryParam: 'since'.
    since isNil ifTrue: [since := 0] ifFalse: [since := since asInteger].
    wait := req queryParam: 'wait'.
    wait isNil ifTrue: [wait := 1] ifFalse: [wait := wait asInteger].

    identity := self notifyIdentityFor: req.
    watchSet := self watchWorkflowsFor: identity.

    "Initial backlog scan (single scanAll, exactly as before)."
    notifications := bbs scanAll: 'notification'.
    filtered := notifications select: [:n |
      ((n at: 'created_at' ifAbsent: [0]) >= since)
        and: [self notification: n visibleTo: identity watches: watchSet]
    ].

    "Long-poll fan-out: subscribe and sleep on the hub. Filter captures
     identity + watchSet at subscribe time; new watch tuples added mid-poll
     surface on the next /stream request rather than scanning per-tick."
    (filtered isEmpty and: [wait > 0]) ifTrue: [
      filterBlock := [:n |
        ((n at: 'created_at' ifAbsent: [0]) >= since)
          and: [self notification: n visibleTo: identity watches: watchSet]].
      sub := notificationHub subscribe: filterBlock.
      i := 0.
      "10s budget in 100ms cheap polls — no BBS scan, just a
       per-subscription pending-array length check under the hub mutex."
      [(notificationHub pendingFor: sub) isEmpty and: [i < 100]] whileTrue: [
        Process sleep: 100.
        i := i + 1
      ].
      pending := notificationHub drain: sub.
      notificationHub unsubscribe: sub.
      pending isEmpty ifFalse: [filtered := pending]
    ].

    "Map to response format — message and severity live inside payload"
    mapped := filtered collect: [:n |
      p := n at: 'payload' ifAbsent: [Dictionary new].
      obj := Dictionary new.
      obj at: 'id' put: (n at: 'id' ifAbsent: ['']).
      obj at: 'message' put: (p at: 'message' ifAbsent: ['']).
      obj at: 'severity' put: (p at: 'severity' ifAbsent: ['info']).
      obj at: 'scope' put: (n at: 'scope' ifAbsent: ['system']).
      obj at: 'created_at' put: (n at: 'created_at' ifAbsent: [0]).
      obj
    ].

    d := Dictionary new.
    d at: 'ok' put: true.
    d at: 'notifications' put: mapped.
    d at: 'count' put: mapped size.
    ^self okResponse: d
  ]

  "--- Workflow Status ---"

  method: handleWorkflowStatus: req [
    "POST /api/workflow/status — get workflow status by ID.
     Body: {workflow_id, scope?}
     Returns: {status, workflow_id, template, started_at, ...}"
    | body wfId scope wf wfPayload d |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].

    wfId := body at: 'workflow_id' ifAbsent: [nil].
    wfId isNil ifTrue: [^self errorResponse: 400 message: 'workflow_id required'].
    scope := body at: 'scope' ifAbsent: ['default'].

    "Find the workflow — try given scope, then scan all"
    wf := bbs rdp: 'workflow' scope: scope identity: wfId.
    wf isNil ifTrue: [
      wf := bbs findByCategory: 'workflow' identity: wfId
    ].
    wf isNil ifTrue: [^self errorResponse: 404 message: 'workflow not found'].

    wfPayload := wf at: 'payload'.
    d := Dictionary new.
    d at: 'workflow_id' put: wfId.
    d at: 'status' put: (wfPayload at: 'status' ifAbsent: ['unknown']).
    d at: 'template' put: (wfPayload at: 'template' ifAbsent: ['?']).
    d at: 'started_at' put: (wfPayload at: 'started_at' ifAbsent: [0]).
    (wfPayload at: 'completed_at' ifAbsent: [nil]) notNil ifTrue: [
      d at: 'completed_at' put: (wfPayload at: 'completed_at')
    ].
    (wfPayload at: 'failed_at' ifAbsent: [nil]) notNil ifTrue: [
      d at: 'failed_at' put: (wfPayload at: 'failed_at').
      d at: 'failure_reason' put: (wfPayload at: 'failure_reason' ifAbsent: [''])
    ].
    ^self okResponse: d
  ]

  "--- Workflow Cancel ---"

  method: handleWorkflowCancel: req actor: actorCtx [
    "POST /api/workflow/cancel — cancel a running workflow and all child workflows.

     D6.15 authority rules:
       - body.reason is required; must be non-empty after stripping whitespace.
       - Authorized cancellers = {launched-by of workflow} ∪ {operators of
         workers holding active claims on tasks in this workflow} ∪ admins.
       - Any other caller → 403."
    | body |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].
    ^self handleWorkflowCancelBody: body actor: actorCtx
  ]

  method: handleWorkflowCancelBody: body actor: actorCtx [
    "Body-driven workflow cancellation (direct entry point for tests)."
    | wfId scope reasonRaw reason wf payload taskStatus launchedBy
      authoritySet tasks taskId opPubkey workerTuple workerPayload
      identities identityMatch actorStr cancelledCount d |
    wfId := body at: 'workflow_id' ifAbsent: [nil].
    wfId isNil ifTrue: [^self errorResponse: 400 message: 'workflow_id required'].

    scope := body at: 'scope' ifAbsent: ['default'].

    "D6.15: --reason is mandatory, non-empty after strip"
    reasonRaw := body at: 'reason' ifAbsent: [nil].
    reasonRaw isNil ifTrue: [^self errorResponse: 400 message: 'reason required'].
    (reasonRaw isKindOf: String) ifFalse: [
      ^self errorResponse: 400 message: 'reason must be a string'
    ].
    reason := reasonRaw trimBoth.
    reason isEmpty ifTrue: [
      ^self errorResponse: 400 message: 'reason required (non-empty after stripping whitespace)'
    ].

    "Check workflow exists"
    wf := bbs rdp: 'workflow' scope: scope identity: wfId.
    wf isNil ifTrue: [^self errorResponse: 404 message: 'workflow not found'].

    "Check workflow is not already terminal"
    payload := wf at: 'payload'.
    taskStatus := payload at: 'status' ifAbsent: ['unknown'].
    (taskStatus = 'completed' or: [taskStatus = 'cancelled']) ifTrue: [
      ^self errorResponse: 409 message: 'workflow already ', taskStatus
    ].

    "--- D6.15 authority computation ---"
    actorStr := self actorOf: actorCtx.
    (actorStr isNil or: [actorStr isEmpty]) ifTrue: [
      ^self errorResponse: 401 message: 'authenticated actor required'
    ].

    authoritySet := Dictionary new.

    "1) launched-by of the workflow"
    launchedBy := wf at: 'launched_by' ifAbsent: [payload at: 'launched_by' ifAbsent: [nil]].
    (launchedBy notNil and: [launchedBy isEmpty not]) ifTrue: [
      authoritySet at: launchedBy put: true
    ].

    "2) operators of workers with active claims on tasks in this workflow.
        Resolve: task.worker_id → worker tuple at scope=/ → operator_pubkey →
        identity tuple (user:<name>) whose pubkey matches."
    identities := bbs scan: 'identity' scope: '/'.
    tasks := bbs scan: 'task' scope: scope.
    tasks do: [:t |
      | tp tStatus twid |
      tp := t at: 'payload' ifAbsent: [Dictionary new].
      ((tp at: 'workflow_instance' ifAbsent: ['']) = wfId) ifTrue: [
        tStatus := tp at: 'status' ifAbsent: [''].
        twid := tp at: 'worker_id' ifAbsent: [nil].
        "An 'active claim' = task dispatched or claimed and worker_id set."
        (tStatus = 'dispatched' and: [twid notNil and: [twid isEmpty not]]) ifTrue: [
          workerTuple := bbs rdp: 'worker' scope: '/' identity: twid.
          workerTuple notNil ifTrue: [
            workerPayload := workerTuple at: 'payload' ifAbsent: [Dictionary new].
            opPubkey := workerPayload at: 'operator_pubkey' ifAbsent: [nil].
            (opPubkey notNil and: [opPubkey isEmpty not]) ifTrue: [
              identityMatch := identities detect: [:id |
                | idPayload idName |
                idName := id at: 'identity' ifAbsent: [''].
                idPayload := id at: 'payload' ifAbsent: [Dictionary new].
                (idName startsWith: 'user:') and: [
                  (idPayload at: 'pubkey' ifAbsent: [nil]) = opPubkey
                ]
              ] ifNone: [nil].
              identityMatch notNil ifTrue: [
                authoritySet at: (identityMatch at: 'identity') put: true
              ]
            ]
          ]
        ]
      ]
    ].

    "3) Admins always authorized. Recognized via actorCtx isAdmin flag."
    (actorCtx notNil and: [actorCtx isAdmin]) ifFalse: [
      (authoritySet includesKey: actorStr) ifFalse: [
        ^self errorResponse: 403 message: 'actor not authorized to cancel this workflow (D6.15)'
      ]
    ].

    "Delegate to WorkflowEngine which handles recursive child cancellation"
    dispatcher isNil ifTrue: [
      ^self errorResponse: 500 message: 'No dispatcher configured'
    ].
    cancelledCount := dispatcher workflowEngine
      cancelWorkflow: wfId scope: scope reason: reason actor: actorStr.

    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: 'workflow_id' put: wfId.
    d at: 'tasks_cancelled' put: cancelledCount.
    d at: 'reason' put: reason.
    d at: 'cancelled_by' put: actorStr.
    ^self okResponse: d
  ]

  "--- Workflow Watch / Unwatch (F8.2) ---"

  method: handleWorkflowWatch: req actor: actorCtx [
    "POST /api/workflow/watch — subscribe the calling user to a workflow's
     lifecycle events. Body: {workflow_id}. Tuple is affine with an
     hours-long TTL so crashed clients do not leak subscriptions.
     Repeat calls with the same (user, workflow_id) refresh the TTL and
     remain idempotent."
    | body wfId user payload identity d ttl |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].
    wfId := body at: 'workflow_id' ifAbsent: [nil].
    (wfId isNil or: [wfId isEmpty]) ifTrue: [
      ^self errorResponse: 400 message: 'workflow_id required'
    ].
    user := self actorOf: actorCtx.
    (user isNil or: [user isEmpty]) ifTrue: [
      ^self errorResponse: 401 message: 'authenticated actor required'
    ].

    identity := user, ':', wfId.
    "Idempotent: outAffine: overwrites any existing subscription for this
     (user, wfId) pair with a fresh TTL."

    payload := Dictionary new.
    payload at: 'user' put: user.
    payload at: 'workflow_id' put: wfId.
    payload at: 'created_at' put: DateTime now epochSeconds.

    ttl := 21600. "6 hours — hours-long so crashed clients do not leak"
    bbs outAffine: 'watch' scope: '/' identity: identity payload: payload ttl: ttl actor: user.

    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: 'workflow_id' put: wfId.
    d at: 'user' put: user.
    ^self okResponse: d
  ]

  method: handleWorkflowUnwatch: req actor: actorCtx [
    "POST /api/workflow/unwatch — remove the caller's subscription to a
     workflow. Body: {workflow_id}. Deletes the tuple matching the
     (user, workflow_id) pair. Missing subscription is not an error."
    | body wfId user identity existing d |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].
    wfId := body at: 'workflow_id' ifAbsent: [nil].
    (wfId isNil or: [wfId isEmpty]) ifTrue: [
      ^self errorResponse: 400 message: 'workflow_id required'
    ].
    user := self actorOf: actorCtx.
    (user isNil or: [user isEmpty]) ifTrue: [
      ^self errorResponse: 401 message: 'authenticated actor required'
    ].

    identity := user, ':', wfId.
    existing := bbs inp: 'watch' scope: '/' identity: identity.

    d := Dictionary new.
    d at: 'status' put: 'ok'.
    d at: 'workflow_id' put: wfId.
    d at: 'user' put: user.
    d at: 'removed' put: (existing notNil).
    ^self okResponse: d
  ]


  "--- Task/Signal Endpoints (inlined into registerRoutes) ---"

  "--- Work Items ---"

  method: handleWorkitemCreate: req actor: actorCtx [
    "POST /api/workitem/create — create a work item (epic or story).
     Validates type, status, and template against allowed enums / registry."
    | body scope identity payload id pinned type status template err |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].

    scope := body at: 'scope' ifAbsent: ['default'].
    identity := body at: 'identity' ifAbsent: [nil].
    identity isNil ifTrue: [^self errorResponse: 400 message: 'identity required'].
    payload := body at: 'payload' ifAbsent: [Dictionary new].
    pinned := body at: 'pinned' ifAbsent: [true].

    "Validate payload fields (type, status, template) if present."
    err := self validateWorkitemPayload: payload scope: scope.
    err notNil ifTrue: [^self errorResponse: 400 message: err].

    "Use upsertPinned to avoid duplicates if called twice with same identity"
    id := bbs upsertPinned: 'workitem' scope: scope identity: identity payload: payload actor: (self actorOf: actorCtx).

    ^self okResponse: (self okWithId: id)
  ]

  method: validateWorkitemPayload: payload scope: scope [
    "Validate the type, status, and template fields of a work item payload.
     Returns an error message string on failure, or nil if valid.
     - type (if present) must be one of WorkItemFields validTypes
     - status (if present) must be one of WorkItemFields validStatuses
     - template (if present) must exist in the template registry
       (category 'template', scope 'system' or the work item's scope)
     Also strips a legacy 'children' key from the payload if present — the
     single source of truth is the child's parent field, and no inbound
     caller is permitted to plant a denormalised children[] array."
    | type status template tmpl estimate |
    (payload includesKey: 'children') ifTrue: [
      payload removeKey: 'children' ifAbsent: [nil]
    ].
    (payload includesKey: 'type') ifTrue: [
      type := payload at: 'type'.
      (WorkItemFields isValidType: type) ifFalse: [
        ^'Invalid type: ', type printString, ' (must be one of: ', WorkItemFields validTypesDisplay, ')'
      ]
    ].
    (payload includesKey: 'status') ifTrue: [
      status := payload at: 'status'.
      (WorkItemFields isValidStatus: status) ifFalse: [
        ^'Invalid status: ', status printString, ' (must be one of: ', WorkItemFields validStatusesDisplay, ')'
      ]
    ].
    (payload includesKey: 'estimate') ifTrue: [
      estimate := payload at: 'estimate'.
      (estimate notNil and: [estimate isEmpty not]) ifTrue: [
        (WorkItemFields isValidEstimate: estimate) ifFalse: [
          ^'Invalid estimate: ', estimate printString, ' (must be one of: ', WorkItemFields validEstimatesDisplay, ')'
        ]
      ]
    ].
    (payload includesKey: 'template') ifTrue: [
      template := payload at: 'template'.
      (template notNil and: [template isEmpty not]) ifTrue: [
        tmpl := bbs rdp: 'template' scope: 'system' identity: template.
        tmpl isNil ifTrue: [
          tmpl := bbs rdp: 'template' scope: scope identity: template
        ].
        tmpl isNil ifTrue: [
          ^'Invalid template: ', template printString, ' (not found in template registry)'
        ]
      ]
    ].
    ^nil
  ]

  method: handleWorkitemUpdate: req actor: actorCtx [
    "POST /api/workitem/update — update fields on a work item.
     Body: {identity, scope, fields: {status, title, ...}, cascade?}"
    | body scope identity fields cascade item newPayload actor |
    actor := self actorOf: actorCtx.
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].

    identity := body at: 'identity' ifAbsent: [nil].
    identity isNil ifTrue: [^self errorResponse: 400 message: 'identity required'].
    scope := body at: 'scope' ifAbsent: ['default'].
    fields := body at: 'fields' ifAbsent: [Dictionary new].
    cascade := body at: 'cascade' ifAbsent: [false].

    "Read existing item"
    item := bbs findInIndex: 'workitem' scope: scope identity: identity.
    item isNil ifTrue: [^self errorResponse: 404 message: 'work item not found'].

    "Guard: 'children' and 'parent' are not mutable via /api/workitem/update.
     'children' is fully derived from child.parent and must never be written.
     'parent' is immutable here — re-parenting would require a dedicated
     endpoint that does not exist yet. Silently drop both keys from the
     incoming fields dict so legacy clients degrade gracefully."
    (fields includesKey: 'children') ifTrue: [
      bbs logEngine: 'warn' component: 'workitem-update' scope: scope
          message: ('dropped ''children'' from update fields for ', identity, ' — children are derived from child.parent').
      fields removeKey: 'children' ifAbsent: [nil]
    ].
    (fields includesKey: 'parent') ifTrue: [
      bbs logEngine: 'warn' component: 'workitem-update' scope: scope
          message: ('dropped ''parent'' from update fields for ', identity, ' — re-parenting via update is not supported').
      fields removeKey: 'parent' ifAbsent: [nil]
    ].

    "Merge fields into existing payload. Also strip any legacy 'children'
     field from the stored payload itself so rewrites of older tuples
     eliminate stale data opportunistically."
    newPayload := nil.
    bbs updatePinned: 'workitem' scope: scope identity: identity actor: actor do: [:p |
      fields keysAndValuesDo: [:k :v | p at: k put: v].
      (p includesKey: 'children') ifTrue: [p removeKey: 'children' ifAbsent: [nil]].
      newPayload := p
    ].

    "Cascade status to children if requested. Children are derived from
     payload.parent — scan workitems in scope rather than trusting a
     denormalised children[] field."
    (cascade and: [fields includesKey: 'status']) ifTrue: [
      | children childId |
      children := bbs scanChildrenOf: identity scope: scope.
      children do: [:childItem |
        childId := childItem at: 'identity'.
        bbs updatePinned: 'workitem' scope: scope identity: childId actor: actor do: [:p |
          p at: 'status' put: (fields at: 'status').
          p at: 'updated_at' put: DateTime now epochSeconds
        ]
      ]
    ].

    "Auto-promote parent epic when this item moves to done and all siblings are done."
    ((fields includesKey: 'status') and: [(fields at: 'status') = 'done']) ifTrue: [
      self maybePromoteParentOf: newPayload scope: scope
    ].

    ^self okResponse: (self okWithIdentity: identity)
  ]

  method: maybePromoteParentOf: payload scope: aScope [
    "If `payload` has a parent, and all of that parent's children are now 'done',
     auto-promote the parent to 'done' and recurse upward. No-op if parent is
     missing, has no children, or is already done."
    | parentId parentItem parentPayload children allDone newParentPayload |
    parentId := payload at: 'parent' ifAbsent: [nil].
    parentId isNil ifTrue: [^self].
    (parentId isString and: [parentId isEmpty]) ifTrue: [^self].
    parentItem := bbs findInIndex: 'workitem' scope: aScope identity: parentId.
    parentItem isNil ifTrue: [^self].
    parentPayload := parentItem at: 'payload'.
    (parentPayload at: 'status' ifAbsent: ['']) = 'done' ifTrue: [^self].
    "Derive children by scanning workitems in scope — child.parent is the source of truth."
    children := bbs scanChildrenOf: parentId scope: aScope.
    children isEmpty ifTrue: [^self].
    allDone := true.
    children do: [:child |
      | cStatus |
      cStatus := (child at: 'payload') at: 'status' ifAbsent: [''].
      cStatus = 'done' ifFalse: [allDone := false]
    ].
    allDone ifFalse: [^self].
    newParentPayload := Dictionary new.
    parentPayload keysAndValuesDo: [:k :v | newParentPayload at: k put: v].
    newParentPayload at: 'status' put: 'done'.
    newParentPayload at: 'updated_at' put: DateTime now epochSeconds.
    bbs upsertPinned: 'workitem' scope: aScope identity: parentId payload: newParentPayload.
    "Recurse upward in case this completes a grandparent."
    self maybePromoteParentOf: newParentPayload scope: aScope
  ]

  method: handleWorkitemComment: req actor: actorCtx [
    "POST /api/workitem/comment — add a comment to a work item."
    | body scope identity author text item comments comment |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].

    identity := body at: 'identity' ifAbsent: [nil].
    identity isNil ifTrue: [^self errorResponse: 400 message: 'identity required'].
    scope := body at: 'scope' ifAbsent: ['default'].
    author := body at: 'author' ifAbsent: ['unknown'].
    text := body at: 'text' ifAbsent: [''].

    item := bbs findInIndex: 'workitem' scope: scope identity: identity.
    item isNil ifTrue: [^self errorResponse: 404 message: 'work item not found'].

    comments := (item at: 'payload') at: 'comments' ifAbsent: [#()].

    comment := Dictionary new.
    comment at: 'author' put: author.
    comment at: 'text' put: text.
    comment at: 'timestamp' put: DateTime now epochSeconds.
    comments := comments copyWith: comment.

    bbs updatePinned: 'workitem' scope: scope identity: identity actor: (self actorOf: actorCtx) do: [:p |
      p at: 'comments' put: comments.
      p at: 'updated_at' put: DateTime now epochSeconds
    ].

    ^self okResponse: (self okWithCount: 'comments' count: comments size)
  ]

  method: handleWorkitemRun: req actor: actorCtx [
    "POST /api/workitem/run — execute a work item via workflow.
     For stories: starts a story/story-lite workflow.
     For epics: starts an execute-epic workflow (dispatch-waves on children)."
    | body scope identity item payload type template wfParams instanceId |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].

    identity := body at: 'identity' ifAbsent: [nil].
    identity isNil ifTrue: [^self errorResponse: 400 message: 'identity required'].
    scope := body at: 'scope' ifAbsent: ['default'].

    item := bbs findInIndex: 'workitem' scope: scope identity: identity.
    item isNil ifTrue: [^self errorResponse: 404 message: 'work item not found'].

    payload := item at: 'payload'.
    type := payload at: 'type' ifAbsent: ['story'].

    dispatcher isNil ifTrue: [
      ^self errorResponse: 500 message: 'No dispatcher configured'
    ].

    "D6.11 / §4.10: reject with 429 if pending-task queue is saturated."
    (self queueBackpressureResponse) notNil ifTrue: [
      ^self queueBackpressureResponse
    ].

    "Update status to in-progress"
    self updateWorkitemStatus: identity scope: scope status: 'in-progress'.

    wfParams := Dictionary new.
    wfParams at: 'workitem' put: identity.
    wfParams at: 'description' put: (payload at: 'description' ifAbsent: [payload at: 'title' ifAbsent: [identity]]).
    (payload at: 'repo' ifAbsent: [nil]) notNil ifTrue: [
      wfParams at: 'repo' put: (payload at: 'repo')
    ].

    "Determine template — honor work item's template field, with type-based default
     (full-pipeline for epics, story for individual stories)."
    template := payload at: 'template' ifAbsent: [
      type = 'epic' ifTrue: ['full-pipeline'] ifFalse: ['story']
    ].
    [
      instanceId := dispatcher instantiateWorkflow: template scope: scope params: wfParams launchedBy: (self actorOf: actorCtx) overrideAffinity: nil.
      ^self okResponse: (self okWithWorkflow: instanceId type: type)
    ] on: Exception do: [:e |
      ^self errorResponse: 400 message: e messageText
    ]
  ]

  method: updateWorkitemStatus: identity scope: scope status: newStatus [
    "Helper: update a work item's status."
    bbs updatePinned: 'workitem' scope: scope identity: identity do: [:p |
      p at: 'status' put: newStatus.
      p at: 'updated_at' put: DateTime now epochSeconds
    ]
  ]

  "--- History ---"

  method: handleHistory: req [
    | filters since limit op category scope identity results d |
    filters := Dictionary new.
    since := req queryParam: 'since'.
    (since notNil and: [since isEmpty not]) ifTrue: [filters at: 'since' put: since asInteger].
    limit := req queryParam: 'limit'.
    (limit notNil and: [limit isEmpty not]) ifTrue: [filters at: 'limit' put: limit asInteger].
    op := req queryParam: 'op'.
    (op notNil and: [op isEmpty not]) ifTrue: [filters at: 'op' put: op].
    category := req queryParam: 'category'.
    (category notNil and: [category isEmpty not]) ifTrue: [filters at: 'category' put: category].
    scope := req queryParam: 'scope'.
    (scope notNil and: [scope isEmpty not]) ifTrue: [filters at: 'scope' put: scope].
    identity := req queryParam: 'identity'.
    (identity notNil and: [identity isEmpty not]) ifTrue: [filters at: 'identity' put: identity].
    results := bbs history: filters.
    d := Dictionary new.
    d at: 'entries' put: results.
    d at: 'count' put: results size.
    ^self okResponse: d
  ]

  "--- Dashboard ---"

  method: handleDashboard: req [
    "GET /api/dashboard — return workflows, tasks, tokens, recent notifications, and health.
     D6.11 / §4.10: also surface pending_tasks and the summed worker slot
     capacity so the dashboard can render a red-threshold depth indicator
     without re-scanning tuples client-side."
    | workflows tasks tokens notifications recent d health
      pending workers slotSum |
    workflows := bbs scanAll: 'workflow'.
    tasks := bbs scanAll: 'task'.
    tokens := bbs scanAll: 'token'.
    notifications := bbs scanAll: 'notification'.
    recent := notifications size > 20
      ifTrue: [notifications copyFrom: (notifications size - 20)]
      ifFalse: [notifications].

    pending := 0.
    tasks do: [:t |
      | p |
      p := t at: 'payload'.
      (p at: 'status' ifAbsent: ['']) = 'pending' ifTrue: [pending := pending + 1]
    ].

    slotSum := 0.
    workers := bbs scanAll: 'worker'.
    workers do: [:w |
      | wp s |
      wp := w at: 'payload'.
      s := wp at: 'slots' ifAbsent: [0].
      (s isKindOf: Number) ifTrue: [slotSum := slotSum + s]
    ].

    health := Dictionary new.
    health at: 'tuples' put: bbs size.
    health at: 'uptime' put: bbs uptime.
    d := Dictionary new.
    d at: 'workflows' put: workflows.
    d at: 'tasks' put: tasks.
    d at: 'tokens' put: tokens.
    d at: 'notifications' put: recent.
    d at: 'health' put: health.
    d at: 'pending_tasks' put: pending.
    d at: 'worker_slots' put: slotSum.
    queueMaxPending notNil ifTrue: [
      d at: 'queue_max_pending' put: queueMaxPending
    ].
    ^self okResponse: d
  ]

  "--- SSE Dashboard Stream ---"

  method: handleSSEDashboard: conn request: req [
    "Accept SSE dashboard subscribers. The dashboard is a read-only
     surface; we do not gate it on signatures. If a signed upgrade
     succeeds we record the actor for audit, otherwise the subscription
     is anonymous. Mutating endpoints remain signature-gated.

     When auth-gated dashboards are needed (multi-user, per-viewer
     filtering), revisit this: plan is a session-cookie path via
     /api/auth/login + /auth/exchange (see chat thread 2026-04-19)."
    | actorCtx identity |
    actorCtx := signatureVerifier verify: req adminList: adminList skewSeconds: skewSeconds.
    actorCtx isNil ifTrue: [
      actorCtx := signatureVerifier verifySSE: req adminList: adminList skewSeconds: skewSeconds
    ].
    actorCtx isNil ifTrue: [actorCtx := ActorContext anonymous].
    identity := actorCtx actor.
    dashboardSSE onConnect: conn identity: identity
  ]

  method: startSSETick [
    [[true] whileTrue: [
      Process sleep: 5000.
      dashboardSSE tick
    ]] fork
  ]

  "--- User Management ---"

  method: handleUserAdd: body actor: actorCtx [
    "POST /api/user/add — admin-gated. Body: {name, pubkey, replace?}.
     Writes pinned tuple category=identity scope='/' identity='user:<name>'
     with payload {pubkey, created_at, status:'active'}. Rejects duplicates
     unless replace=true."
    | name pubkey replace existing payload now actor |
    actorCtx isAdmin ifFalse: [
      ^self errorResponse: 401 message: 'admin signature required'
    ].
    name := body at: 'name'.
    pubkey := body at: 'pubkey'.
    replace := body at: 'replace' ifAbsent: [false].
    existing := bbs rdp: 'identity' scope: '/' identity: 'user:', name.
    (existing notNil and: [replace not]) ifTrue: [
      ^self errorResponse: 409 message: 'identity already registered for ', name
    ].
    now := DateTime now epochSeconds.
    payload := Dictionary new.
    payload at: 'pubkey' put: pubkey.
    payload at: 'created_at' put: now.
    payload at: 'status' put: 'active'.
    actor := self actorOf: actorCtx.
    bbs upsertPinned: 'identity' scope: '/' identity: 'user:', name payload: payload actor: actor.
    ^self okResponse: (self okWithIdentity: 'user:', name)
  ]

  method: handleUserRevoke: body actor: actorCtx [
    "POST /api/user/revoke — admin-gated. Body: {name}.
     Flips the identity payload's status to 'revoked'. Prior history is
     retained by BBS history log for audit."
    | name existing |
    actorCtx isAdmin ifFalse: [
      ^self errorResponse: 401 message: 'admin signature required'
    ].
    name := body at: 'name'.
    existing := bbs rdp: 'identity' scope: '/' identity: 'user:', name.
    existing isNil ifTrue: [
      ^self errorResponse: 404 message: 'identity not found for ', name
    ].
    bbs updatePinned: 'identity' scope: '/' identity: 'user:', name actor: (self actorOf: actorCtx) do: [:p |
      p at: 'status' put: 'revoked'.
      p at: 'revoked_at' put: DateTime now epochSeconds
    ].
    ^self okResponse: (self okWithIdentity: 'user:', name)
  ]

  method: handleUserRotate: req [
    "POST /api/user/rotate — self-serve key rotation. Body: {old_pub, new_pub}.
     Verifier must confirm the signature was produced with old_pub AND that
     old_pub is the currently-registered key for the actor. On success,
     overwrites payload.pubkey and emits an event tuple key-rotated:<actor>."
    | body err oldPub newPub actorHeader actorCtx existing payload actorName actor |
    body := self parseBody: req.
    body isNil ifTrue: [^self errorResponse: 400 message: 'Invalid JSON'].
    err := self requireFields: #('old_pub' 'new_pub') in: body.
    err notNil ifTrue: [^self errorResponse: 400 message: err].
    oldPub := body at: 'old_pub'.
    newPub := body at: 'new_pub'.
    actorHeader := req header: 'X-PP-Actor'.
    (actorHeader isNil or: [actorHeader isEmpty]) ifTrue: [
      ^self errorResponse: 401 message: 'X-PP-Actor header required'
    ].

    "Require signature by old_pub and match against registered key."
    actorCtx := signatureVerifier verify: req adminList: adminList
                                  skewSeconds: skewSeconds
                                  requireOldPub: oldPub.
    (enforceSignatures and: [actorCtx isNil]) ifTrue: [
      ^self errorResponse: 401 message: 'rotation signature verification failed'
    ].
    actorCtx isNil ifTrue: [actorCtx := ActorContext anonymous].

    existing := bbs rdp: 'identity' scope: '/' identity: 'user:', actorHeader.
    existing isNil ifTrue: [
      ^self errorResponse: 404 message: 'identity not found for ', actorHeader
    ].
    payload := existing at: 'payload' ifAbsent: [Dictionary new].
    (payload at: 'status' ifAbsent: ['active']) = 'active' ifFalse: [
      ^self errorResponse: 401 message: 'identity is not active'
    ].
    "Sanity: old_pub must match stored pubkey (verifier already checked when
     enforcement is on; re-check here so behavior is correct even when
     enforcement is off)."
    (payload at: 'pubkey' ifAbsent: [nil]) = oldPub ifFalse: [
      ^self errorResponse: 401 message: 'old_pub does not match registered key'
    ].
    actorName := 'user:', actorHeader.
    actor := self actorOf: actorCtx.
    actor isNil ifTrue: [actor := actorName].
    bbs updatePinned: 'identity' scope: '/' identity: actorName actor: actor do: [:p |
      p at: 'pubkey' put: newPub.
      p at: 'rotated_at' put: DateTime now epochSeconds
    ].
    bbs emitEvent: '/' identity: 'key-rotated:', actorName type: 'key-rotated' summary: 'Key rotated' actor: actor.
    ^self okResponse: (self okWithIdentity: actorName)
  ]

