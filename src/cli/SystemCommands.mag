"SystemCommands — system-level CLI commands extracted from PP.
 Handles status, prime, task, log, history, dashboard, and gc."

SystemCommands subclass: CLIBase

  classMethod: new [
    ^super new initialize
  ]

  method: runCommand: cmd args: args [
    "Dispatch a system command by name."
    cmd = 'status'    ifTrue: [^self cmdStatus: args].
    cmd = 'prime'     ifTrue: [^self cmdPrime: args].
    cmd = 'task'      ifTrue: [^self cmdTask: args].
    cmd = 'log'       ifTrue: [^self cmdLog: args].
    cmd = 'history'   ifTrue: [^self cmdHistory: args].
    cmd = 'dashboard' ifTrue: [^self cmdDashboard: args].
    cmd = 'gc'        ifTrue: [^self cmdGc: args].
    cmd = 'session'   ifTrue: [^self cmdSession: args].
    cmd = 'usage'     ifTrue: [^self cmdUsage: args].
    ('SystemCommands: unknown command: ', cmd) println
  ]

  "--- Status & Context ---"

  method: cmdStatus: args [
    "pp status — show health + current task context"
    | response health |
    [
      response := client get: baseUrl, '/api/health'.
      response isNil ifTrue: [
        ('Error: no response from server at ', baseUrl) println.
        ^self
      ].
      (response isKindOf: String) ifFalse: [
        ('Error: server returned non-String response') println.
        ^self
      ].
      response isEmpty ifTrue: [
        ('Error: empty response from server') println.
        ^self
      ].
      health := Json decode: response.
      'Procyon Park Status:' println.
      ('  Tuples:           ', (health at: 'tuples' ifAbsent: ['?']) printString) println.
      ('  Uptime:           ', (health at: 'uptime' ifAbsent: ['?']) printString, 's') println.
      ('  Slots:            ',
        (health at: 'active_slots' ifAbsent: ['?']) printString, ' / ',
        (health at: 'max_slots' ifAbsent: ['?']) printString) println.
      ('  Active tasks:     ', (health at: 'active_tasks' ifAbsent: ['?']) printString) println.
      ('  Pending tasks:    ', (health at: 'pending_tasks' ifAbsent: ['?']) printString) println.
      ('  Avg duration (s): ', (health at: 'avg_task_duration_s' ifAbsent: ['?']) printString) println.
      ('  Errors (1h):      ', (health at: 'error_count_last_hour' ifAbsent: ['?']) printString) println.

      taskId isEmpty ifFalse: [
        ('  Task:    ', taskId) println.
        ('  Scope:   ', scope) println
      ]
    ] on: Exception do: [:e |
      ('Error connecting to Procyon Park at ', baseUrl, ': ', e messageText) println
    ]
  ]

  method: cmdPrime: args [
    "pp prime [--role <role>] — output priming context for an agent."
    | roleName conventions facts signals notifications out |

    roleName := self flagValue: '--role' in: args.
    roleName isNil ifTrue: [roleName := 'agent'].

    out := '# Procyon Park Agent Context

You are connected to the Procyon Park orchestration system.
Communicate with it using the `pp` command-line tool.

## Available Commands

  pp observe <identity> <detail> [--tags t1,t2]     Report an observation
  pp decide <identity> <detail> [--rationale ..]     Record a decision
  pp event <identity> [--type T] [--summary S]       Emit an event
  pp plan <file.json>                                Submit a structured plan
  pp read <category> [scope] [identity]              Read tuples
  pp notify <message> [--severity info|warn|urgent]  Notify the user
  pp dismiss                                         Signal task completion
  pp status                                          Show system status
  pp task <id> --role <r> --description <d> [--workdir <p>]  Create a task
  pp workflow <template> [--param key=val ...]        Start a workflow
  pp signal <id> <key> <value>                       Upsert a signal
  pp log [--follow] [--no-follow] [--since <secs>]   Tail notification stream
  pp usage [--json]                                  Report your session token consumption (self-regulate)

Worktree base: ~/.pp/worktrees/
Dashboard:     ', baseUrl, '/dashboard/

## Rules

- All coordination flows through `pp`. Do not coordinate with other agents directly.
- Report anything unexpected with `pp observe`.
- When done, run `pp dismiss`.

## Environment

  PP_URL   = ', baseUrl, '
  PP_SCOPE = ', scope, '
'.

    taskId isEmpty ifFalse: [
      out := out, '  PP_TASK  = ', taskId, '
'
    ].

    "Conventions"
    conventions := self safeScan: 'convention' scope: nil.
    conventions isEmpty ifFalse: [
      out := out, '
## Conventions

'.
      conventions do: [:t |
        | payload |
        payload := t at: 'payload' ifAbsent: [Dictionary new].
        out := out, '- **', (t at: 'identity' ifAbsent: ['?']), '**: ', (payload at: 'detail' ifAbsent: ['']), '
'
      ]
    ].

    "Facts in scope"
    facts := self safeScan: 'fact' scope: scope.
    facts isEmpty ifFalse: [
      out := out, '
## Known Facts (scope: ', scope, ')

'.
      facts do: [:t |
        | payload |
        payload := t at: 'payload' ifAbsent: [Dictionary new].
        out := out, '- **', (t at: 'identity' ifAbsent: ['?']), '**: ', (payload at: 'detail' ifAbsent: ['']), '
'
      ]
    ].

    "Signals in scope"
    signals := self safeScan: 'signal' scope: scope.
    signals isEmpty ifFalse: [
      out := out, '
## Signals (scope: ', scope, ')

'.
      signals do: [:t |
        | payload |
        payload := t at: 'payload' ifAbsent: [Dictionary new].
        out := out, '- **', (t at: 'identity' ifAbsent: ['?']), '**: ', (Json encode: payload), '
'
      ]
    ].

    "Pending notifications"
    notifications := self safeGetNotifications.
    notifications isEmpty ifFalse: [
      out := out, '
## Pending Notifications

'.
      notifications do: [:t |
        | payload |
        payload := t at: 'payload' ifAbsent: [Dictionary new].
        out := out, '- [', (payload at: 'severity' ifAbsent: ['info']), '] ', (payload at: 'message' ifAbsent: ['']), '
'
      ]
    ].

    out println
  ]

  "--- Task ---"

  method: cmdTask: args [
    "pp task <identity> --role <role> --description <desc> [--workdir <path>] [--repo <name>]"
    | body identity role desc workdir repo |
    args size < 2 ifTrue: [
      'Usage: pp task <identity> --role <role> --description <desc> [--workdir <path>] [--repo <name>]' println.
      ^self
    ].

    identity := args at: 1.
    role := self flagValue: '--role' in: args.
    desc := self flagValue: '--description' in: args.

    role isNil ifTrue: [
      'Error: --role is required' println.
      ^self
    ].

    desc isNil ifTrue: [desc := ''].

    body := Dictionary new.
    body at: 'scope' put: scope.
    body at: 'identity' put: identity.
    body at: 'role' put: role.
    body at: 'description' put: desc.

    workdir := self flagValue: '--workdir' in: args.
    workdir notNil ifTrue: [body at: 'workdir' put: workdir].

    "Repo: from --repo flag, PP_REPO env, or omit"
    repo := self flagValue: '--repo' in: args.
    repo isNil ifTrue: [
      repo := System env: 'PP_REPO'.
      (repo isNil or: [repo isEmpty]) ifTrue: [repo := nil]
    ].
    repo notNil ifTrue: [body at: 'repo' put: repo].

    taskId isEmpty ifFalse: [
      body at: 'workflow_instance' put: taskId
    ].

    self post: '/api/task/create' body: body
  ]

  "--- Log & History ---"

  method: cmdLog: args [
    "pp log [--follow] [--no-follow] [--since <seconds>] — poll notifications stream"
    | follow sinceOffset since sinceStr url response result notifications payload createdAt severity message ts maxCreatedAt dt waitParam |
    follow := true.
    sinceOffset := 0.

    "Parse flags — follow is default; --no-follow disables, --follow is explicit"
    (args indexOf: '--no-follow') >= 0 ifTrue: [follow := false].
    (args indexOf: '--follow') >= 0 ifTrue: [follow := true].
    sinceStr := self flagValue: '--since' in: args.
    sinceStr notNil ifTrue: [sinceOffset := sinceStr asInteger].

    "Compute initial since epoch"
    since := DateTime now epochSeconds - sinceOffset.

    "Non-following mode: single fetch via curl (avoids HttpClient blocking bug)"
    follow ifFalse: [
      sinceStr := since printString.
      url := baseUrl, '/api/notifications/stream?since=', sinceStr, '&wait=0'.
      response := Shell capture: 'curl -s "', url, '"'.
      (response notNil and: [response isEmpty not]) ifTrue: [
        [
          result := Json decode: response.
          notifications := result at: 'notifications' ifAbsent: [#()].
          notifications do: [:notif |
            payload := notif.
            createdAt := payload at: 'created_at' ifAbsent: [0].
            severity := payload at: 'severity' ifAbsent: ['info'].
            message := payload at: 'message' ifAbsent: [''].
            dt := DateTime fromEpoch: createdAt.
            ts := dt printString.
            (ts, ' [', severity, '] ', message) println
          ]
        ] on: Exception do: [:e |
          ('Error: ', e messageText) println
        ]
      ].
      ^self
    ].

    "Following mode: long-poll loop via HttpClient"
    [true] whileTrue: [
      sinceStr := since printString.
      url := baseUrl, '/api/notifications/stream?since=', sinceStr, '&wait=1'.
      [
        response := client get: url.
        (response notNil and: [(response isKindOf: String) and: [response isEmpty not]]) ifTrue: [
          result := Json decode: response.
          notifications := result at: 'notifications' ifAbsent: [#()].
          maxCreatedAt := since.
          notifications do: [:notif |
            payload := notif.
            createdAt := payload at: 'created_at' ifAbsent: [0].
            severity := payload at: 'severity' ifAbsent: ['info'].
            message := payload at: 'message' ifAbsent: [''].
            dt := DateTime fromEpoch: createdAt.
            ts := dt printString.
            (ts, ' [', severity, '] ', message) println.
            createdAt > maxCreatedAt ifTrue: [maxCreatedAt := createdAt]
          ].
          notifications size > 0 ifTrue: [since := maxCreatedAt + 1]
        ]
      ] on: Exception do: [:e |
        ('Error polling notifications: ', e messageText) println
      ].
      Process sleep: 2000
    ]
  ]

  method: cmdHistory: args [
    "pp history [--since S] [--limit N] [--op O] [--category C] [--scope S] [--identity I]"
    | sinceStr limitStr op category histScope identity url sep response result entries entry ts entryOp entryCat entryScope entryIdentity |
    sinceStr := self flagValue: '--since' in: args.
    limitStr := self flagValue: '--limit' in: args.
    op := self flagValue: '--op' in: args.
    category := self flagValue: '--category' in: args.
    histScope := self flagValue: '--scope' in: args.
    identity := self flagValue: '--identity' in: args.

    url := '/api/history?limit='.
    limitStr notNil
      ifTrue: [url := url, limitStr]
      ifFalse: [url := url, '50'].
    sinceStr notNil ifTrue: [url := url, '&since=', sinceStr].
    op notNil ifTrue: [url := url, '&op=', op].
    category notNil ifTrue: [url := url, '&category=', category].
    histScope notNil ifTrue: [url := url, '&scope=', histScope].
    identity notNil ifTrue: [url := url, '&identity=', identity].

    [
      response := client get: baseUrl, url.
      response isNil ifTrue: [
        'Error: no response from server' println.
        ^self
      ].
      (response isKindOf: String) ifFalse: [
        'Error: server returned non-String response' println.
        ^self
      ].
      response isEmpty ifTrue: [
        'Error: empty response from server' println.
        ^self
      ].
      result := Json decode: response.
      entries := result at: 'entries' ifAbsent: [#()].
      entries size = 0 ifTrue: [
        'No history entries.' println.
        ^self
      ].
      entries do: [:e |
        ts := e at: 'ts' ifAbsent: ['?'].
        entryOp := e at: 'op' ifAbsent: ['?'].
        entryCat := e at: 'category' ifAbsent: [''].
        entryScope := e at: 'scope' ifAbsent: [''].
        entryIdentity := e at: 'identity' ifAbsent: [''].
        (ts printString, ' ', entryOp, ' ', entryCat, '/', entryScope, '/', entryIdentity) println
      ]
    ] on: Exception do: [:e |
      ('Error: ', e messageText) println
    ]
  ]

  "--- Dashboard ---"

  method: cmdDashboard: args [
    "Open the web dashboard in the default browser."
    | url |
    url := baseUrl, '/dashboard/'.
    ('Opening dashboard: ', url) println.
    Shell run: 'open ', url
  ]

  "--- Garbage Collection ---"

  method: cmdGc: args [
    "pp gc — clean up finished workflows and merged branches.
     Flags:
       --dry-run                 show what would be removed, do not modify state
       --sessions                also clean orphaned session JSONL files
       --older-than <hours>      (with --sessions) only remove session files whose
                                 mtime is older than N hours (default: 24)"
    | dryRun count sessionsFlag olderThanStr olderThanHours sessionCount |
    dryRun := (args indexOf: '--dry-run') >= 0.
    sessionsFlag := (args indexOf: '--sessions') >= 0.
    olderThanStr := self flagValue: '--older-than' in: args.
    olderThanHours := olderThanStr notNil
      ifTrue: [olderThanStr asInteger]
      ifFalse: [24].
    'Procyon Park GC' println.
    dryRun ifTrue: ['(dry-run)' println].
    count := self gcWorkflows: dryRun.
    self gcBranches: dryRun.
    sessionCount := 0.
    sessionsFlag ifTrue: [
      sessionCount := self gcSessionsOlderThanHours: olderThanHours dryRun: dryRun
    ].
    ('Done. Removed ', count printString, ' workflows.') println.
    sessionsFlag ifTrue: [
      ('       Removed ', sessionCount printString, ' session file(s).') println
    ]
  ]

  method: gcWorkflows: dryRun [
    | body response result workflows count |
    body := Dictionary new.
    body at: 'category' put: 'workflow'.
    count := 0.
    [
      response := client post: baseUrl, '/api/scan' body: (Json encode: body) contentType: 'application/json'.
      result := Json decode: response.
      workflows := result at: 'tuples' ifAbsent: [#()].
      workflows do: [:wf |
        | p status wfId wfScope |
        p := wf at: 'payload' ifAbsent: [Dictionary new].
        status := p at: 'status' ifAbsent: [''].
        wfId := wf at: 'identity' ifAbsent: [''].
        wfScope := wf at: 'scope' ifAbsent: ['default'].
        (status = 'completed' or: [status = 'cancelled' or: [status = 'failed']]) ifTrue: [
          ('  ', wfId, ' [', status, ']') println.
          "Remove all tokens/tasks/events/signals associated with this workflow
           before removing the workflow tuple itself."
          self gcWorkflowTuples: wfId dryRun: dryRun.
          dryRun ifFalse: [
            self silentInp: 'workflow' scope: wfScope identity: wfId
          ].
          count := count + 1
        ]
      ]
    ] on: Exception do: [:e |
      ('Error: ', e messageText) println
    ].
    ^count
  ]

  method: gcWorkflowTuples: wfId dryRun: dryRun [
    "Remove all token/task/event/signal tuples associated with workflow wfId.
     A tuple is considered associated if any of the following hold:
       - payload.workflow_instance equals wfId
       - scope equals wfId (many workflow signals are scoped to the instance id)
       - identity equals wfId
       - identity has wfId as a prefix followed by ':' (e.g., <wfId>:token:<place>)
     Returns the number of tuples removed (or that would be removed in dry-run)."
    | categories removedCount |
    categories := #('token' 'task' 'event' 'signal').
    removedCount := 0.
    categories do: [:cat |
      | tuples |
      tuples := self safeScan: cat scope: nil.
      tuples do: [:t |
        (self tuple: t matchesWorkflow: wfId) ifTrue: [
          | tScope tIdentity |
          tScope := t at: 'scope' ifAbsent: ['default'].
          tIdentity := t at: 'identity' ifAbsent: [''].
          ('    [', cat, '] ', tScope, '/', tIdentity) println.
          dryRun ifFalse: [
            self silentInp: cat scope: tScope identity: tIdentity
          ].
          removedCount := removedCount + 1
        ]
      ]
    ].
    removedCount > 0 ifTrue: [
      ('    -> ', removedCount printString, ' associated tuple(s) ',
        (dryRun ifTrue: ['would be removed'] ifFalse: ['removed'])) println
    ].
    ^removedCount
  ]

  method: tuple: t matchesWorkflow: wfId [
    "Return true if tuple t is associated with workflow wfId."
    | payload identity tScope wfInst |
    wfId isEmpty ifTrue: [^false].
    payload := t at: 'payload' ifAbsent: [Dictionary new].
    identity := t at: 'identity' ifAbsent: [''].
    tScope := t at: 'scope' ifAbsent: [''].
    "Payload workflow_instance match"
    wfInst := payload at: 'workflow_instance' ifAbsent: [''].
    wfInst = wfId ifTrue: [^true].
    "Scope equals workflow ID (common for instance-scoped signals)"
    tScope = wfId ifTrue: [^true].
    "Identity equals workflow ID"
    identity = wfId ifTrue: [^true].
    "Identity has wfId as a prefix followed by ':' (e.g., <wfId>:token:<place>)"
    (identity startsWith: (wfId, ':')) ifTrue: [^true].
    ^false
  ]

  method: gcBranches: dryRun [
    | output lines |
    [
      output := Shell capture: 'git branch --merged main 2>/dev/null | grep feature/ | sed "s/^[* ]*//"'.
      output isEmpty ifFalse: [
        lines := output split: (Character lf asString).
        lines do: [:line |
          line isEmpty ifFalse: [
            ('  branch: ', line) println.
            dryRun ifFalse: [
              Shell run: 'git branch -D ', line, ' 2>/dev/null'
            ]
          ]
        ]
      ]
    ] on: Exception do: [:e | ]
  ]

  method: gcSessionsOlderThanHours: olderThanHours dryRun: dryRun [
    "Clean up session JSONL files in ~/.pp/sessions/ whose mtime is older than
     olderThanHours AND whose workflow ID is no longer present as a workflow
     tuple (i.e. the workflow has completed and been GC'd, or never existed).
     Returns the number of files removed (or that would be removed in dry-run)."
    | homeDir sessionsDir minutes output lines body response result workflows
      existingIds removedCount lf marker |
    removedCount := 0.
    homeDir := System env: 'HOME'.
    (homeDir isNil or: [homeDir isEmpty]) ifTrue: [^0].
    sessionsDir := homeDir, '/.pp/sessions'.
    (File exists: sessionsDir) ifFalse: [^0].
    minutes := olderThanHours * 60.
    lf := Character lf asString.
    marker := ':task:'.

    "Collect workflow IDs still present in tuple space (these we keep)."
    existingIds := Array new: 0.
    [
      body := Dictionary new.
      body at: 'category' put: 'workflow'.
      response := client post: baseUrl, '/api/scan'
        body: (Json encode: body) contentType: 'application/json'.
      (response notNil and: [response isEmpty not]) ifTrue: [
        result := Json decode: response.
        workflows := result at: 'tuples' ifAbsent: [#()].
        workflows do: [:wf |
          | wfId |
          wfId := wf at: 'identity' ifAbsent: [''].
          wfId isEmpty ifFalse: [
            existingIds := existingIds copyWith: wfId
          ]
        ]
      ]
    ] on: Exception do: [:e |
      ('Warning: could not scan workflows: ', e messageText) println
    ].

    ('Cleaning orphaned session files older than ', olderThanHours printString, ' hour(s)...') println.
    [
      output := Shell capture: 'find "', sessionsDir, '" -maxdepth 1 -name "*.jsonl" -type f -mmin +', minutes printString, ' 2>/dev/null'.
      (output notNil and: [output isEmpty not]) ifTrue: [
        lines := output split: lf.
        lines do: [:path |
          path isEmpty ifFalse: [
            | fname wfId mIdx prefixLen |
            "Extract basename by stripping the known sessionsDir prefix + '/'"
            prefixLen := sessionsDir size + 1.
            fname := path size > prefixLen
              ifTrue: [path copyFrom: prefixLen to: path size]
              ifFalse: [path].
            "Extract workflow id: prefix before ':task:'"
            mIdx := fname indexOf: marker.
            wfId := mIdx >= 0
              ifTrue: [fname copyFrom: 0 to: mIdx]
              ifFalse: [''].
            (wfId isEmpty not and: [(existingIds includes: wfId) not]) ifTrue: [
              ('  session: ', fname) println.
              dryRun ifFalse: [
                Shell run: 'rm -f "', path, '"'
              ].
              removedCount := removedCount + 1
            ]
          ]
        ]
      ]
    ] on: Exception do: [:e |
      ('Error cleaning sessions: ', e messageText) println
    ].
    ^removedCount
  ]

  "--- Session Viewer ---"

  method: cmdSession: args [
    "pp session [<taskId>] [--full|--summary] — view Claude Code session logs.
       (no flag)  truncate long strings (default)
       --full     show full untruncated content
       --summary  show only tool_use names + assistant text blocks"
    | homeDir sessionsDir taskArg filePath contents lines lf mode i a |
    homeDir := System env: 'HOME'.
    sessionsDir := homeDir, '/.pp/sessions'.
    lf := Character lf asString.

    "Parse flags; first non-flag after 'session' becomes taskArg."
    mode := 'default'.
    taskArg := nil.
    i := 1.
    [i < args size] whileTrue: [
      a := args at: i.
      a = '--full' ifTrue: [mode := 'full']
        ifFalse: [a = '--summary' ifTrue: [mode := 'summary']
        ifFalse: [taskArg isNil ifTrue: [taskArg := a]]].
      i := i + 1
    ].

    taskArg isNil ifTrue: [
      "List available session files"
      | listing fileList |
      'Available sessions:' println.
      [
        listing := Shell capture: 'ls -1 "', sessionsDir, '" 2>/dev/null'.
        listing isEmpty ifTrue: [
          '  (none)' println.
          ^self
        ].
        fileList := listing split: lf.
        fileList do: [:f |
          f isEmpty ifFalse: [
            | name |
            name := f.
            (name endsWith: '.jsonl') ifTrue: [
              name := name copyFrom: 0 to: name size - 6
            ].
            ('  ', name) println
          ]
        ]
      ] on: Exception do: [:e |
        ('Error listing sessions: ', e messageText) println
      ].
      ^self
    ].

    filePath := sessionsDir, '/', taskArg, '.jsonl'.

    (File exists: filePath) ifFalse: [
      ('Session file not found: ', filePath) println.
      ^self
    ].

    [
      contents := File readFileContents: filePath.
      lines := contents split: lf.
      ('Session: ', taskArg) println.
      ('Lines: ', lines size printString) println.
      '---' println.

      lines do: [:line |
        line isEmpty ifFalse: [
          | entry entryType |
          [
            entry := Json decode: line.
            entryType := entry at: 'type' ifAbsent: ['unknown'].

            entryType = 'system' ifTrue: [
              mode = 'summary' ifFalse: [self showSystemEntry: entry]
            ].

            entryType = 'assistant' ifTrue: [
              self showAssistantEntry: entry mode: mode
            ].

            entryType = 'tool_result' ifTrue: [
              mode = 'summary' ifFalse: [self showToolResultEntry: entry mode: mode]
            ].

            entryType = 'result' ifTrue: [
              mode = 'summary' ifFalse: [self showResultEntry: entry]
            ].

            "Show usage if present (suppressed in summary mode)"
            mode = 'summary' ifFalse: [
              (entry at: 'usage' ifAbsent: [nil]) notNil ifTrue: [
                self showUsage: (entry at: 'usage')
              ]
            ]
          ] on: Exception do: [:e | ]
        ]
      ]
    ] on: Exception do: [:e |
      ('Error reading session: ', e messageText) println
    ]
  ]

  method: showSystemEntry: entry [
    | msg model cwd |
    msg := '  [system] Session init'.
    model := entry at: 'model' ifAbsent: [nil].
    model notNil ifTrue: [msg := msg, ' model=', model].
    cwd := entry at: 'cwd' ifAbsent: [nil].
    cwd notNil ifTrue: [msg := msg, ' cwd=', cwd].
    msg println
  ]

  method: showAssistantEntry: entry mode: mode [
    | content |
    content := entry at: 'content' ifAbsent: [nil].
    content isNil ifTrue: [
      | message |
      message := entry at: 'message' ifAbsent: [nil].
      message notNil ifTrue: [
        content := message at: 'content' ifAbsent: [nil]
      ]
    ].
    content isNil ifTrue: [^self].

    (content isKindOf: String) ifTrue: [
      | shown |
      shown := (mode = 'full' or: [content size <= 120])
        ifTrue: [content]
        ifFalse: [content copyFrom: 0 to: 120].
      ('  [assistant] ', shown) println.
      ^self
    ].

    (content isKindOf: Array) ifTrue: [
      content do: [:block |
        | blockType |
        (block isKindOf: Dictionary) ifTrue: [
          blockType := block at: 'type' ifAbsent: [''].
          blockType = 'thinking' ifTrue: ["always skip thinking blocks"].
          blockType = 'text' ifTrue: [
            | text shown |
            text := block at: 'text' ifAbsent: [''].
            shown := (mode = 'full' or: [text size <= 120])
              ifTrue: [text]
              ifFalse: [text copyFrom: 0 to: 120].
            ('  [assistant] ', shown) println
          ].
          blockType = 'tool_use' ifTrue: [
            | toolName inputStr shown |
            toolName := block at: 'name' ifAbsent: ['?'].
            mode = 'summary'
              ifTrue: [('  [tool_use] ', toolName) println]
              ifFalse: [
                inputStr := Json encode: (block at: 'input' ifAbsent: [Dictionary new]).
                shown := (mode = 'full' or: [inputStr size <= 80])
                  ifTrue: [inputStr]
                  ifFalse: [inputStr copyFrom: 0 to: 80].
                ('  [tool_use] ', toolName, ' ', shown) println
              ]
          ]
        ]
      ]
    ]
  ]

  method: showToolResultEntry: entry mode: mode [
    | isError content shown |
    isError := entry at: 'is_error' ifAbsent: [false].
    content := entry at: 'content' ifAbsent: [''].
    (content isKindOf: String) ifTrue: [
      shown := (mode = 'full' or: [content size <= 80])
        ifTrue: [content]
        ifFalse: [content copyFrom: 0 to: 80].
      isError
        ifTrue: [('  [tool_result] ERROR: ', shown) println]
        ifFalse: [mode = 'full'
          ifTrue: [('  [tool_result] ok (', content size printString, ' chars): ', shown) println]
          ifFalse: [('  [tool_result] ok (', content size printString, ' chars)') println]]
    ] ifFalse: [
      isError
        ifTrue: ['  [tool_result] ERROR' println]
        ifFalse: ['  [tool_result] ok' println]
    ]
  ]

  method: showResultEntry: entry [
    | result subtype |
    result := entry at: 'result' ifAbsent: [nil].
    result isNil ifTrue: [^self].
    subtype := result at: 'subtype' ifAbsent: [''].
    ('  [result] subtype=', subtype) println
  ]

  method: showUsage: usage [
    | input output |
    input := usage at: 'input_tokens' ifAbsent: [0].
    output := usage at: 'output_tokens' ifAbsent: [0].
    (input > 0 or: [output > 0]) ifTrue: [
      ('    tokens: in=', input printString, ' out=', output printString) println
    ]
  ]

  "--- Usage / Self-Regulation ---"

  method: cmdUsage: args [
    "pp usage [<taskId>] [--json]
     Report current session token consumption so the agent can self-regulate.
     Resolution order for which session file to read:
       1. positional <taskId> argument
       2. PP_OUTPUT_FILE env var (set by harness)
       3. PP_TASK env var -> ~/.pp/sessions/<task>.jsonl
     Output (default, human-readable):
       context_tokens   approximation of current context size (last turn's
                        input + cache_creation + cache_read)
       total_input      sum across all turns of input + cache_creation
       total_cache_read sum of cache-read input tokens
       total_output     sum of output tokens
       turns            count of assistant messages with usage
     With --json, emit a single JSON object with the same fields."
    | homeDir sessionsDir taskArg filePath contents lines lf jsonMode i a
      contextTokens totalInput totalCacheRead totalOutput turns
      lastInput lastCacheCreation lastCacheRead env outFile result |

    homeDir := System env: 'HOME'.
    sessionsDir := homeDir, '/.pp/sessions'.
    lf := Character lf asString.

    "Parse args: --json flag and optional positional taskId"
    jsonMode := false.
    taskArg := nil.
    i := 1.
    [i < args size] whileTrue: [
      a := args at: i.
      a = '--json' ifTrue: [jsonMode := true]
        ifFalse: [taskArg isNil ifTrue: [taskArg := a]].
      i := i + 1
    ].

    "Resolve file path"
    filePath := nil.
    taskArg notNil ifTrue: [
      filePath := sessionsDir, '/', taskArg, '.jsonl'
    ] ifFalse: [
      outFile := System env: 'PP_OUTPUT_FILE'.
      (outFile notNil and: [outFile isEmpty not]) ifTrue: [
        filePath := outFile
      ] ifFalse: [
        env := System env: 'PP_TASK'.
        (env notNil and: [env isEmpty not]) ifTrue: [
          filePath := sessionsDir, '/', env, '.jsonl'
        ]
      ]
    ].

    filePath isNil ifTrue: [
      'Error: no session file. Pass <taskId> or set PP_TASK / PP_OUTPUT_FILE.' println.
      ^self
    ].

    (File exists: filePath) ifFalse: [
      ('Error: session file not found: ', filePath) println.
      ^self
    ].

    "Tally usage across all assistant messages"
    contextTokens := 0.
    totalInput := 0.
    totalCacheRead := 0.
    totalOutput := 0.
    turns := 0.
    lastInput := 0.
    lastCacheCreation := 0.
    lastCacheRead := 0.

    [
      contents := File readFileContents: filePath.
      lines := contents split: lf.
      lines do: [:line |
        line isEmpty ifFalse: [
          [
            | entry message usage inTok outTok ccTok crTok |
            entry := Json decode: line.
            "Usage may live at top level or under message.usage (assistant entries)"
            usage := entry at: 'usage' ifAbsent: [nil].
            usage isNil ifTrue: [
              message := entry at: 'message' ifAbsent: [nil].
              (message notNil and: [message isKindOf: Dictionary]) ifTrue: [
                usage := message at: 'usage' ifAbsent: [nil]
              ]
            ].
            usage notNil ifTrue: [
              inTok := usage at: 'input_tokens' ifAbsent: [0].
              outTok := usage at: 'output_tokens' ifAbsent: [0].
              ccTok := usage at: 'cache_creation_input_tokens' ifAbsent: [0].
              crTok := usage at: 'cache_read_input_tokens' ifAbsent: [0].
              totalInput := totalInput + inTok + ccTok.
              totalCacheRead := totalCacheRead + crTok.
              totalOutput := totalOutput + outTok.
              turns := turns + 1.
              lastInput := inTok.
              lastCacheCreation := ccTok.
              lastCacheRead := crTok
            ]
          ] on: Exception do: [:e | "skip malformed line"]
        ]
      ]
    ] on: Exception do: [:e |
      ('Error reading session: ', e messageText) println.
      ^self
    ].

    contextTokens := lastInput + lastCacheCreation + lastCacheRead.

    jsonMode ifTrue: [
      result := Dictionary new.
      result at: 'session_file' put: filePath.
      result at: 'turns' put: turns.
      result at: 'context_tokens' put: contextTokens.
      result at: 'total_input' put: totalInput.
      result at: 'total_cache_read' put: totalCacheRead.
      result at: 'total_output' put: totalOutput.
      (Json encode: result) println.
      ^self
    ].

    'Session usage:' println.
    ('  file:             ', filePath) println.
    ('  turns:            ', turns printString) println.
    ('  context_tokens:   ', contextTokens printString, '  (last turn input + cache)') println.
    ('  total_input:      ', totalInput printString, '  (input + cache_creation, summed)') println.
    ('  total_cache_read: ', totalCacheRead printString) println.
    ('  total_output:     ', totalOutput printString)  println
  ]
