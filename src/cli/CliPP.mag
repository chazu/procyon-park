"CliPP — port of several pp subcommands to the new Maggie Cli framework
 (Cli::Command, Cli::Flag, Cli::EnvBinding, Cli::Output).

 Activated by setting PP_USE_CLI=1 (any truthy value). When unset, the
 original PP/SystemCommands/WorkflowCommands code paths run unchanged.
 The ported commands are:

   pp status          — exercises Cli::Command + Cli::EnvBinding + Cli::Output
   pp workflow list   — exercises Cli::Command + Cli::Flag + Cli::Output
   pp log             — exercises Cli::Flag #bool pair + Cli::EnvBinding for
                        two log-specific env vars
   pp prime           — no-flags command, exercises text output + env bindings
   pp gc              — exercises Cli::Flag #bool flags (--dry-run, --all)

 See docs/cli-poc-writeup.md for findings."

PPCliConfig subclass: Object
  instanceVars: baseUrl scope taskId logFollow logSince workflowInstance

  classMethod: new [
    | c |
    c := super new.
    c init.
    ^c
  ]

  method: init [
    baseUrl := 'http://localhost:7777'.
    scope := 'default'.
    taskId := ''.
    logFollow := true.
    logSince := ''.
    workflowInstance := ''
  ]

  method: baseUrl [ ^baseUrl ]
  method: baseUrl: aValue [ baseUrl := aValue ]
  method: scope [ ^scope ]
  method: scope: aValue [ scope := aValue ]
  method: taskId [ ^taskId ]
  method: taskId: aValue [ taskId := aValue ]
  method: logFollow [ ^logFollow ]
  method: logFollow: aValue [ logFollow := aValue ]
  method: logSince [ ^logSince ]
  method: logSince: aValue [ logSince := aValue ]
  method: workflowInstance [ ^workflowInstance ]
  method: workflowInstance: aValue [ workflowInstance := aValue ]


CliPP subclass: Object

  "--- Toggle / dispatch ----------------------------------------------------"

  classMethod: enabled [
    "Returns true when PP_USE_CLI is set to a truthy value."
    | raw lower |
    raw := System env: 'PP_USE_CLI'.
    (raw isNil or: [raw isEmpty]) ifTrue: [^false].
    lower := raw asLowercase.
    ^(lower = '1') or: [(lower = 'true') or: [lower = 'yes']]
  ]

  classMethod: handles: args [
    "Returns true when this PoC should handle the given args. We claim
     `pp status`, the full `pp workflow` subcommand tree, `pp log`,
     `pp prime`, `pp gc`, `pp read`, `pp history`, and the six
     signal-writer subcommands (observe, decide, event, notify, signal,
     dismiss); everything else falls through to the existing dispatcher."
    | head |
    args isEmpty ifTrue: [^false].
    head := args at: 0.
    head = 'status'   ifTrue: [^true].
    head = 'log'      ifTrue: [^true].
    head = 'prime'    ifTrue: [^true].
    head = 'gc'       ifTrue: [^true].
    head = 'observe'  ifTrue: [^true].
    head = 'decide'   ifTrue: [^true].
    head = 'event'    ifTrue: [^true].
    head = 'notify'   ifTrue: [^true].
    head = 'signal'   ifTrue: [^true].
    head = 'verdict'  ifTrue: [^true].
    head = 'dismiss'  ifTrue: [^true].
    head = 'read'     ifTrue: [^true].
    head = 'history'  ifTrue: [^true].
    head = 'workflow' ifTrue: [^true].
    head = 'workitem' ifTrue: [^true].
    head = 'repo'     ifTrue: [^true].
    head = 'worktree' ifTrue: [^true].
    head = 'clean-branches' ifTrue: [^true].
    head = 'task'     ifTrue: [^true].
    head = 'session'  ifTrue: [^true].
    head = 'usage'    ifTrue: [^true].
    head = 'plan'     ifTrue: [^true].
    head = 'identity' ifTrue: [^true].
    ^false
  ]

  classMethod: runWith: args [
    "Dispatch from Main.start. Returns the exit code from cobra."
    | head |
    args isEmpty ifTrue: [^0].
    head := args at: 0.
    head = 'status'   ifTrue: [^self runStatus: args].
    head = 'workflow' ifTrue: [^self runWorkflow: args].
    head = 'log'      ifTrue: [^self runLog: args].
    head = 'prime'    ifTrue: [^self runPrime: args].
    head = 'gc'       ifTrue: [^self runGc: args].
    head = 'observe'  ifTrue: [^self runObserve: args].
    head = 'decide'   ifTrue: [^self runDecide: args].
    head = 'event'    ifTrue: [^self runEvent: args].
    head = 'notify'   ifTrue: [^self runNotify: args].
    head = 'signal'   ifTrue: [^self runSignal: args].
    head = 'verdict'  ifTrue: [^self runVerdict: args].
    head = 'dismiss'  ifTrue: [^self runDismiss: args].
    head = 'read'     ifTrue: [^self runRead: args].
    head = 'history'  ifTrue: [^self runHistory: args].
    head = 'workitem' ifTrue: [^self runWorkitem: args].
    head = 'repo'     ifTrue: [^self runRepo: args].
    head = 'worktree' ifTrue: [^self runWorktree: args].
    head = 'clean-branches' ifTrue: [^self runCleanBranches: args].
    head = 'task'     ifTrue: [^self runTask: args].
    head = 'session'  ifTrue: [^self runSession: args].
    head = 'usage'    ifTrue: [^self runUsage: args].
    head = 'plan'     ifTrue: [^self runPlan: args].
    head = 'identity' ifTrue: [^self runIdentity: args].
    ^0
  ]

  "--- Subcommand: status --------------------------------------------------"

  classMethod: runStatus: args [
    "Build, configure, and dispatch the new `status` command.

     Exercises:
       * Cli::Command         — leaf command + run block
       * Cli::EnvBinding      — PP_URL, PP_SCOPE, PP_TASK projected onto
                                a PPCliConfig instance
       * Cli::Output          — dictText: for the status fields
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'status' doc: 'Show system status'.

    "Default values match CLIBase>>initialize so behavior is preserved
     when the corresponding env var is unset."
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_TASK'
      setter: #taskId:
      type: #string
      default: '').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      cmd applyEnvBindings: cfg.
      self performStatus: cfg.
      0
    ].

    "args[0] is 'status' — strip it before handing control to cobra so
     the leaf command sees only its own options/positionals."
    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    "Catch Cli::CliError (bad flags / unknown subcommand) the same way
     examples/cli/demo.mag does — cobra prints the error/usage to stderr
     before raising; we just need to convert the signal into exit 1."
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: performStatus: cfg [
    "GET /api/health, then render the result via Cli::Output dictText:."
    | response health dict |
    response := self unauthedGet: '/api/health' cfg: cfg.
    [
      response isNil ifTrue: [^self].
      (response isKindOf: String) ifFalse: [
        ('Error: server returned non-String response') println.
        ^self
      ].
      response isEmpty ifTrue: [
        ('Error: empty response from server') println.
        ^self
      ].
      health := Json decode: response.

      'Procyon Park Status:' println.

      "Build a Dictionary so Cli::Output can render aligned key/value lines."
      dict := Dictionary new.
      dict at: 'tuples' put: (health at: 'tuples' ifAbsent: ['?']) printString.
      dict at: 'uptime' put: (health at: 'uptime' ifAbsent: ['?']) printString, 's'.
      dict at: 'slots' put:
        (health at: 'active_slots' ifAbsent: ['?']) printString, ' / ',
        (health at: 'max_slots' ifAbsent: ['?']) printString.
      dict at: 'active_tasks' put: (health at: 'active_tasks' ifAbsent: ['?']) printString.
      dict at: 'pending_tasks' put: (health at: 'pending_tasks' ifAbsent: ['?']) printString.
      dict at: 'avg_task_duration_s' put: (health at: 'avg_task_duration_s' ifAbsent: ['?']) printString.
      dict at: 'error_count_last_hour' put: (health at: 'error_count_last_hour' ifAbsent: ['?']) printString.
      cfg taskId isEmpty ifFalse: [
        dict at: 'task' put: cfg taskId.
        dict at: 'scope' put: cfg scope
      ].
      Cli::Output dictText: dict
    ] on: Exception do: [:e |
      ('Error connecting to Procyon Park at ', cfg baseUrl, ': ', e messageText) println
    ]
  ]

  "--- Subcommand: workflow (parent + children) ----------------------------"

  classMethod: runWorkflow: args [
    "Top-level dispatcher for `pp workflow ...`. Cobra rejects unknown
     first args when a command has children, so the bare
     `pp workflow <template>` form (start a workflow) can't be modelled
     as a run block on the parent — cobra complains with
     `unknown command <template>`. We detect it here and route to a
     dedicated leaf command (runWorkflowStart:). Everything else goes
     through the children tree (list/status/cancel/wait + help)."
    | head knownChildren |
    knownChildren := #('list' 'status' 'cancel' 'wait' 'help'
                       '--help' '-h' 'completion').
    args size <= 1 ifTrue: [^self runWorkflowTree: args].
    head := args at: 1.
    (knownChildren includes: head) ifTrue: [^self runWorkflowTree: args].
    "Leading `-` means a flag — let cobra report unknown-flag against
     the parent, which prints usage. Everything else is a template id."
    (head startsWith: '-') ifTrue: [^self runWorkflowTree: args].
    ^self runWorkflowStart: args
  ]

  classMethod: runWorkflowStart: args [
    "Handle `pp workflow <template> [--scope S] [--repo R] [--param k=v ...]`
     as a leaf command with no children. This path exercises the
     repeatable --param flag via manual accumulation, plus two string
     flags and a required positional arg.

     Exercises:
       * Cli::Command       — leaf command with required positional
       * Cli::Flag          — --scope / --repo string flags
       * Manual flag loop   — --param repeated (no StringArray primitive)
     "
    | cmd cfg rest repoParams argTail params prunedRest |
    cfg := self loadConfig.
    cmd := Cli::Command named: 'workflow' doc: 'Start a workflow'.
    cmd flag: (Cli::Flag
      name: 'scope'
      type: #string
      default: ''
      doc: 'Scope for the workflow (defaults to PP_SCOPE / repo name)').
    cmd flag: (Cli::Flag
      name: 'repo'
      type: #string
      default: ''
      doc: 'Inject repo into params and default scope to repo name').

    argTail := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    repoParams := self extractParamFlags: argTail.
    params := repoParams at: 0.
    prunedRest := repoParams at: 1.

    cmd run: [:runArgs |
      | scopeArg repoArg theScope templateId body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workflow <template> [--scope <scope>] [--repo <name>] [--param key=value ...]' println.
        exitCode := 1
      ] ifFalse: [
        templateId := runArgs at: 0.
        scopeArg := cmd flagValue: 'scope'.
        repoArg := cmd flagValue: 'repo'.
        (repoArg isNil or: [repoArg isEmpty]) ifTrue: [
          repoArg := System env: 'PP_REPO'.
          (repoArg isNil or: [repoArg isEmpty]) ifTrue: [repoArg := nil]
        ].
        theScope := (scopeArg notNil and: [scopeArg isEmpty not])
          ifTrue: [scopeArg]
          ifFalse: [
            repoArg notNil ifTrue: [repoArg] ifFalse: [cfg scope]
          ].
        repoArg notNil ifTrue: [
          params at: 'repo' put: repoArg
        ].
        body := Dictionary new.
        body at: 'template' put: templateId.
        body at: 'scope' put: theScope.
        body at: 'params' put: params.
        self postAndPrint: cfg path: '/api/workflow/start' body: body
      ].
      exitCode
    ].

    rest := prunedRest.
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: runWorkflowTree: args [
    "Dispatch `pp workflow [list|status|cancel|wait] ...` via the
     children tree. Cobra owns flag parsing for each child."
    | root list status cancel wait rest cfg |
    cfg := self loadConfig.

    root := Cli::Command named: 'workflow' doc: 'Workflow operations'.

    "--- Child: list (unchanged from before — pure tabular listing)"
    list := Cli::Command named: 'list' doc: 'Tabular listing of workflows'.
    list flag: (Cli::Flag
      name: 'status'
      type: #string
      default: ''
      doc: 'Filter by status (running, completed, failed, cancelled)').
    list flag: (Cli::Flag
      name: 'scope'
      type: #string
      default: ''
      doc: 'Restrict to a single scope (otherwise scans all scopes)').
    list run: [:runArgs |
      | statusFilter scopeFilter |
      statusFilter := list flagValue: 'status'.
      scopeFilter := list flagValue: 'scope'.
      self performWorkflowList: cfg
           statusFilter: statusFilter
           scopeFilter: scopeFilter.
      0
    ].

    "--- Child: status — no id => tabular; id => detail view"
    status := Cli::Command named: 'status' doc: 'Show workflow status (list if no id)'.
    status flag: (Cli::Flag
      name: 'scope'
      type: #string
      default: ''
      doc: 'Restrict to a single scope when listing; required for id detail').
    status run: [:runArgs |
      | scopeFilter |
      scopeFilter := status flagValue: 'scope'.
      runArgs size >= 1
        ifTrue: [self performWorkflowStatusDetail: cfg id: (runArgs at: 0) scope: scopeFilter]
        ifFalse: [self performWorkflowStatusList: cfg scope: scopeFilter].
      0
    ].

    "--- Child: cancel <id> [--scope]"
    cancel := Cli::Command named: 'cancel' doc: 'Cancel a running workflow'.
    cancel flag: (Cli::Flag
      name: 'scope'
      type: #string
      default: ''
      doc: 'Scope of the workflow (defaults to PP_SCOPE)').
    cancel run: [:runArgs |
      | scopeArg theScope body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workflow cancel <workflow-id> [--scope <scope>]' println.
        exitCode := 1
      ] ifFalse: [
        scopeArg := cancel flagValue: 'scope'.
        theScope := (scopeArg notNil and: [scopeArg isEmpty not])
          ifTrue: [scopeArg]
          ifFalse: [cfg scope].
        body := Dictionary new.
        body at: 'workflow_id' put: (runArgs at: 0).
        body at: 'scope' put: theScope.
        self postAndPrint: cfg path: '/api/workflow/cancel' body: body
      ].
      exitCode
    ].

    "--- Child: wait <id> [--scope] [--timeout N]"
    wait := Cli::Command named: 'wait' doc: 'Block until a workflow reaches terminal state'.
    wait flag: (Cli::Flag
      name: 'scope'
      type: #string
      default: ''
      doc: 'Scope of the workflow (defaults to PP_SCOPE)').
    wait flag: (Cli::Flag
      name: 'timeout'
      type: #int
      default: 3600
      doc: 'Maximum seconds to wait before giving up (default 3600)').
    wait run: [:runArgs |
      | scopeArg theScope maxWait exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workflow wait <workflow-id> [--scope <scope>] [--timeout <seconds>]' println.
        exitCode := 1
      ] ifFalse: [
        scopeArg := wait flagValue: 'scope'.
        theScope := (scopeArg notNil and: [scopeArg isEmpty not])
          ifTrue: [scopeArg]
          ifFalse: [cfg scope].
        maxWait := wait flagValue: 'timeout'.
        (maxWait isNil or: [maxWait <= 0]) ifTrue: [maxWait := 3600].
        self performWorkflowWait: cfg id: (runArgs at: 0) scope: theScope timeout: maxWait
      ].
      exitCode
    ].

    root registerSubcommand: list.
    root registerSubcommand: status.
    root registerSubcommand: cancel.
    root registerSubcommand: wait.

    "args = #('workflow' ...). Strip the leading `workflow` so cobra
     dispatches directly to the named child."
    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    root setArgs: rest.
    ^[root execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: extractParamFlags: argArr [
    "Walk argArr extracting every `--param <k=v>` or `--param=<k=v>` pair
     into a Dictionary, returning a two-element Array #(paramsDict cleanArgs).
     This is the manual-accumulation fallback for repeated --param flags
     (the Cli framework has no StringArray flag type)."
    | i params out arg next eqIdx key val result rest2 |
    params := Dictionary new.
    out := Array new: 0.
    i := 0.
    [i < argArr size] whileTrue: [
      arg := argArr at: i.
      arg = '--param' ifTrue: [
        i < (argArr size - 1) ifTrue: [
          i := i + 1.
          next := argArr at: i.
          eqIdx := next indexOf: '='.
          eqIdx >= 0 ifTrue: [
            key := next copyFrom: 0 to: eqIdx.
            val := next copyFrom: eqIdx + 1.
            params at: key put: val
          ]
        ]
      ] ifFalse: [
        (arg startsWith: '--param=') ifTrue: [
          rest2 := arg copyFrom: 8.
          eqIdx := rest2 indexOf: '='.
          eqIdx >= 0 ifTrue: [
            key := rest2 copyFrom: 0 to: eqIdx.
            val := rest2 copyFrom: eqIdx + 1.
            params at: key put: val
          ]
        ] ifFalse: [
          out := out copyWith: arg
        ]
      ].
      i := i + 1
    ].
    result := Array new: 2.
    result at: 0 put: params.
    result at: 1 put: out.
    ^result
  ]

  classMethod: loadConfig [
    "Hand-rolled env load (no Cli::EnvBinding) — workflow list is the
     Cli::Flag exemplar, status is the Cli::EnvBinding exemplar. Keeping
     them split makes the writeup compare both shapes side by side."
    | cfg url s |
    cfg := PPCliConfig new.
    url := System env: 'PP_URL'.
    (url notNil and: [url isEmpty not]) ifTrue: [cfg baseUrl: url].
    s := System env: 'PP_SCOPE'.
    (s notNil and: [s isEmpty not]) ifTrue: [cfg scope: s].
    ^cfg
  ]

  classMethod: performWorkflowList: cfg statusFilter: statusFilter scopeFilter: scopeFilter [
    "Replicate WorkflowCommands>>cmdWorkflowList: but render the table
     via Cli::Output table:headers:keys:."
    | workflows filtered now rows |

    workflows := self safeScanWorkflows: cfg scope: scopeFilter.

    "Apply --status filter (empty string means no filter)."
    filtered := workflows.
    (statusFilter notNil and: [statusFilter isEmpty not]) ifTrue: [
      filtered := workflows select: [:w |
        | p s |
        p := w at: 'payload' ifAbsent: [Dictionary new].
        s := p at: 'status' ifAbsent: [''].
        s = statusFilter
      ]
    ].

    filtered size = 0 ifTrue: [
      (statusFilter notNil and: [statusFilter isEmpty not])
        ifTrue: [('No workflows with status: ', statusFilter) println]
        ifFalse: ['No workflows.' println].
      ^self
    ].

    now := DateTime now epochSeconds.

    "Project every workflow tuple into a Dictionary row keyed by the
     column names declared below. Cli::Output table: handles widths."
    rows := Array new: 0.
    filtered do: [:wf |
      | row wfId payload template wfStatus params description startedAt completedAt duration durStr truncDesc |
      wfId := wf at: 'identity' ifAbsent: ['?'].
      payload := wf at: 'payload' ifAbsent: [Dictionary new].
      template := payload at: 'template' ifAbsent: ['?'].
      wfStatus := payload at: 'status' ifAbsent: ['?'].
      params := payload at: 'params' ifAbsent: [nil].
      description := params notNil
        ifTrue: [params at: 'description' ifAbsent: ['']]
        ifFalse: [''].
      startedAt := payload at: 'started_at' ifAbsent: [0].
      completedAt := payload at: 'completed_at' ifAbsent: [nil].
      duration := 0.
      startedAt > 0 ifTrue: [
        completedAt notNil
          ifTrue: [duration := completedAt - startedAt]
          ifFalse: [duration := now - startedAt]
      ].
      durStr := self formatDuration: duration.
      truncDesc := description size > 50
        ifTrue: [(description copyFrom: 0 to: 47), '...']
        ifFalse: [description].

      row := Dictionary new.
      row at: 'id' put: wfId.
      row at: 'template' put: template.
      row at: 'status' put: wfStatus.
      row at: 'duration' put: durStr.
      row at: 'description' put: truncDesc.
      rows := rows copyWith: row
    ].

    Cli::Output
      table: rows
      headers: #('INSTANCE ID' 'TEMPLATE' 'STATUS' 'DURATION' 'DESCRIPTION')
      keys: #('id' 'template' 'status' 'duration' 'description')
  ]

  classMethod: safeScanWorkflows: cfg scope: scopeFilter [
    "Like CLIBase>>safeScan: but a class-side helper that doesn't need
     a CLIBase instance. An empty scopeFilter (the Cli::Flag default)
     means scan all scopes. /api/scan is read-only and intentionally
     unsigned per F1.4/NF6."
    | body response result |
    body := Dictionary new.
    body at: 'category' put: 'workflow'.
    (scopeFilter notNil and: [scopeFilter isEmpty not]) ifTrue: [
      body at: 'scope' put: scopeFilter
    ].
    response := self unauthedPost: '/api/scan' body: body cfg: cfg.
    response isNil ifTrue: [^Array new: 0].
    [
      result := Json decode: response.
      ^result at: 'tuples' ifAbsent: [Array new: 0]
    ] on: Exception do: [:e | ^Array new: 0]
  ]

  classMethod: formatDuration: seconds [
    "Identical to WorkflowCommands>>formatDuration: so durations render
     consistently between the old and new implementations."
    | h m s |
    seconds <= 0 ifTrue: [^'-'].
    h := seconds / 3600.
    m := (seconds - (h * 3600)) / 60.
    s := seconds - (h * 3600) - (m * 60).
    h > 0 ifTrue: [^h printString, 'h', m printString, 'm'].
    m > 0 ifTrue: [^m printString, 'm', s printString, 's'].
    ^s printString, 's'
  ]

  "--- Shared scan helper --------------------------------------------------"

  classMethod: safeScan: category cfg: cfg scope: aScope [
    "Generic scan helper used by runPrime: and runGc:. An empty/nil
     aScope means scan every scope. Read-only — unsigned."
    | body response result |
    body := Dictionary new.
    body at: 'category' put: category.
    (aScope notNil and: [aScope isEmpty not]) ifTrue: [
      body at: 'scope' put: aScope
    ].
    response := self unauthedPost: '/api/scan' body: body cfg: cfg.
    response isNil ifTrue: [^Array new: 0].
    [
      result := Json decode: response.
      ^result at: 'tuples' ifAbsent: [Array new: 0]
    ] on: Exception do: [:e | ^Array new: 0]
  ]

  classMethod: silentInp: category cfg: cfg scope: aScope identity: anIdentity [
    "Remove a tuple from the BBS silently. /api/inp is a mutating
     endpoint; route through the signed POST helper so GC works under
     enforce_signatures=true. Errors are swallowed (silent)."
    | body |
    body := Dictionary new.
    body at: 'category' put: category.
    body at: 'scope' put: aScope.
    body at: 'identity' put: anIdentity.
    [self signedPost: '/api/inp' body: body cfg: cfg]
      on: Exception do: [:e | "ignore"]
  ]

  "--- Subcommand: log -----------------------------------------------------"

  classMethod: runLog: args [
    "Build, configure, and dispatch the new `log` command.

     Exercises:
       * Cli::Command     — leaf command + streaming run block
       * Cli::Flag #bool  — --follow / --no-follow pair pattern, both are
                            registered as distinct bool flags so the
                            user can say either `--follow=false` or
                            `--no-follow` to disable streaming.
       * Cli::Flag #string — --since accepts an offset in seconds.
       * Cli::EnvBinding  — PP_LOG_FOLLOW and PP_LOG_SINCE are applied
                            to a PPCliConfig instance and the resulting
                            values become the flag defaults, so env
                            vars act as user-level defaults that the
                            per-invocation flag can override.
     "
    | cmd cfg rest followBinding sinceBinding |
    cfg := PPCliConfig new.

    "Apply PP_LOG_FOLLOW / PP_LOG_SINCE up front so the flag defaults
     reflect the user's environment. Flags then override on a per-call
     basis."
    followBinding := Cli::EnvBinding
      envName: 'PP_LOG_FOLLOW'
      setter: #logFollow:
      type: #bool
      default: true.
    sinceBinding := Cli::EnvBinding
      envName: 'PP_LOG_SINCE'
      setter: #logSince:
      type: #string
      default: ''.
    followBinding applyTo: cfg.
    sinceBinding applyTo: cfg.

    cmd := Cli::Command named: 'log' doc: 'Stream notifications from the server'.

    "Connection-level env bindings, applied from inside the run block."
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').

    "Bool flag pair: --follow defaults to the env-derived value so
     `./pp log` still streams by default; --no-follow is a separate
     bool that forces follow off when set."
    cmd flag: (Cli::Flag
      name: 'follow'
      type: #bool
      default: cfg logFollow
      doc: 'Follow and stream new notifications (default true)').
    cmd flag: (Cli::Flag
      name: 'no-follow'
      type: #bool
      default: false
      doc: 'Disable streaming: fetch once and exit').
    cmd flag: (Cli::Flag
      name: 'since'
      type: #string
      default: cfg logSince
      doc: 'Offset in seconds from now for the initial cursor').

    cmd run: [:runArgs |
      | follow sinceStr |
      cmd applyEnvBindings: cfg.
      follow := cmd flagValue: 'follow'.
      (cmd flagValue: 'no-follow') ifTrue: [follow := false].
      sinceStr := cmd flagValue: 'since'.
      self performLog: cfg follow: follow since: sinceStr.
      0
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: performLog: cfg follow: follow since: sinceStr [
    "Port of SystemCommands>>cmdLog: that uses explicit follow / since
     values rather than scanning the raw args. Non-following mode does
     a single fetch via curl (to avoid the HttpClient blocking bug);
     following mode long-polls via HttpClient in a loop."
    | sinceOffset since url client response result notifications
      payload createdAt severity message ts maxCreatedAt dt sinceEpochStr |
    sinceOffset := 0.
    (sinceStr notNil and: [sinceStr isEmpty not]) ifTrue: [
      sinceOffset := sinceStr asInteger.
      sinceOffset isNil ifTrue: [sinceOffset := 0]
    ].
    since := DateTime now epochSeconds - sinceOffset.

    follow ifFalse: [
      "Single-shot path mirrors SystemCommands>>cmdLog:'s curl branch."
      sinceEpochStr := since printString.
      url := cfg baseUrl, '/api/notifications/stream?since=', sinceEpochStr, '&wait=0'.
      response := Shell capture: 'curl -s "', url, '"'.
      (response notNil and: [response isEmpty not]) ifTrue: [
        [
          result := Json decode: response.
          notifications := result at: 'notifications' ifAbsent: [#()].
          notifications do: [:notif |
            payload := notif.
            createdAt := payload at: 'created_at' ifAbsent: [0].
            severity := payload at: 'severity' ifAbsent: ['info'].
            message := payload at: 'message' ifAbsent: [''].
            dt := DateTime fromEpoch: createdAt.
            ts := dt printString.
            (ts, ' [', severity, '] ', message) println
          ]
        ] on: Exception do: [:e |
          ('Error: ', e messageText) println
        ]
      ].
      ^self
    ].

    "Following mode: long-poll loop. This runs inside the Cli::Command's
     run block — cobra does not impose a timeout, so the loop is free to
     run until the user interrupts. The notification-stream endpoint is
     a read-only GET so it is intentionally unsigned."
    [true] whileTrue: [
      sinceEpochStr := since printString.
      url := '/api/notifications/stream?since=', sinceEpochStr, '&wait=1'.
      [
        response := self unauthedGet: url cfg: cfg.
        (response notNil and: [(response isKindOf: String) and: [response isEmpty not]]) ifTrue: [
          result := Json decode: response.
          notifications := result at: 'notifications' ifAbsent: [#()].
          maxCreatedAt := since.
          notifications do: [:notif |
            payload := notif.
            createdAt := payload at: 'created_at' ifAbsent: [0].
            severity := payload at: 'severity' ifAbsent: ['info'].
            message := payload at: 'message' ifAbsent: [''].
            dt := DateTime fromEpoch: createdAt.
            ts := dt printString.
            (ts, ' [', severity, '] ', message) println.
            createdAt > maxCreatedAt ifTrue: [maxCreatedAt := createdAt]
          ].
          notifications size > 0 ifTrue: [since := maxCreatedAt + 1]
        ]
      ] on: Exception do: [:e |
        ('Error polling notifications: ', e messageText) println
      ].
      Process sleep: 2000
    ]
  ]

  "--- Subcommand: prime ---------------------------------------------------"

  classMethod: runPrime: args [
    "Build, configure, and dispatch the new `prime` command.

     Exercises:
       * Cli::Command       — leaf command with no flags
       * Cli::EnvBinding    — PP_URL / PP_SCOPE / PP_TASK applied to cfg
       * Plain text output  — the priming context is free-form markdown,
                              so we bypass Cli::Output and just println
                              the whole string in one shot.
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'prime' doc: 'Output agent priming context'.

    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_TASK'
      setter: #taskId:
      type: #string
      default: '').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      cmd applyEnvBindings: cfg.
      self performPrime: cfg.
      0
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: performPrime: cfg [
    "Port of SystemCommands>>cmdPrime:. Builds the priming markdown by
     concatenating fixed header text with scanned tuples (conventions,
     facts, signals, pending notifications)."
    | conventions facts signals notifications out |

    out := '# Procyon Park Agent Context

You are connected to the Procyon Park orchestration system.
Communicate with it using the `pp` command-line tool.

## Available Commands

  pp observe <identity> <detail> [--tags t1,t2]     Report an observation
  pp decide <identity> <detail> [--rationale ..]     Record a decision
  pp event <identity> [--type T] [--summary S]       Emit an event
  pp plan <file.json>                                Submit a structured plan
  pp read <category> [scope] [identity]              Read tuples
  pp notify <message> [--severity info|warn|urgent]  Notify the user
  pp dismiss                                         Signal task completion
  pp status                                          Show system status
  pp task <id> --role <r> --description <d> [--workdir <p>]  Create a task
  pp workflow <template> [--param key=val ...]        Start a workflow
  pp signal <id> <key> <value>                       Upsert a signal
  pp log [--follow] [--no-follow] [--since <secs>]   Tail notification stream

Worktree base: ~/.pp/worktrees/
Dashboard:     ', cfg baseUrl, '/dashboard/

## Rules

- All coordination flows through `pp`. Do not coordinate with other agents directly.
- Report anything unexpected with `pp observe`.
- When done, run `pp dismiss`.

## Environment

  PP_URL   = ', cfg baseUrl, '
  PP_SCOPE = ', cfg scope, '
'.

    cfg taskId isEmpty ifFalse: [
      out := out, '  PP_TASK  = ', cfg taskId, '
'
    ].

    "Conventions (scope-independent)"
    conventions := self safeScan: 'convention' cfg: cfg scope: nil.
    conventions isEmpty ifFalse: [
      out := out, '
## Conventions

'.
      conventions do: [:t |
        | payload |
        payload := t at: 'payload' ifAbsent: [Dictionary new].
        out := out, '- **', (t at: 'identity' ifAbsent: ['?']), '**: ', (payload at: 'detail' ifAbsent: ['']), '
'
      ]
    ].

    "Facts in scope"
    facts := self safeScan: 'fact' cfg: cfg scope: cfg scope.
    facts isEmpty ifFalse: [
      out := out, '
## Known Facts (scope: ', cfg scope, ')

'.
      facts do: [:t |
        | payload |
        payload := t at: 'payload' ifAbsent: [Dictionary new].
        out := out, '- **', (t at: 'identity' ifAbsent: ['?']), '**: ', (payload at: 'detail' ifAbsent: ['']), '
'
      ]
    ].

    "Signals in scope"
    signals := self safeScan: 'signal' cfg: cfg scope: cfg scope.
    signals isEmpty ifFalse: [
      out := out, '
## Signals (scope: ', cfg scope, ')

'.
      signals do: [:t |
        | payload |
        payload := t at: 'payload' ifAbsent: [Dictionary new].
        out := out, '- **', (t at: 'identity' ifAbsent: ['?']), '**: ', (Json encode: payload), '
'
      ]
    ].

    "Pending notifications"
    notifications := self safeScan: 'notification' cfg: cfg scope: nil.
    notifications isEmpty ifFalse: [
      out := out, '
## Pending Notifications

'.
      notifications do: [:t |
        | payload |
        payload := t at: 'payload' ifAbsent: [Dictionary new].
        out := out, '- [', (payload at: 'severity' ifAbsent: ['info']), '] ', (payload at: 'message' ifAbsent: ['']), '
'
      ]
    ].

    out println
  ]

  "--- Subcommand: gc ------------------------------------------------------"

  classMethod: runGc: args [
    "Build, configure, and dispatch the new `gc` command.

     Exercises:
       * Cli::Command    — leaf command
       * Cli::Flag #bool — --dry-run and --all, both as value objects
       * Cli::EnvBinding — PP_URL / PP_SCOPE for connection config
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'gc' doc: 'Garbage-collect finished workflows & branches'.

    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').

    cmd flag: (Cli::Flag
      name: 'dry-run'
      type: #bool
      default: false
      doc: 'Preview what would be removed without actually removing it').
    cmd flag: (Cli::Flag
      name: 'all'
      type: #bool
      default: false
      doc: 'GC every workflow regardless of status (normally only terminal ones)').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | dryRun allFlag |
      cmd applyEnvBindings: cfg.
      dryRun := cmd flagValue: 'dry-run'.
      allFlag := cmd flagValue: 'all'.
      self performGc: cfg dryRun: dryRun all: allFlag.
      0
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: performGc: cfg dryRun: dryRun all: allFlag [
    "Port of SystemCommands>>cmdGc:. The --all flag relaxes the status
     filter so every workflow (including running ones) is considered
     for removal — useful in test environments where long-lived
     workflows need to be wiped."
    | count |
    'Procyon Park GC' println.
    dryRun ifTrue: ['(dry-run)' println].
    allFlag ifTrue: ['(all workflows — ignoring status filter)' println].
    count := self gcWorkflows: cfg dryRun: dryRun all: allFlag.
    self gcBranches: dryRun.
    ('Done. Removed ', count printString, ' workflows.') println
  ]

  classMethod: gcWorkflows: cfg dryRun: dryRun all: allFlag [
    "Scan all workflows; remove the ones in terminal states (or every
     one when allFlag is set). Returns the number of workflows
     removed/previewed."
    | body response result workflows count |
    body := Dictionary new.
    body at: 'category' put: 'workflow'.
    count := 0.
    response := self unauthedPost: '/api/scan' body: body cfg: cfg.
    response isNil ifTrue: [^0].
    [
      result := Json decode: response.
      workflows := result at: 'tuples' ifAbsent: [#()].
      workflows do: [:wf |
        | p status wfId wfScope shouldGc |
        p := wf at: 'payload' ifAbsent: [Dictionary new].
        status := p at: 'status' ifAbsent: [''].
        wfId := wf at: 'identity' ifAbsent: [''].
        wfScope := wf at: 'scope' ifAbsent: ['default'].
        shouldGc := allFlag or: [
          status = 'completed' or: [status = 'cancelled' or: [status = 'failed']]
        ].
        shouldGc ifTrue: [
          ('  ', wfId, ' [', status, ']') println.
          self gcWorkflowTuples: wfId cfg: cfg dryRun: dryRun.
          dryRun ifFalse: [
            self silentInp: 'workflow' cfg: cfg scope: wfScope identity: wfId
          ].
          count := count + 1
        ]
      ]
    ] on: Exception do: [:e |
      ('Error: ', e messageText) println
    ].
    ^count
  ]

  classMethod: gcWorkflowTuples: wfId cfg: cfg dryRun: dryRun [
    "Remove all token/task/event/signal tuples associated with workflow
     wfId. Same matching rules as SystemCommands>>gcWorkflowTuples:dryRun:."
    | categories removedCount |
    categories := #('token' 'task' 'event' 'signal').
    removedCount := 0.
    categories do: [:cat |
      | tuples |
      tuples := self safeScan: cat cfg: cfg scope: nil.
      tuples do: [:t |
        (self tuple: t matchesWorkflow: wfId) ifTrue: [
          | tScope tIdentity |
          tScope := t at: 'scope' ifAbsent: ['default'].
          tIdentity := t at: 'identity' ifAbsent: [''].
          ('    [', cat, '] ', tScope, '/', tIdentity) println.
          dryRun ifFalse: [
            self silentInp: cat cfg: cfg scope: tScope identity: tIdentity
          ].
          removedCount := removedCount + 1
        ]
      ]
    ].
    removedCount > 0 ifTrue: [
      ('    -> ', removedCount printString, ' associated tuple(s) ',
        (dryRun ifTrue: ['would be removed'] ifFalse: ['removed'])) println
    ].
    ^removedCount
  ]

  classMethod: tuple: t matchesWorkflow: wfId [
    "True if tuple t is associated with workflow wfId. Mirrors
     SystemCommands>>tuple:matchesWorkflow:."
    | payload identity tScope wfInst |
    wfId isEmpty ifTrue: [^false].
    payload := t at: 'payload' ifAbsent: [Dictionary new].
    identity := t at: 'identity' ifAbsent: [''].
    tScope := t at: 'scope' ifAbsent: [''].
    wfInst := payload at: 'workflow_instance' ifAbsent: [''].
    wfInst = wfId ifTrue: [^true].
    tScope = wfId ifTrue: [^true].
    identity = wfId ifTrue: [^true].
    (identity startsWith: (wfId, ':')) ifTrue: [^true].
    ^false
  ]

  classMethod: gcBranches: dryRun [
    "Delete local feature/* branches that are merged into main."
    | output lines |
    [
      output := Shell capture: 'git branch --merged main 2>/dev/null | grep feature/ | sed "s/^[* ]*//"'.
      output isEmpty ifFalse: [
        lines := output split: (Character lf asString).
        lines do: [:line |
          line isEmpty ifFalse: [
            ('  branch: ', line) println.
            dryRun ifFalse: [
              Shell run: 'git branch -D ', line, ' 2>/dev/null'
            ]
          ]
        ]
      ]
    ] on: Exception do: [:e | ]
  ]

  "--- Shared POST helper for signal-writer commands ---------------------"

  classMethod: postAndPrint: cfg path: path body: body [
    "POST a JSON body to the API, pretty-print the decoded response.
     Mutating route — every send is ed25519-signed by the local identity
     loaded via IdentityStore loadCurrent. Shared by the six
     signal-writer ports (observe, decide, event, notify, signal,
     dismiss) plus all workflow / workitem mutation sites."
    ^self renderResponse: (self signedPost: path body: body cfg: cfg) path: path
  ]

  classMethod: unauthedPostAndPrint: cfg path: path body: body [
    "POST a JSON body to a read-only endpoint (/api/rdp, /api/scan)
     and pretty-print the decoded response. No signature is attached."
    ^self renderResponse: (self unauthedPost: path body: body cfg: cfg) path: path
  ]

  classMethod: getAndPrint: cfg path: path [
    "GET a JSON endpoint and pretty-print the response."
    ^self renderResponse: (self unauthedGet: path cfg: cfg) path: path
  ]

  classMethod: signedPost: path body: body cfg: cfg [
    "Thin shim onto CLIBase>>signedPost:body:baseUrl: so the only
     HttpClient construction site in src/cli/ lives in CLIBase.mag.
     The active identity is loaded lazily via IdentityStore loadCurrent."
    ^CLIBase signedPost: path body: body baseUrl: cfg baseUrl
  ]

  classMethod: unauthedPost: path body: body cfg: cfg [
    "Thin shim onto CLIBase>>unauthedPost:body:baseUrl: — for read-only
     POST endpoints (/api/scan, /api/rdp, /api/health)."
    ^CLIBase unauthedPost: path body: body baseUrl: cfg baseUrl
  ]

  classMethod: unauthedGet: path cfg: cfg [
    "Thin shim onto CLIBase>>unauthedGet:baseUrl: — for read-only GETs."
    ^CLIBase unauthedGet: path baseUrl: cfg baseUrl
  ]

  classMethod: renderResponse: response path: path [
    "Decode and pretty-print a JSON response, surfacing 401 errors as
     operator-friendly text rather than a raw JSON dump."
    | result errMsg lower |
    response isNil ifTrue: [^self].
    (response isKindOf: String) ifFalse: [
      'Error: server returned non-String response' println. ^self
    ].
    response isEmpty ifTrue: [
      'Error: empty response from server' println. ^self
    ].
    result := nil.
    [result := Json decode: response] on: Exception do: [:e |
      ('Error decoding response: ', e messageText) println.
      response println.
      ^self
    ].
    (result isKindOf: Dictionary) ifTrue: [
      errMsg := result at: 'error' ifAbsent: [nil].
      errMsg notNil ifTrue: [
        lower := errMsg asLowercase.
        ('Request rejected: ', errMsg) println.
        (lower includesSubstring: 'signature') ifTrue: [
          'Hint: ensure your local identity is registered via `pp user add <name> --pubkey <hex>`' println.
          '      and not revoked. A stale system clock can also trip the skew window.' println.
          ^self
        ].
        (lower includesSubstring: 'admin') ifTrue: [
          'Hint: this endpoint is admin-only — sign with the hex pubkey listed in' println.
          '      ~/.config/pp/server.toml under [admin].admins.' println.
          ^self
        ].
        (lower includesSubstring: 'revoked') ifTrue: [
          'Hint: identity is revoked. Ask an admin to re-add or rotate.' println
        ].
        ^self
      ]
    ].
    (Json encodePretty: result) println
  ]

  "--- Subcommand: observe -----------------------------------------------"

  classMethod: runObserve: args [
    "Build, configure, and dispatch the new `observe` command.

     Exercises:
       * Cli::Command       — leaf command with required positional args
       * Cli::EnvBinding    — PP_URL, PP_SCOPE, PP_TASK projected onto
                              a PPCliConfig instance. PP_TASK becomes a
                              payload field when present.
       * Cli::Flag #string  — --tags is a comma-separated list. The Cli
                              framework doesn't have a list-type flag, so
                              we take the raw string and split inside
                              the run block.
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'observe' doc: 'Report an observation'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_TASK'
      setter: #taskId:
      type: #string
      default: '').

    cmd flag: (Cli::Flag
      name: 'tags'
      type: #string
      default: ''
      doc: 'Comma-separated tags (e.g. a,b,c)').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | identity detail tagsStr body tagArr exitCode |
      exitCode := 0.
      runArgs size < 2 ifTrue: [
        'Usage: pp observe <identity> <detail> [--tags t1,t2]' println.
        exitCode := 1
      ] ifFalse: [
        cmd applyEnvBindings: cfg.
        identity := runArgs at: 0.
        detail := runArgs at: 1.
        tagsStr := cmd flagValue: 'tags'.
        body := Dictionary new.
        body at: 'scope' put: cfg scope.
        body at: 'identity' put: identity.
        body at: 'detail' put: detail.
        cfg taskId isEmpty ifFalse: [body at: 'task' put: cfg taskId].
        (tagsStr notNil and: [tagsStr isEmpty not]) ifTrue: [
          tagArr := tagsStr split: ','.
          body at: 'tags' put: tagArr
        ].
        self postAndPrint: cfg path: '/api/observe' body: body
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: decide ------------------------------------------------"

  classMethod: runDecide: args [
    "Build, configure, and dispatch the new `decide` command.

     Exercises:
       * Cli::Command       — leaf command with required positional args
       * Cli::EnvBinding    — PP_URL / PP_SCOPE / PP_TASK
       * Cli::Flag #string  — --rationale is a free-text string flag
                              that only appears in the payload when set
                              (legacy behaviour — nil vs. empty matters).
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'decide' doc: 'Record a decision'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_TASK'
      setter: #taskId:
      type: #string
      default: '').

    cmd flag: (Cli::Flag
      name: 'rationale'
      type: #string
      default: ''
      doc: 'Rationale for the decision').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | identity detail rationale body exitCode |
      exitCode := 0.
      runArgs size < 2 ifTrue: [
        'Usage: pp decide <identity> <detail> [--rationale ...]' println.
        exitCode := 1
      ] ifFalse: [
        cmd applyEnvBindings: cfg.
        identity := runArgs at: 0.
        detail := runArgs at: 1.
        rationale := cmd flagValue: 'rationale'.
        body := Dictionary new.
        body at: 'scope' put: cfg scope.
        body at: 'identity' put: identity.
        body at: 'detail' put: detail.
        cfg taskId isEmpty ifFalse: [body at: 'task' put: cfg taskId].
        (rationale notNil and: [rationale isEmpty not]) ifTrue: [
          body at: 'rationale' put: rationale
        ].
        self postAndPrint: cfg path: '/api/decide' body: body
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: event -------------------------------------------------"

  classMethod: runEvent: args [
    "Build, configure, and dispatch the new `event` command.

     Exercises:
       * Cli::Command       — leaf command with required positional args
       * Cli::EnvBinding    — PP_URL / PP_SCOPE
       * Cli::Flag #string  — two string flags (--type with a default
                              value, --summary as optional).
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'event' doc: 'Emit an event'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').

    cmd flag: (Cli::Flag
      name: 'type'
      type: #string
      default: 'generic'
      doc: 'Event type (defaults to generic)').
    cmd flag: (Cli::Flag
      name: 'summary'
      type: #string
      default: ''
      doc: 'Optional event summary').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | identity eventType summary body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp event <identity> [--type T] [--summary S]' println.
        exitCode := 1
      ] ifFalse: [
        cmd applyEnvBindings: cfg.
        identity := runArgs at: 0.
        eventType := cmd flagValue: 'type'.
        summary := cmd flagValue: 'summary'.
        body := Dictionary new.
        body at: 'scope' put: cfg scope.
        body at: 'identity' put: identity.
        body at: 'type' put: ((eventType notNil and: [eventType isEmpty not])
          ifTrue: [eventType]
          ifFalse: ['generic']).
        (summary notNil and: [summary isEmpty not]) ifTrue: [
          body at: 'summary' put: summary
        ].
        self postAndPrint: cfg path: '/api/event' body: body
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: notify ------------------------------------------------"

  classMethod: runNotify: args [
    "Build, configure, and dispatch the new `notify` command.

     Exercises:
       * Cli::Command       — leaf command with one required positional
       * Cli::EnvBinding    — PP_URL / PP_SCOPE
       * Cli::Flag #string  — --severity is a constrained enum-ish flag.
                              The Cli framework has no enum type, so the
                              run block validates the value against the
                              allowed set {info, warn, urgent} and returns
                              exit code 1 if the user passes a bogus one.
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'notify' doc: 'Notify the user'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').

    cmd flag: (Cli::Flag
      name: 'severity'
      type: #string
      default: 'info'
      doc: 'Notification severity: one of info|warn|urgent (default info)').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | message severity body allowed exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp notify <message> [--severity info|warn|urgent]' println.
        exitCode := 1
      ] ifFalse: [
        cmd applyEnvBindings: cfg.
        message := runArgs at: 0.
        severity := cmd flagValue: 'severity'.
        (severity isNil or: [severity isEmpty]) ifTrue: [severity := 'info'].
        allowed := #('info' 'warn' 'urgent').
        (allowed includes: severity) ifTrue: [
          body := Dictionary new.
          body at: 'message' put: message.
          body at: 'scope' put: cfg scope.
          body at: 'severity' put: severity.
          self postAndPrint: cfg path: '/api/notify' body: body
        ] ifFalse: [
          ('Error: --severity must be one of info|warn|urgent (got: ',
            severity, ')') println.
          exitCode := 1
        ]
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: signal ------------------------------------------------"

  classMethod: runSignal: args [
    "Build, configure, and dispatch the new `signal` command.

     Exercises:
       * Cli::Command       — leaf command that takes THREE required
                              positional args (id, key, value). The Cli
                              framework wrapper doesn't expose cobra's
                              MinimumNArgs directly, so the run block
                              validates the count and returns exit code 1
                              with a usage message when short.
       * Cli::EnvBinding    — PP_URL / PP_SCOPE
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'signal' doc: 'Upsert a signal tuple'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | identity key value payload body exitCode |
      exitCode := 0.
      runArgs size < 3 ifTrue: [
        'Usage: pp signal <id> <key> <value>' println.
        exitCode := 1
      ] ifFalse: [
        cmd applyEnvBindings: cfg.
        identity := runArgs at: 0.
        key := runArgs at: 1.
        value := runArgs at: 2.
        payload := Dictionary new.
        payload at: key put: value.
        body := Dictionary new.
        body at: 'scope' put: cfg scope.
        body at: 'identity' put: identity.
        body at: 'payload' put: payload.
        self postAndPrint: cfg path: '/api/signal' body: body
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: dismiss -----------------------------------------------"

  classMethod: runDismiss: args [
    "Build, configure, and dispatch the new `dismiss` command.

     Exercises:
       * Cli::Command       — zero-arg leaf command (no flags, no
                              positional args)
       * Cli::EnvBinding    — PP_URL / PP_SCOPE / PP_TASK. PP_TASK is
                              the sole input: dismiss exits 1 if it's
                              unset, otherwise it POSTs the task-complete
                              event. This exercises env-binding as the
                              primary way to receive input.
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'dismiss' doc: 'Signal task completion'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_TASK'
      setter: #taskId:
      type: #string
      default: '').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | body exitCode |
      exitCode := 0.
      cmd applyEnvBindings: cfg.
      cfg taskId isEmpty ifTrue: [
        'No task ID set (PP_TASK env var). Cannot dismiss.' println.
        exitCode := 1
      ] ifFalse: [
        body := Dictionary new.
        body at: 'task_id' put: cfg taskId.
        body at: 'scope' put: cfg scope.
        self postAndPrint: cfg path: '/api/dismiss' body: body
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: verdict -----------------------------------------------"

  classMethod: runVerdict: args [
    "Build, configure, and dispatch the `verdict` shorthand command.

     Shorthand for: pp signal verdict:<workflow-instance> decision <pass|fix|exhausted>.
     Agents receive PP_WORKFLOW from the harness; humans can supply
     --workflow <id>. When neither is available, the command lists
     running workflows so the caller can pick one explicitly."
    | cmd cfg rest |
    cmd := Cli::Command named: 'verdict'
           doc: 'Write a review verdict (pass|fix|exhausted) for the current workflow'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_WORKFLOW'
      setter: #workflowInstance:
      type: #string
      default: '').
    cmd flag: (Cli::Flag
      name: 'workflow'
      type: #string
      default: ''
      doc: 'Workflow instance ID (overrides PP_WORKFLOW)').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | decision wfFlag wfId payload body exitCode workflows |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp verdict <pass|fix|exhausted> [--workflow <id>]' println.
        exitCode := 1
      ] ifFalse: [
        decision := runArgs at: 0.
        (decision = 'pass' or: [decision = 'fix' or: [decision = 'exhausted']]) ifFalse: [
          ('Invalid decision: ', decision, ' (expected pass|fix|exhausted)') println.
          exitCode := 1
        ] ifTrue: [
          cmd applyEnvBindings: cfg.
          wfFlag := cmd flagValue: 'workflow'.
          (wfFlag notNil and: [wfFlag isEmpty not])
            ifTrue: [wfId := wfFlag]
            ifFalse: [
              cfg workflowInstance isEmpty
                ifTrue: [wfId := nil]
                ifFalse: [wfId := cfg workflowInstance]
            ].
          wfId isNil ifTrue: [
            'Error: no workflow instance ID.' println.
            'Set PP_WORKFLOW env var (agents get this from the harness) or pass --workflow <id>.' println.
            workflows := self safeScanWorkflows: cfg scope: nil.
            workflows size > 0 ifTrue: [
              '' println.
              'Running workflows:' println.
              workflows do: [:wf |
                | wfp wfStatus wfIdent wfTmpl |
                wfp := wf at: 'payload' ifAbsent: [Dictionary new].
                wfStatus := wfp at: 'status' ifAbsent: ['?'].
                wfIdent := wf at: 'identity' ifAbsent: ['?'].
                wfTmpl := wfp at: 'template' ifAbsent: ['?'].
                wfStatus = 'running' ifTrue: [
                  ('  ', wfIdent, '  [', wfTmpl, ']') println
                ]
              ]
            ].
            exitCode := 1
          ] ifFalse: [
            payload := Dictionary new.
            payload at: 'decision' put: decision.
            body := Dictionary new.
            body at: 'scope' put: cfg scope.
            body at: 'identity' put: 'verdict:', wfId.
            body at: 'payload' put: payload.
            self postAndPrint: cfg path: '/api/signal' body: body
          ]
        ]
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Workflow helpers ----------------------------------------------------"

  classMethod: performWorkflowStatusList: cfg scope: scopeFilter [
    "List every workflow (optionally filtered by scope) using the
     Cli::Output table formatter. Exercises the table:headers:keys:
     path now that string-quoting is fixed."
    | workflows rows |
    workflows := self safeScanWorkflows: cfg scope: scopeFilter.
    workflows size = 0 ifTrue: [
      'No workflows.' println.
      ^self
    ].
    rows := Array new: 0.
    workflows do: [:wf |
      | row wfId payload template wfStatus wfScope params description truncDesc |
      wfId := wf at: 'identity' ifAbsent: ['?'].
      payload := wf at: 'payload' ifAbsent: [Dictionary new].
      template := payload at: 'template' ifAbsent: ['?'].
      wfStatus := payload at: 'status' ifAbsent: ['?'].
      wfScope := wf at: 'scope' ifAbsent: ['?'].
      params := payload at: 'params' ifAbsent: [nil].
      description := params notNil
        ifTrue: [params at: 'description' ifAbsent: ['']]
        ifFalse: [''].
      truncDesc := description size > 60
        ifTrue: [(description copyFrom: 0 to: 57), '...']
        ifFalse: [description].
      row := Dictionary new.
      row at: 'id' put: wfId.
      row at: 'status' put: wfStatus.
      row at: 'template' put: template.
      row at: 'scope' put: wfScope.
      row at: 'description' put: truncDesc.
      rows := rows copyWith: row
    ].
    Cli::Output
      table: rows
      headers: #('ID' 'STATUS' 'TEMPLATE' 'SCOPE' 'DESCRIPTION')
      keys: #('id' 'status' 'template' 'scope' 'description')
  ]

  classMethod: performWorkflowStatusDetail: cfg id: wfId scope: scopeFilter [
    "Show detail for one workflow. If scopeFilter is empty/nil, search
     every scope for the id; otherwise look under the given scope
     directly. Mirrors the legacy `workflow status <id>` shape line-by-line."
    | wfScope wf wfPayload tokens tasks activeTasks doneTasks cycleSignal |
    wfScope := (scopeFilter notNil and: [scopeFilter isEmpty not])
      ifTrue: [scopeFilter]
      ifFalse: [
        | found |
        found := self findWorkflowScope: cfg id: wfId.
        found isNil ifTrue: [cfg scope] ifFalse: [found]
      ].
    wf := self safeRdp: cfg category: 'workflow' scope: wfScope identity: wfId.
    wf isNil ifTrue: [
      ('Workflow not found: ', wfId) println.
      ^self
    ].
    wfPayload := wf at: 'payload' ifAbsent: [Dictionary new].
    ('Workflow: ', wfId) println.
    ('  Template: ', (wfPayload at: 'template' ifAbsent: ['?'])) println.
    ('  Status:   ', (wfPayload at: 'status' ifAbsent: ['?'])) println.
    (wfPayload includesKey: 'params') ifTrue: [
      | params repo desc |
      params := wfPayload at: 'params'.
      repo := params at: 'repo' ifAbsent: [nil].
      repo notNil ifTrue: [('  Repo:     ', repo) println].
      desc := params at: 'description' ifAbsent: [nil].
      (desc notNil and: [desc isEmpty not]) ifTrue: [
        ('  Desc:     ', desc) println
      ]
    ].
    '' println.

    '  Tokens:' println.
    tokens := (self safeScan: 'token' cfg: cfg scope: wfScope)
      select: [:t |
        | tp |
        tp := t at: 'payload' ifAbsent: [Dictionary new].
        (tp at: 'workflow_instance' ifAbsent: ['']) = wfId
      ].
    tokens size = 0
      ifTrue: ['    (none)' println]
      ifFalse: [
        tokens do: [:t |
          | tp place tStatus color |
          tp := t at: 'payload' ifAbsent: [Dictionary new].
          place := tp at: 'place' ifAbsent: ['?'].
          tStatus := tp at: 'status' ifAbsent: ['?'].
          color := tp at: 'color' ifAbsent: [nil].
          color notNil
            ifTrue: [('    ', place, ' [', tStatus, '] color:', color) println]
            ifFalse: [('    ', place, ' [', tStatus, ']') println]
        ]
      ].
    '' println.

    '  Tasks:' println.
    tasks := (self safeScan: 'task' cfg: cfg scope: wfScope)
      select: [:t |
        | tp |
        tp := t at: 'payload' ifAbsent: [Dictionary new].
        (tp at: 'workflow_instance' ifAbsent: ['']) = wfId
      ].
    tasks size = 0
      ifTrue: ['    (none)' println]
      ifFalse: [
        activeTasks := tasks select: [:t |
          | tp ts |
          tp := t at: 'payload' ifAbsent: [Dictionary new].
          ts := tp at: 'status' ifAbsent: [''].
          (ts = 'active') or: [ts = 'pending']
        ].
        activeTasks size > 0 ifTrue: [
          ('    Active/Pending: ', activeTasks size printString) println.
          activeTasks do: [:t |
            | tp role tStatus transId taskId |
            tp := t at: 'payload' ifAbsent: [Dictionary new].
            role := tp at: 'role' ifAbsent: ['?'].
            tStatus := tp at: 'status' ifAbsent: ['?'].
            transId := tp at: 'transition_id' ifAbsent: ['?'].
            taskId := t at: 'identity' ifAbsent: ['?'].
            ('      ', role, ' [', tStatus, '] ', transId, ' id:', taskId) println
          ]
        ].
        doneTasks := tasks select: [:t |
          | tp ts |
          tp := t at: 'payload' ifAbsent: [Dictionary new].
          ts := tp at: 'status' ifAbsent: [''].
          (ts = 'dismissed') or: [(ts = 'completed') or: [ts = 'failed']]
        ].
        doneTasks size > 0 ifTrue: [
          ('    Done/Failed: ', doneTasks size printString) println
        ]
      ].
    '' println.

    cycleSignal := self safeRdp: cfg category: 'signal' scope: wfScope identity: 'review_cycle:', wfId.
    cycleSignal notNil ifTrue: [
      | cp |
      cp := cycleSignal at: 'payload' ifAbsent: [Dictionary new].
      ('  Review cycle: ', (cp at: 'count' ifAbsent: ['?']) printString) println
    ]
  ]

  classMethod: findWorkflowScope: cfg id: wfId [
    "Scan every scope for a workflow with this id; return its scope or nil."
    | all found |
    all := self safeScanWorkflows: cfg scope: nil.
    found := all detect: [:wf |
      (wf at: 'identity' ifAbsent: ['']) = wfId
    ] ifNone: [nil].
    found isNil ifTrue: [^nil].
    ^found at: 'scope' ifAbsent: [nil]
  ]

  classMethod: safeRdp: cfg category: category scope: aScope identity: anIdentity [
    "Class-side analog of CLIBase>>safeRdp:scope:identity: — returns the
     tuple dictionary or nil. /api/rdp is read-only and unsigned."
    | body response result |
    body := Dictionary new.
    body at: 'category' put: category.
    body at: 'scope' put: aScope.
    body at: 'identity' put: anIdentity.
    response := self unauthedPost: '/api/rdp' body: body cfg: cfg.
    (response isNil or: [(response isKindOf: String) not or: [response isEmpty]]) ifTrue: [^nil].
    [
      result := Json decode: response.
      ^result at: 'tuple' ifAbsent: [nil]
    ] on: Exception do: [:e | ^nil]
  ]

  classMethod: performWorkflowWait: cfg id: wfId scope: wfScope timeout: maxWait [
    "Poll /api/workflow/status every 10 seconds until the workflow hits
     a terminal state (completed/failed/cancelled), or maxWait elapses.
     Prints the final JSON response on success, or a timeout message."
    | body response result status elapsed curlCmd |
    body := Dictionary new.
    body at: 'workflow_id' put: wfId.
    body at: 'scope' put: wfScope.

    elapsed := 0.
    [elapsed < maxWait] whileTrue: [
      [
        "Use curl to avoid HttpClient blocking-on-POST issues that
         the legacy implementation documents with this same workaround."
        curlCmd := 'curl -s -X POST ', cfg baseUrl,
          '/api/workflow/status -H "Content-Type: application/json" -d ''',
          (Json encode: body), ''''.
        response := Shell capture: curlCmd.
        (response notNil and: [response isEmpty not]) ifTrue: [
          result := Json decode: response.
          status := result at: 'status' ifAbsent: ['unknown'].
          (status = 'completed' or: [status = 'failed' or: [status = 'cancelled']]) ifTrue: [
            (Json encodePretty: result) println.
            ^self
          ]
        ]
      ] on: Exception do: [:e |
        ('Error checking workflow status: ', e messageText) println
      ].
      Process sleep: 10000.
      elapsed := elapsed + 10
    ].
    ('Timeout: workflow ', wfId, ' did not complete within ', maxWait printString, ' seconds') println
  ]

  "--- Subcommand: read ----------------------------------------------------"

  classMethod: runRead: args [
    "Build, configure, and dispatch the new `read` command.

     Exercises:
       * Cli::Command       — leaf command with variable-arity positionals.
                              The Cli framework wrapper doesn't expose
                              cobra's `MinimumNArgs` directly, so the run
                              block inspects the runArgs size and branches.
                              Three arities are supported:
                                pp read <category>
                                pp read <category> <scope>
                                pp read <category> <scope> <identity>
       * Cli::EnvBinding    — PP_URL / PP_SCOPE
       * JSON output        — matches the legacy pretty-printed shape.
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'read' doc: 'Read tuples from the tuplespace'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | category rdScope rdIdentity body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp read <category> [scope] [identity]' println.
        exitCode := 1
      ] ifFalse: [
        cmd applyEnvBindings: cfg.
        category := runArgs at: 0.
        rdScope := runArgs size > 1 ifTrue: [runArgs at: 1] ifFalse: [cfg scope].
        rdIdentity := runArgs size > 2 ifTrue: [runArgs at: 2] ifFalse: [nil].
        rdIdentity notNil ifTrue: [
          body := Dictionary new.
          body at: 'category' put: category.
          body at: 'scope' put: rdScope.
          body at: 'identity' put: rdIdentity.
          self unauthedPostAndPrint: cfg path: '/api/rdp' body: body
        ] ifFalse: [
          body := Dictionary new.
          body at: 'category' put: category.
          body at: 'scope' put: rdScope.
          self unauthedPostAndPrint: cfg path: '/api/scan' body: body
        ]
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: history -------------------------------------------------"

  classMethod: runHistory: args [
    "Build, configure, and dispatch the new `history` command.

     Exercises:
       * Cli::Command       — leaf command with five string filter flags
                              and one integer flag.
       * Cli::Flag #int     — `--limit` demonstrates the string-to-int
                              flag path (addIntFlag primitive).
       * Cli::EnvBinding    — PP_URL.
       * Cli::Output        — `table:headers:keys:` renders the audit log
                              with TIME / OP / CATEGORY / SCOPE / IDENTITY
                              columns.
     "
    | cmd cfg rest |
    cmd := Cli::Command named: 'history' doc: 'Query the audit log'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').

    cmd flag: (Cli::Flag
      name: 'since'
      type: #string
      default: ''
      doc: 'Filter entries since this ISO timestamp').
    cmd flag: (Cli::Flag
      name: 'limit'
      type: #int
      default: 50
      doc: 'Maximum number of entries to return (default 50)').
    cmd flag: (Cli::Flag
      name: 'op'
      type: #string
      default: ''
      doc: 'Filter by operation (out, inp, rdp, etc.)').
    cmd flag: (Cli::Flag
      name: 'category'
      type: #string
      default: ''
      doc: 'Filter by tuple category').
    cmd flag: (Cli::Flag
      name: 'scope'
      type: #string
      default: ''
      doc: 'Filter by scope').
    cmd flag: (Cli::Flag
      name: 'identity'
      type: #string
      default: ''
      doc: 'Filter by tuple identity').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | sinceStr limit op category histScope identity url |
      cmd applyEnvBindings: cfg.
      sinceStr := cmd flagValue: 'since'.
      limit := cmd flagValue: 'limit'.
      op := cmd flagValue: 'op'.
      category := cmd flagValue: 'category'.
      histScope := cmd flagValue: 'scope'.
      identity := cmd flagValue: 'identity'.
      (limit isNil or: [limit <= 0]) ifTrue: [limit := 50].
      url := '/api/history?limit=', limit printString.
      (sinceStr notNil and: [sinceStr isEmpty not]) ifTrue: [url := url, '&since=', sinceStr].
      (op notNil and: [op isEmpty not]) ifTrue: [url := url, '&op=', op].
      (category notNil and: [category isEmpty not]) ifTrue: [url := url, '&category=', category].
      (histScope notNil and: [histScope isEmpty not]) ifTrue: [url := url, '&scope=', histScope].
      (identity notNil and: [identity isEmpty not]) ifTrue: [url := url, '&identity=', identity].
      self performHistory: cfg url: url.
      0
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: performHistory: cfg url: urlPath [
    "GET the audit log, then render it via Cli::Output table:headers:keys:
     — that replaces the legacy single-line-per-entry println."
    | response result entries rows |
    response := self unauthedGet: urlPath cfg: cfg.
    [
      response isNil ifTrue: [^self].
      (response isKindOf: String) ifFalse: [
        'Error: server returned non-String response' println.
        ^self
      ].
      response isEmpty ifTrue: [
        'Error: empty response from server' println.
        ^self
      ].
      result := Json decode: response.
      entries := result at: 'entries' ifAbsent: [#()].
      entries size = 0 ifTrue: [
        'No history entries.' println.
        ^self
      ].
      rows := Array new: 0.
      entries do: [:e |
        | row |
        row := Dictionary new.
        row at: 'ts' put: (e at: 'ts' ifAbsent: ['?']) printString.
        row at: 'op' put: (e at: 'op' ifAbsent: ['?']).
        row at: 'category' put: (e at: 'category' ifAbsent: ['']).
        row at: 'scope' put: (e at: 'scope' ifAbsent: ['']).
        row at: 'identity' put: (e at: 'identity' ifAbsent: ['']).
        rows := rows copyWith: row
      ].
      Cli::Output
        table: rows
        headers: #('TIME' 'OP' 'CATEGORY' 'SCOPE' 'IDENTITY')
        keys: #('ts' 'op' 'category' 'scope' 'identity')
    ] on: Exception do: [:e |
      ('Error: ', e messageText) println
    ]
  ]

  "--- Subcommand: workitem (parent + children) ----------------------------"

  classMethod: runWorkitem: args [
    "Dispatch `pp workitem <subcmd> ...` through a subcommand tree.
     All 12 subcommands are leaf commands registered on a parent
     `workitem` command. Each takes a common --repo flag which
     overrides the effective scope."
    | cfg root create show list children update comment ready done block runC plan review rewave rest |
    cfg := self loadConfig.

    root := Cli::Command named: 'workitem' doc: 'Manage work items (epics, stories)'.

    create := self buildWorkitemCreate: cfg.
    show := self buildWorkitemShow: cfg.
    list := self buildWorkitemList: cfg.
    children := self buildWorkitemChildren: cfg.
    update := self buildWorkitemUpdate: cfg.
    comment := self buildWorkitemComment: cfg.
    ready := self buildWorkitemSetStatus: cfg name: 'ready' doc: 'Mark a work item ready (cascades)' status: 'ready'.
    done := self buildWorkitemSetStatus: cfg name: 'done' doc: 'Mark a work item done (cascades)' status: 'done'.
    block := self buildWorkitemBlock: cfg.
    runC := self buildWorkitemRun: cfg.
    plan := self buildWorkitemPlan: cfg.
    review := self buildWorkitemReview: cfg.
    rewave := self buildWorkitemRewave: cfg.

    root registerSubcommand: create.
    root registerSubcommand: show.
    root registerSubcommand: list.
    root registerSubcommand: children.
    root registerSubcommand: update.
    root registerSubcommand: comment.
    root registerSubcommand: ready.
    root registerSubcommand: done.
    root registerSubcommand: block.
    root registerSubcommand: runC.
    root registerSubcommand: plan.
    root registerSubcommand: review.
    root registerSubcommand: rewave.

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    root setArgs: rest.
    ^[root execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Scope resolution helper ---------------------------------------------"

  classMethod: workitemScope: cfg repoFlag: repoFlag [
    "If --repo is set, use it as scope; otherwise fall back to cfg.scope."
    (repoFlag notNil and: [repoFlag isEmpty not]) ifTrue: [^repoFlag].
    ^cfg scope
  ]

  "--- Subcommand builders -------------------------------------------------"

  classMethod: buildWorkitemCreate: cfg [
    | cmd |
    cmd := Cli::Command named: 'create' doc: 'Create a work item'.
    cmd flag: (Cli::Flag name: 'title' type: #string default: '' doc: 'Title of the work item').
    cmd flag: (Cli::Flag name: 'type' type: #string default: 'story' doc: 'Type: epic | story').
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd flag: (Cli::Flag name: 'status' type: #string default: 'backlog' doc: 'Initial status').
    cmd flag: (Cli::Flag name: 'parent' type: #string default: '' doc: 'Parent work item identity').
    cmd flag: (Cli::Flag name: 'description' type: #string default: '' doc: 'Description text').
    cmd flag: (Cli::Flag name: 'template' type: #string default: 'story' doc: 'Workflow template name').
    cmd flag: (Cli::Flag name: 'batch' type: #string default: '' doc: 'Batch identifier').
    cmd flag: (Cli::Flag name: 'wave' type: #int default: 1 doc: 'Execution wave number').
    cmd flag: (Cli::Flag name: 'depends-on' type: #string default: '' doc: 'Comma-separated dependency ids').
    cmd flag: (Cli::Flag name: 'label' type: #string default: '' doc: 'Comma-separated labels').

    cmd run: [:runArgs |
      | identity title type repoArg status parent description template batch wave dependsOn labels theScope payload body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workitem create <identity> --title T --type epic|story [flags]' println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        title := cmd flagValue: 'title'.
        type := cmd flagValue: 'type'.
        repoArg := cmd flagValue: 'repo'.
        status := cmd flagValue: 'status'.
        parent := cmd flagValue: 'parent'.
        description := cmd flagValue: 'description'.
        template := cmd flagValue: 'template'.
        batch := cmd flagValue: 'batch'.
        wave := cmd flagValue: 'wave'.
        dependsOn := cmd flagValue: 'depends-on'.
        labels := cmd flagValue: 'label'.

        (title isNil or: [title isEmpty]) ifTrue: [title := identity].
        (type isNil or: [type isEmpty]) ifTrue: [type := 'story'].
        (status isNil or: [status isEmpty]) ifTrue: [status := 'backlog'].
        (description isNil) ifTrue: [description := ''].
        (template isNil or: [template isEmpty]) ifTrue: [template := 'story'].
        (wave isNil or: [wave <= 0]) ifTrue: [wave := 1].

        theScope := self workitemScope: cfg repoFlag: repoArg.

        payload := Dictionary new.
        payload at: 'title' put: title.
        payload at: 'description' put: description.
        payload at: 'status' put: status.
        payload at: 'type' put: type.
        (parent notNil and: [parent isEmpty not])
          ifTrue: [payload at: 'parent' put: parent]
          ifFalse: [payload at: 'parent' put: nil].
        (repoArg notNil and: [repoArg isEmpty not]) ifTrue: [
          payload at: 'repo' put: repoArg
        ].
        payload at: 'template' put: template.
        (batch notNil and: [batch isEmpty not]) ifTrue: [
          payload at: 'batch' put: batch
        ].
        payload at: 'wave' put: wave.
        (dependsOn notNil and: [dependsOn isEmpty not])
          ifTrue: [payload at: 'depends_on' put: (dependsOn split: ',')]
          ifFalse: [payload at: 'depends_on' put: (Array new: 0)].
        (labels notNil and: [labels isEmpty not])
          ifTrue: [payload at: 'labels' put: (labels split: ',')]
          ifFalse: [payload at: 'labels' put: (Array new: 0)].
        payload at: 'comments' put: (Array new: 0).
        payload at: 'created_by' put: 'human'.
        payload at: 'created_at' put: DateTime now epochSeconds.
        payload at: 'updated_at' put: DateTime now epochSeconds.

        body := Dictionary new.
        body at: 'category' put: 'workitem'.
        body at: 'scope' put: theScope.
        body at: 'identity' put: identity.
        body at: 'payload' put: payload.
        body at: 'pinned' put: true.

        "Single POST — child.parent is the sole source of truth for the
         parent/child relationship. No add-child follow-up is needed."
        self postAndPrint: cfg path: '/api/workitem/create' body: body
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemShow: cfg [
    | cmd |
    cmd := Cli::Command named: 'show' doc: 'Show work item detail'.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd run: [:runArgs |
      | identity repoArg theScope exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workitem show <identity> [--repo R]' println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.
        self performWorkitemShow: cfg scope: theScope identity: identity
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemList: cfg [
    | cmd |
    cmd := Cli::Command named: 'list' doc: 'List work items'.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd flag: (Cli::Flag name: 'status' type: #string default: '' doc: 'Filter by status').
    cmd flag: (Cli::Flag name: 'type' type: #string default: '' doc: 'Filter by type').
    cmd flag: (Cli::Flag name: 'parent' type: #string default: '' doc: 'Filter by parent').
    cmd flag: (Cli::Flag name: 'label' type: #string default: '' doc: 'Filter by label').
    cmd run: [:runArgs |
      | repoArg theScope |
      repoArg := cmd flagValue: 'repo'.
      theScope := self workitemScope: cfg repoFlag: repoArg.
      self performWorkitemList: cfg
           scope: theScope
           status: (cmd flagValue: 'status')
           type: (cmd flagValue: 'type')
           parent: (cmd flagValue: 'parent')
           label: (cmd flagValue: 'label').
      0
    ].
    ^cmd
  ]

  classMethod: buildWorkitemChildren: cfg [
    | cmd |
    cmd := Cli::Command named: 'children' doc: 'List children of a work item'.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd run: [:runArgs |
      | identity repoArg theScope exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workitem children <identity> [--repo R]' println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.
        self performWorkitemList: cfg
             scope: theScope
             status: ''
             type: ''
             parent: identity
             label: ''
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemUpdate: cfg [
    | cmd |
    cmd := Cli::Command named: 'update' doc: 'Update fields on a work item'.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd flag: (Cli::Flag name: 'status' type: #string default: '' doc: 'New status').
    cmd flag: (Cli::Flag name: 'title' type: #string default: '' doc: 'New title').
    cmd flag: (Cli::Flag name: 'description' type: #string default: '' doc: 'New description').
    cmd flag: (Cli::Flag name: 'wave' type: #int default: 0 doc: 'New wave number (>0)').
    cmd flag: (Cli::Flag name: 'depends-on' type: #string default: '' doc: 'Comma-separated dependencies').
    cmd flag: (Cli::Flag name: 'template' type: #string default: '' doc: 'New template').
    cmd run: [:runArgs |
      | identity repoArg theScope fields status title description wave dependsOn template exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workitem update <identity> [flags]' println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.

        fields := Dictionary new.
        status := cmd flagValue: 'status'.
        (status notNil and: [status isEmpty not]) ifTrue: [fields at: 'status' put: status].
        title := cmd flagValue: 'title'.
        (title notNil and: [title isEmpty not]) ifTrue: [fields at: 'title' put: title].
        description := cmd flagValue: 'description'.
        (description notNil and: [description isEmpty not]) ifTrue: [fields at: 'description' put: description].
        wave := cmd flagValue: 'wave'.
        (wave notNil and: [wave > 0]) ifTrue: [fields at: 'wave' put: wave].
        dependsOn := cmd flagValue: 'depends-on'.
        (dependsOn notNil and: [dependsOn isEmpty not]) ifTrue: [
          fields at: 'depends_on' put: (dependsOn split: ',')
        ].
        template := cmd flagValue: 'template'.
        (template notNil and: [template isEmpty not]) ifTrue: [fields at: 'template' put: template].
        fields at: 'updated_at' put: DateTime now epochSeconds.

        self performWorkitemUpdate: cfg
             scope: theScope
             identity: identity
             fields: fields
             cascade: false
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemComment: cfg [
    | cmd |
    cmd := Cli::Command named: 'comment' doc: 'Add a comment to a work item'.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd run: [:runArgs |
      | identity text repoArg theScope body exitCode |
      exitCode := 0.
      runArgs size < 2 ifTrue: [
        'Usage: pp workitem comment <identity> "text" [--repo R]' println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        text := runArgs at: 1.
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.
        body := Dictionary new.
        body at: 'identity' put: identity.
        body at: 'scope' put: theScope.
        body at: 'author' put: 'human'.
        body at: 'text' put: text.
        self postAndPrint: cfg path: '/api/workitem/comment' body: body
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemSetStatus: cfg name: cmdName doc: docStr status: newStatus [
    "Thin wrapper over update: build a fields dict with just status +
     updated_at, then POST via the cascading update helper. Used for
     ready / done."
    | cmd |
    cmd := Cli::Command named: cmdName doc: docStr.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd run: [:runArgs |
      | identity repoArg theScope fields exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        ('Usage: pp workitem ', cmdName, ' <identity> [--repo R]') println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.
        fields := Dictionary new.
        fields at: 'status' put: newStatus.
        fields at: 'updated_at' put: DateTime now epochSeconds.
        self performWorkitemUpdate: cfg
             scope: theScope
             identity: identity
             fields: fields
             cascade: true
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemBlock: cfg [
    | cmd |
    cmd := Cli::Command named: 'block' doc: 'Mark a work item blocked'.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd flag: (Cli::Flag name: 'reason' type: #string default: '' doc: 'Block reason (required)').
    cmd run: [:runArgs |
      | identity reason repoArg theScope fields exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workitem block <identity> --reason "..." [--repo R]' println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        reason := cmd flagValue: 'reason'.
        reason isNil ifTrue: [reason := ''].
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.
        fields := Dictionary new.
        fields at: 'status' put: 'blocked'.
        fields at: 'block_reason' put: reason.
        fields at: 'updated_at' put: DateTime now epochSeconds.
        self performWorkitemUpdate: cfg
             scope: theScope
             identity: identity
             fields: fields
             cascade: false
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemRun: cfg [
    | cmd |
    cmd := Cli::Command named: 'run' doc: 'Run the work items workflow for this item'.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd run: [:runArgs |
      | identity repoArg theScope body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workitem run <identity> [--repo R]' println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.
        body := Dictionary new.
        body at: 'identity' put: identity.
        body at: 'scope' put: theScope.
        self postAndPrint: cfg path: '/api/workitem/run' body: body
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemPlan: cfg [
    ^self buildWorkitemWorkflow: cfg
                            name: 'plan'
                             doc: 'Start workitem-plan workflow'
                        template: 'workitem-plan'
  ]

  classMethod: buildWorkitemReview: cfg [
    ^self buildWorkitemWorkflow: cfg
                            name: 'review'
                             doc: 'Start workitem-review workflow'
                        template: 'workitem-review'
  ]

  classMethod: buildWorkitemWorkflow: cfg name: cmdName doc: docStr template: templateId [
    "Shared builder for `pp workitem plan` and `pp workitem review`.
     Both start a workflow with {workitem: <id>} params."
    | cmd |
    cmd := Cli::Command named: cmdName doc: docStr.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd run: [:runArgs |
      | identity repoArg theScope wfParams body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        ('Usage: pp workitem ', cmdName, ' <identity> [--repo R]') println.
        exitCode := 1
      ] ifFalse: [
        identity := runArgs at: 0.
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.
        wfParams := Dictionary new.
        wfParams at: 'workitem' put: identity.
        body := Dictionary new.
        body at: 'template' put: templateId.
        body at: 'scope' put: theScope.
        body at: 'params' put: wfParams.
        self postAndPrint: cfg path: '/api/workflow/start' body: body
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: buildWorkitemRewave: cfg [
    "pp workitem rewave <epic-id> [mapping] [--file path]
     Bulk-update the wave number on stories under an epic. The mapping can
     be supplied inline as 'story1=2,story2=3' or via --file pointing to a
     JSON/YAML/CUE file. File format is a top-level map of story-id to
     integer wave number."
    | cmd |
    cmd := Cli::Command named: 'rewave' doc: 'Bulk-update wave numbers for stories under an epic'.
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (becomes scope)').
    cmd flag: (Cli::Flag name: 'file' type: #string default: '' doc: 'Path to YAML/JSON/CUE mapping file').
    cmd flag: (Cli::Flag name: 'dry-run' type: #bool default: false doc: 'Print actions without updating').
    cmd run: [:runArgs |
      | epicId repoArg theScope fileArg inlineArg dryRun mapping exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp workitem rewave <epic-id> [story1=2,story2=3] [--file path] [--repo R] [--dry-run]' println.
        exitCode := 1
      ] ifFalse: [
        epicId := runArgs at: 0.
        repoArg := cmd flagValue: 'repo'.
        theScope := self workitemScope: cfg repoFlag: repoArg.
        fileArg := cmd flagValue: 'file'.
        dryRun := cmd flagValue: 'dry-run'.
        inlineArg := runArgs size > 1 ifTrue: [runArgs at: 1] ifFalse: [nil].

        mapping := nil.
        (fileArg notNil and: [fileArg isEmpty not]) ifTrue: [
          mapping := self loadRewaveMappingFile: fileArg
        ] ifFalse: [
          (inlineArg notNil and: [inlineArg isEmpty not]) ifTrue: [
            mapping := self parseRewaveInline: inlineArg
          ]
        ].

        mapping isNil ifTrue: [
          'Error: supply a mapping, either inline (id1=2,id2=3) or via --file.' println.
          exitCode := 1
        ] ifFalse: [
          mapping isEmpty ifTrue: [
            'No mappings parsed; nothing to do.' println
          ] ifFalse: [
            exitCode := self performWorkitemRewave: cfg
                              scope: theScope
                              epic: epicId
                              mapping: mapping
                              dryRun: (dryRun = true)
          ]
        ]
      ].
      exitCode
    ].
    ^cmd
  ]

  classMethod: parseRewaveInline: aString [
    "Parse 'id1=2,id2=3' into a Dictionary {id1 -> 2, id2 -> 3}.
     Skips malformed entries with a warning."
    | result pairs |
    result := Dictionary new.
    pairs := aString split: ','.
    pairs do: [:pair |
      | parts key waveStr waveNum |
      (pair isEmpty or: [pair size = 0]) ifFalse: [
        parts := pair split: '='.
        parts size = 2 ifTrue: [
          key := parts at: 0.
          waveStr := parts at: 1.
          waveNum := waveStr asInteger.
          (key isEmpty not and: [waveNum > 0]) ifTrue: [
            result at: key put: waveNum
          ] ifFalse: [
            ('Skipping malformed entry: ', pair) println
          ]
        ] ifFalse: [
          ('Skipping malformed entry (expected id=N): ', pair) println
        ]
      ]
    ].
    ^result
  ]

  classMethod: loadRewaveMappingFile: path [
    "Load a YAML/JSON/CUE mapping file of {story-id: wave-number}.
     Returns a Dictionary or nil on failure. Uses `cue export` for yaml/cue
     as elsewhere in the codebase."
    | lower ext contents jsonText raw result |
    (File exists: path) ifFalse: [
      ('File not found: ', path) println. ^nil
    ].
    lower := path asLowercase.
    ext := ''.
    (lower endsWith: '.json') ifTrue: [ext := 'json'].
    (lower endsWith: '.yaml') ifTrue: [ext := 'yaml'].
    (lower endsWith: '.yml')  ifTrue: [ext := 'yaml'].
    (lower endsWith: '.cue')  ifTrue: [ext := 'cue'].
    ext isEmpty ifTrue: [
      'Unsupported file extension; expected .yaml, .yml, .json, or .cue' println.
      ^nil
    ].

    raw := nil.
    ext = 'json' ifTrue: [
      [
        contents := File readFileContents: path.
        contents isNil ifTrue: [^nil].
        raw := Json decode: contents
      ] on: Exception do: [:e |
        ('JSON parse error: ', e messageText) println. ^nil
      ]
    ] ifFalse: [
      [
        jsonText := Shell capture: 'cue export "', path, '" --out json 2>/dev/null'.
        (jsonText isNil or: [jsonText isEmpty]) ifTrue: [
          ('Failed to convert to JSON via `cue export`: ', path) println.
          ^nil
        ].
        raw := Json decode: jsonText
      ] on: Exception do: [:e |
        ('Parse error: ', e messageText) println. ^nil
      ]
    ].

    raw isNil ifTrue: [^nil].
    (raw isKindOf: Dictionary) ifFalse: [
      'Rewave mapping file must be a top-level map of story-id -> wave-number.' println.
      ^nil
    ].

    "Normalise: coerce wave values to integers, skip bad entries."
    result := Dictionary new.
    raw keysAndValuesDo: [:k :v |
      | waveNum |
      (v isKindOf: String)
        ifTrue: [waveNum := v asInteger]
        ifFalse: [waveNum := v asInteger].
      (waveNum notNil and: [waveNum > 0])
        ifTrue: [result at: k put: waveNum]
        ifFalse: [('Skipping ', k printString, ' (invalid wave ', v printString, ')') println]
    ].
    ^result
  ]

  classMethod: performWorkitemRewave: cfg scope: aScope epic: epicId mapping: mapping dryRun: dryRun [
    "Apply a rewave mapping to stories under an epic. Verifies each story is
     a child of the epic (warning and skipping if not). Returns 0 on success,
     1 if any story was skipped or failed."
    | items epicItem childParents updated skipped |
    items := self safeScan: 'workitem' cfg: cfg scope: aScope.
    epicItem := items detect: [:t | (t at: 'identity' ifAbsent: ['']) = epicId]
                      ifNone: [nil].
    epicItem isNil ifTrue: [
      ('Epic not found: ', epicId) println.
      ^1
    ].
    "Derive parent-of map from the same scan (single source of truth)."
    childParents := Dictionary new.
    items do: [:t |
      | p |
      p := (t at: 'payload' ifAbsent: [Dictionary new]) at: 'parent' ifAbsent: [nil].
      p notNil ifTrue: [childParents at: (t at: 'identity') put: p]
    ].

    updated := 0.
    skipped := 0.
    mapping keysAndValuesDo: [:storyId :newWave |
      (childParents at: storyId ifAbsent: [nil]) = epicId ifFalse: [
        ('Skipping ', storyId, ': not a child of ', epicId) println.
        skipped := skipped + 1
      ] ifTrue: [
        dryRun
          ifTrue: [
            ('[dry-run] ', storyId, ' -> wave ', newWave printString) println.
            updated := updated + 1
          ]
          ifFalse: [
            | fields |
            fields := Dictionary new.
            fields at: 'wave' put: newWave.
            fields at: 'updated_at' put: DateTime now epochSeconds.
            self performWorkitemUpdate: cfg
                 scope: aScope
                 identity: storyId
                 fields: fields
                 cascade: false.
            updated := updated + 1
          ]
      ]
    ].

    ('Rewave complete: ', updated printString, ' updated, ',
      skipped printString, ' skipped.') println.
    ^skipped > 0 ifTrue: [1] ifFalse: [0]
  ]

  "--- Workitem perform helpers --------------------------------------------"

  classMethod: performWorkitemUpdate: cfg scope: aScope identity: anIdentity fields: fields cascade: cascade [
    "Shared helper for update/ready/done/block. Cascade is true for the
     ready/done shortcuts (matches WorkItemCLI>>cmdSetStatus:status:)."
    | body |
    body := Dictionary new.
    body at: 'identity' put: anIdentity.
    body at: 'scope' put: aScope.
    body at: 'fields' put: fields.
    cascade ifTrue: [body at: 'cascade' put: true].
    self postAndPrint: cfg path: '/api/workitem/update' body: body
  ]

  classMethod: performWorkitemShow: cfg scope: aScope identity: anIdentity [
    "Scan + filter by identity to always see the latest payload (avoids
     stale persistent tuple reads). Render via Cli::Output dictText:keys:
     with an explicit key order so fields print Title / Type / Status /
     etc. deterministically — no more random reordering."
    | items item payload dict keys comments childCount |
    items := self safeScan: 'workitem' cfg: cfg scope: aScope.
    item := items detect: [:t | (t at: 'identity' ifAbsent: ['']) = anIdentity]
                  ifNone: [nil].
    item isNil ifTrue: ['Not found.' println. ^self].
    payload := item at: 'payload' ifAbsent: [Dictionary new].
    "Derive child count from the scan — children are tuples whose parent = this identity."
    childCount := (items select: [:t |
      ((t at: 'payload' ifAbsent: [Dictionary new]) at: 'parent' ifAbsent: [nil]) = anIdentity
    ]) size.

    dict := Dictionary new.
    dict at: 'Identity' put: anIdentity.
    dict at: 'Type' put: (payload at: 'type' ifAbsent: ['?']).
    dict at: 'Status' put: (payload at: 'status' ifAbsent: ['?']).
    dict at: 'Title' put: (payload at: 'title' ifAbsent: ['']).
    dict at: 'Repo' put: (payload at: 'repo' ifAbsent: ['']).
    dict at: 'Template' put: (payload at: 'template' ifAbsent: ['story']).
    dict at: 'Wave' put: (payload at: 'wave' ifAbsent: [1]) printString.
    dict at: 'Parent' put: (payload at: 'parent' ifAbsent: ['(none)']) printString.
    dict at: 'Children' put: childCount printString.
    dict at: 'Depends on' put: (payload at: 'depends_on' ifAbsent: [#()]) printString.
    dict at: 'Labels' put: (payload at: 'labels' ifAbsent: [#()]) printString.
    dict at: 'Description' put: (payload at: 'description' ifAbsent: ['']).

    keys := #('Identity' 'Type' 'Status' 'Title' 'Repo' 'Template'
              'Wave' 'Parent' 'Children' 'Depends on' 'Labels' 'Description').
    Cli::Output dictText: dict keys: keys.

    comments := payload at: 'comments' ifAbsent: [#()].
    comments size > 0 ifTrue: [
      '' println.
      'Comments:' println.
      comments do: [:c |
        ('  [', (c at: 'author' ifAbsent: ['?']), '] ',
          (c at: 'text' ifAbsent: [''])) println
      ]
    ]
  ]

  classMethod: performWorkitemList: cfg scope: aScope status: statusFilter type: typeFilter parent: parentFilter label: labelFilter [
    "List work items filtered by any of status/type/parent/label. Empty
     string (the Cli::Flag default) means no filter. Rendered via
     Cli::Output table:headers:keys: — which benefits from the recent
     string-quoting fix."
    | items filtered rows |
    items := self safeScan: 'workitem' cfg: cfg scope: aScope.

    filtered := items.
    (statusFilter notNil and: [statusFilter isEmpty not]) ifTrue: [
      filtered := filtered select: [:t |
        ((t at: 'payload' ifAbsent: [Dictionary new]) at: 'status' ifAbsent: ['']) = statusFilter
      ]
    ].
    (typeFilter notNil and: [typeFilter isEmpty not]) ifTrue: [
      filtered := filtered select: [:t |
        ((t at: 'payload' ifAbsent: [Dictionary new]) at: 'type' ifAbsent: ['']) = typeFilter
      ]
    ].
    (parentFilter notNil and: [parentFilter isEmpty not]) ifTrue: [
      filtered := filtered select: [:t |
        | p |
        p := (t at: 'payload' ifAbsent: [Dictionary new]) at: 'parent' ifAbsent: [nil].
        p = parentFilter
      ]
    ].
    (labelFilter notNil and: [labelFilter isEmpty not]) ifTrue: [
      filtered := filtered select: [:t |
        | lbls |
        lbls := (t at: 'payload' ifAbsent: [Dictionary new]) at: 'labels' ifAbsent: [#()].
        lbls includes: labelFilter
      ]
    ].

    filtered size = 0 ifTrue: [
      'No work items found.' println.
      ^self
    ].

    rows := Array new: 0.
    filtered do: [:t |
      | row p childCount tid |
      p := t at: 'payload' ifAbsent: [Dictionary new].
      tid := t at: 'identity' ifAbsent: ['?'].
      "Count children by scanning the full (pre-filter) list for tuples
       whose parent matches. Filters may have narrowed `filtered`, but
       `items` still holds the complete scan."
      childCount := (items select: [:x |
        ((x at: 'payload' ifAbsent: [Dictionary new]) at: 'parent' ifAbsent: [nil]) = tid
      ]) size.
      row := Dictionary new.
      row at: 'id' put: tid.
      row at: 'type' put: (p at: 'type' ifAbsent: ['?']).
      row at: 'status' put: (p at: 'status' ifAbsent: ['?']).
      row at: 'title' put: (p at: 'title' ifAbsent: ['']).
      row at: 'children' put: (childCount > 0
        ifTrue: [childCount printString]
        ifFalse: ['']).
      rows := rows copyWith: row
    ].
    Cli::Output
      table: rows
      headers: #('ID' 'TYPE' 'STATUS' 'TITLE' 'CHILDREN')
      keys: #('id' 'type' 'status' 'title' 'children')
  ]

  "--- ~/.pp directory helpers --------------------------------------------"

  classMethod: ppHome [
    "Mirror Repo>>initialize: ~/.pp under HOME (fallback /tmp)."
    | home |
    home := System env: 'HOME'.
    (home isNil or: [home isEmpty]) ifTrue: [home := '/tmp'].
    ^home, '/.pp'
  ]

  classMethod: reposDir   [ ^self ppHome, '/repos' ]
  classMethod: worktreesDir [ ^self ppHome, '/worktrees' ]

  classMethod: ensurePpDirs [
    Shell run: 'mkdir -p "', self reposDir, '" "', self worktreesDir, '"'
  ]

  classMethod: stripTrailingNewlines: aString [
    "Trim trailing CR/LF from a Shell capture result."
    | r last |
    r := aString.
    [r size > 0 and: [
      last := r copyFrom: r size - 1.
      (last = (Character lf asString)) or: [last = (Character cr asString)]
    ]] whileTrue: [
      r := r copyFrom: 0 to: r size - 1
    ].
    ^r
  ]

  "--- Subcommand: repo (parent + children) --------------------------------"

  classMethod: runRepo: args [
    "Dispatch `pp repo <subcmd> ...` through a Cli subcommand tree.
     Children: add, list, remove, info — mirroring src/cli/Repo.mag."
    | cfg root add list remove info rest |
    cfg := self loadConfig.
    root := Cli::Command named: 'repo' doc: 'Manage registered repositories'.

    add := Cli::Command named: 'add' doc: 'Register a repository'.
    add flag: (Cli::Flag name: 'name' type: #string default: '' doc: 'Repo name (defaults to basename of path)').
    add run: [:runArgs |
      | rawPath nameFlag exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp repo add <path> [--name <name>]' println.
        exitCode := 1
      ] ifFalse: [
        rawPath := runArgs at: 0.
        nameFlag := add flagValue: 'name'.
        self performRepoAdd: rawPath name: nameFlag
      ].
      exitCode
    ].

    list := Cli::Command named: 'list' doc: 'List registered repositories'.
    list run: [:runArgs |
      self performRepoList.
      0
    ].

    remove := Cli::Command named: 'remove' doc: 'Unregister a repository'.
    remove run: [:runArgs |
      | exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp repo remove <name>' println.
        exitCode := 1
      ] ifFalse: [
        self performRepoRemove: (runArgs at: 0)
      ].
      exitCode
    ].

    info := Cli::Command named: 'info' doc: 'Show repository details'.
    info run: [:runArgs |
      | exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp repo info <name>' println.
        exitCode := 1
      ] ifFalse: [
        self performRepoInfo: (runArgs at: 0)
      ].
      exitCode
    ].

    root registerSubcommand: add.
    root registerSubcommand: list.
    root registerSubcommand: remove.
    root registerSubcommand: info.

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    root setArgs: rest.
    ^[root execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: performRepoAdd: rawPath name: nameFlag [
    "Resolve rawPath to absolute, verify it's a git repo, and write a
     JSON config under ~/.pp/repos/<name>.json. Mirrors Repo>>cmdAdd:."
    | absPath repoName configPath config |
    absPath := self stripTrailingNewlines:
      (Shell capture: 'cd "', rawPath, '" 2>/dev/null && pwd').
    absPath isEmpty ifTrue: [
      ('Error: path does not exist: ', rawPath) println.
      ^self
    ].
    (File exists: absPath, '/.git') ifFalse: [
      ('Error: not a git repository: ', absPath) println.
      ^self
    ].

    (nameFlag notNil and: [nameFlag isEmpty not])
      ifTrue: [repoName := nameFlag]
      ifFalse: [
        repoName := self stripTrailingNewlines:
          (Shell capture: 'basename "', absPath, '"')
      ].

    self ensurePpDirs.
    configPath := self reposDir, '/', repoName, '.json'.

    config := Dictionary new.
    config at: 'name' put: repoName.
    config at: 'path' put: absPath.
    config at: 'registered_at' put: DateTime now epochSeconds.

    Shell run: 'cat > "', configPath, '" << ''PPEOF''
', (Json encodePretty: config), '
PPEOF'.

    ('Registered repository: ', repoName) println.
    ('  Path: ', absPath) println.
    ('  Config: ', configPath) println
  ]

  classMethod: performRepoList [
    "Tabular listing of registered repos via Cli::Output table:headers:keys:.
     The new STATUS column flags missing on-disk paths the same way the
     legacy `[MISSING]` annotation did."
    | listing rows |
    self ensurePpDirs.
    listing := Shell capture: 'ls "', self reposDir, '/" 2>/dev/null | grep ".json$"'.
    listing := self stripTrailingNewlines: listing.
    listing isEmpty ifTrue: [
      'No repositories registered.' println.
      'Use: pp repo add <path>' println.
      ^self
    ].
    rows := Array new: 0.
    (listing split: (Character lf asString)) do: [:fname |
      (fname size > 5 and: [(fname copyFrom: fname size - 5) = '.json']) ifTrue: [
        | configPath contents config row |
        configPath := self reposDir, '/', fname.
        [
          contents := File readFileContents: configPath.
          config := Json decode: contents.
          row := Dictionary new.
          row at: 'name' put: (config at: 'name' ifAbsent: ['?']).
          row at: 'path' put: (config at: 'path' ifAbsent: ['?']).
          row at: 'status' put: ((File exists: (config at: 'path' ifAbsent: ['']))
            ifTrue: ['']
            ifFalse: ['MISSING']).
          rows := rows copyWith: row
        ] on: Exception do: [:e |
          ('  Error reading ', fname, ': ', e messageText) println
        ]
      ]
    ].
    rows size = 0 ifTrue: [
      'No repositories registered.' println.
      'Use: pp repo add <path>' println.
      ^self
    ].
    Cli::Output
      table: rows
      headers: #('NAME' 'PATH' 'STATUS')
      keys: #('name' 'path' 'status')
  ]

  classMethod: performRepoRemove: repoName [
    | configPath |
    configPath := self reposDir, '/', repoName, '.json'.
    (File exists: configPath) ifFalse: [
      ('Error: no repository registered with name: ', repoName) println.
      ^self
    ].
    Shell run: 'rm "', configPath, '"'.
    ('Removed repository: ', repoName) println
  ]

  classMethod: performRepoInfo: repoName [
    "Render one repo's config via Cli::Output dictText:keys: for
     deterministic field order (name, path, registered_at)."
    | configPath contents config dict |
    configPath := self reposDir, '/', repoName, '.json'.
    (File exists: configPath) ifFalse: [
      ('Error: no repository registered with name: ', repoName) println.
      ^self
    ].
    contents := File readFileContents: configPath.
    config := Json decode: contents.

    dict := Dictionary new.
    dict at: 'name' put: (config at: 'name' ifAbsent: ['?']).
    dict at: 'path' put: (config at: 'path' ifAbsent: ['?']).
    dict at: 'registered_at' put: (config at: 'registered_at' ifAbsent: [0]) printString.

    Cli::Output dictText: dict keys: #('name' 'path' 'registered_at')
  ]

  "--- Subcommand: worktree (parent + children) ----------------------------"

  classMethod: runWorktree: args [
    "Dispatch `pp worktree <subcmd>`. Children: list, clean."
    | root list clean rest |
    root := Cli::Command named: 'worktree' doc: 'Manage worktrees'.

    list := Cli::Command named: 'list' doc: 'List managed worktrees'.
    list run: [:runArgs |
      self performWorktreeList.
      0
    ].

    clean := Cli::Command named: 'clean' doc: 'Remove worktrees for completed/missing workflows'.
    clean flag: (Cli::Flag
      name: 'dry-run'
      type: #bool
      default: false
      doc: 'Preview what would be removed without actually removing it').
    clean run: [:runArgs |
      | dryRun |
      dryRun := clean flagValue: 'dry-run'.
      self performWorktreeClean: dryRun.
      0
    ].

    root registerSubcommand: list.
    root registerSubcommand: clean.

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    root setArgs: rest.
    ^[root execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: performWorktreeList [
    "Tabular listing of worktrees: one row per (task, worktree) pair."
    | listing rows wtDir lf |
    self ensurePpDirs.
    wtDir := self worktreesDir.
    lf := Character lf asString.
    listing := self stripTrailingNewlines:
      (Shell capture: 'ls "', wtDir, '" 2>/dev/null').
    listing isEmpty ifTrue: [
      'No worktrees found.' println.
      ^self
    ].
    rows := Array new: 0.
    (listing split: lf) do: [:taskName |
      (taskName isEmpty or: [taskName startsWith: '.']) ifFalse: [
        | subList row |
        subList := self stripTrailingNewlines:
          (Shell capture: 'ls "', wtDir, '/', taskName, '" 2>/dev/null').
        subList isEmpty ifTrue: [
          row := Dictionary new.
          row at: 'task' put: taskName.
          row at: 'worktree' put: ''.
          rows := rows copyWith: row
        ] ifFalse: [
          (subList split: lf) do: [:wtName |
            (wtName isEmpty or: [wtName startsWith: '.']) ifFalse: [
              row := Dictionary new.
              row at: 'task' put: taskName.
              row at: 'worktree' put: wtName.
              rows := rows copyWith: row
            ]
          ]
        ]
      ]
    ].
    rows size = 0 ifTrue: ['No worktrees found.' println. ^self].
    Cli::Output
      table: rows
      headers: #('TASK' 'WORKTREE')
      keys: #('task' 'worktree')
  ]

  classMethod: performWorktreeClean: dryRun [
    "Port of Repo>>cmdWorktreeClean:. Probe each task dir against the
     workflow status endpoint; if completed/missing, drop the worktree."
    | wtDir listing ppUrl cleaned lf |
    self ensurePpDirs.
    wtDir := self worktreesDir.
    lf := Character lf asString.
    cleaned := 0.
    ppUrl := System env: 'PP_URL'.
    (ppUrl isNil or: [ppUrl isEmpty]) ifTrue: [ppUrl := 'http://localhost:7777'].

    listing := self stripTrailingNewlines:
      (Shell capture: 'ls "', wtDir, '/" 2>/dev/null').
    listing isEmpty ifTrue: ['No worktrees to clean.' println. ^self].

    (listing split: lf) do: [:taskName |
      taskName isEmpty ifFalse: [
        | taskDir shouldRemove statusResponse statusBody wfStatus subList |
        taskDir := wtDir, '/', taskName.
        shouldRemove := false.
        [
          statusResponse := Shell capture:
            'curl -s "', ppUrl, '/api/v1/workflow/status/', taskName, '" 2>/dev/null'.
          (statusResponse isNil or: [statusResponse isEmpty]) ifTrue: [
            shouldRemove := true
          ] ifFalse: [
            [
              statusBody := Json decode: statusResponse.
              wfStatus := statusBody at: 'status' ifAbsent: [''].
              (wfStatus = 'completed' or: [wfStatus = 'not_found']) ifTrue: [
                shouldRemove := true
              ]
            ] on: Exception do: [:e | shouldRemove := true]
          ]
        ] on: Exception do: [:e | shouldRemove := true].

        shouldRemove ifTrue: [
          dryRun ifTrue: [
            ('Would remove: ', taskDir) println.
            cleaned := cleaned + 1
          ] ifFalse: [
            subList := self stripTrailingNewlines:
              (Shell capture: 'ls "', taskDir, '/" 2>/dev/null').
            subList isEmpty ifFalse: [
              (subList split: lf) do: [:wtName |
                wtName isEmpty ifFalse: [
                  | wtPath |
                  wtPath := taskDir, '/', wtName.
                  Shell run:
                    'git worktree remove "', wtPath,
                    '" 2>/dev/null || rm -rf "', wtPath, '"'
                ]
              ]
            ].
            Shell run: 'rm -rf "', taskDir, '"'.
            ('Removed: ', taskDir) println.
            cleaned := cleaned + 1
          ]
        ]
      ]
    ].
    ('Cleaned ', cleaned printString, ' worktree(s).') println
  ]

  "--- Subcommand: clean-branches -----------------------------------------"

  classMethod: runCleanBranches: args [
    "`pp clean-branches [--dry-run] [--all] [--repo <name>]` — port of
     Repo>>cmdCleanBranches:. Exercises two bool flags + one string flag."
    | cmd rest |
    cmd := Cli::Command named: 'clean-branches' doc: 'Remove stale impl/feature branches'.
    cmd flag: (Cli::Flag
      name: 'dry-run'
      type: #bool
      default: false
      doc: 'Preview deletions without actually removing branches').
    cmd flag: (Cli::Flag
      name: 'all'
      type: #bool
      default: false
      doc: 'Also force-delete unmerged branches').
    cmd flag: (Cli::Flag
      name: 'repo'
      type: #string
      default: ''
      doc: 'Operate on a registered repository (by name)').

    cmd run: [:runArgs |
      | dryRun deleteAll repoFlag |
      dryRun := cmd flagValue: 'dry-run'.
      deleteAll := cmd flagValue: 'all'.
      repoFlag := cmd flagValue: 'repo'.
      (repoFlag isNil or: [repoFlag isEmpty]) ifTrue: [repoFlag := nil].
      self performCleanBranches: dryRun all: deleteAll repo: repoFlag.
      0
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  classMethod: performCleanBranches: dryRun all: deleteAll repo: repoName [
    "Mirrors Repo>>cmdCleanBranches: but driven by Cli::Flag values."
    | repoPath repoConfig branchOutput branchLines mergedOutput mergedLines current
      deletedMerged deletedForce totalDeleted lf |
    deletedMerged := 0.
    deletedForce := 0.
    lf := Character lf asString.

    repoPath := nil.
    repoName notNil ifTrue: [
      | configPath contents |
      configPath := self reposDir, '/', repoName, '.json'.
      (File exists: configPath) ifFalse: [
        ('Error: no repository registered with name: ', repoName) println.
        ^self
      ].
      contents := File readFileContents: configPath.
      repoConfig := Json decode: contents.
      repoPath := repoConfig at: 'path' ifAbsent: [nil]
    ].
    repoPath isNil ifTrue: [
      repoPath := self stripTrailingNewlines: (Shell capture: 'pwd')
    ].

    branchOutput := self stripTrailingNewlines:
      (Shell capture: 'git -C "', repoPath, '" branch --list "impl/*" "feature/*" 2>/dev/null | sed "s/^[* ]*//"').
    branchOutput isEmpty ifTrue: [
      'No impl/* or feature/* branches found.' println.
      ^self
    ].
    branchLines := branchOutput split: lf.

    current := self stripTrailingNewlines:
      (Shell capture: 'git -C "', repoPath, '" rev-parse --abbrev-ref HEAD 2>/dev/null').

    mergedOutput := self stripTrailingNewlines:
      (Shell capture: 'git -C "', repoPath, '" branch --merged main 2>/dev/null | sed "s/^[* ]*//"').
    mergedLines := Array new: 0.
    mergedOutput isEmpty ifFalse: [
      (mergedOutput split: lf) do: [:ml |
        ml isEmpty ifFalse: [mergedLines := mergedLines copyWith: ml]
      ]
    ].

    branchLines do: [:line |
      | branch isMerged |
      line isEmpty ifFalse: [
        line = current ifTrue: [
          ('Skipping current branch: ', line) println
        ] ifFalse: [
          branch := line.
          isMerged := (mergedLines indexOf: branch) >= 0.
          isMerged ifTrue: [
            dryRun
              ifTrue: [('Would delete (merged): ', branch) println]
              ifFalse: [
                Shell run: 'git -C "', repoPath, '" branch -d "', branch, '"'.
                ('Deleted (merged): ', branch) println
              ].
            deletedMerged := deletedMerged + 1
          ] ifFalse: [
            deleteAll ifTrue: [
              dryRun
                ifTrue: [('Would force-delete (unmerged): ', branch) println]
                ifFalse: [
                  ('Deleting UNMERGED branch: ', branch) println.
                  Shell run: 'git -C "', repoPath, '" branch -D "', branch, '"'
                ].
              deletedForce := deletedForce + 1
            ] ifFalse: [
              ('Skipping unmerged: ', branch, ' (use --all to force-delete)') println
            ]
          ]
        ]
      ]
    ].

    totalDeleted := deletedMerged + deletedForce.
    dryRun
      ifTrue: [('Dry run: would delete ', totalDeleted printString, ' branches') println]
      ifFalse: [('Deleted ', totalDeleted printString, ' branches (',
                 deletedMerged printString, ' merged, ',
                 deletedForce printString, ' force-deleted)') println]
  ]

  "--- Subcommand: task ----------------------------------------------------"

  classMethod: runTask: args [
    "`pp task <id> --role R --description D [--workdir P] [--repo R]`
     — agent-facing primitive that POSTs /api/task/create. Exercises
     two required string flags plus two optional ones."
    | cmd cfg rest |
    cmd := Cli::Command named: 'task' doc: 'Create a task tuple directly'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_TASK'
      setter: #taskId:
      type: #string
      default: '').

    cmd flag: (Cli::Flag name: 'role' type: #string default: '' doc: 'Agent role (required)').
    cmd flag: (Cli::Flag name: 'description' type: #string default: '' doc: 'Task description (required)').
    cmd flag: (Cli::Flag name: 'workdir' type: #string default: '' doc: 'Working directory for the task').
    cmd flag: (Cli::Flag name: 'repo' type: #string default: '' doc: 'Repo (defaults to PP_REPO env)').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | identity role desc workdir repo body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp task <identity> --role <role> --description <desc> [--workdir <path>] [--repo <name>]' println.
        exitCode := 1
      ] ifFalse: [
        cmd applyEnvBindings: cfg.
        identity := runArgs at: 0.
        role := cmd flagValue: 'role'.
        desc := cmd flagValue: 'description'.
        workdir := cmd flagValue: 'workdir'.
        repo := cmd flagValue: 'repo'.

        (role isNil or: [role isEmpty]) ifTrue: [
          'Error: --role is required' println.
          exitCode := 1
        ] ifFalse: [
          (desc isNil or: [desc isEmpty]) ifTrue: [
            'Error: --description is required' println.
            exitCode := 1
          ] ifFalse: [
            body := Dictionary new.
            body at: 'scope' put: cfg scope.
            body at: 'identity' put: identity.
            body at: 'role' put: role.
            body at: 'description' put: desc.
            (workdir notNil and: [workdir isEmpty not]) ifTrue: [
              body at: 'workdir' put: workdir
            ].
            (repo isNil or: [repo isEmpty]) ifTrue: [
              repo := System env: 'PP_REPO'.
              (repo isNil or: [repo isEmpty]) ifTrue: [repo := nil]
            ].
            repo notNil ifTrue: [body at: 'repo' put: repo].
            cfg taskId isEmpty ifFalse: [
              body at: 'workflow_instance' put: cfg taskId
            ].
            self postAndPrint: cfg path: '/api/task/create' body: body
          ]
        ]
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: session -------------------------------------------------"

  classMethod: runSession: args [
    "`pp session [<task-id>]` — view (or list) Claude Code session
     logs. Display formatting is reused from SystemCommands so the
     output exactly matches the legacy command."
    | cmd rest |
    cmd := Cli::Command named: 'session' doc: 'View Claude session log for a task'.
    cmd run: [:runArgs |
      | callArgs sysCmd |
      callArgs := Array new: 0.
      callArgs := callArgs copyWith: 'session'.
      runArgs size >= 1 ifTrue: [
        callArgs := callArgs copyWith: (runArgs at: 0)
      ].
      sysCmd := SystemCommands new.
      sysCmd cmdSession: callArgs.
      0
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: usage ---------------------------------------------------"

  classMethod: runUsage: args [
    "`pp usage [<task-id>] [--json]` — report current session token usage so
     agents can self-regulate. Delegates to SystemCommands>>cmdUsage:."
    | cmd rest |
    cmd := Cli::Command named: 'usage' doc: 'Report current session token consumption'.
    cmd run: [:runArgs |
      | callArgs sysCmd i |
      callArgs := Array new: 0.
      callArgs := callArgs copyWith: 'usage'.
      i := 0.
      [i < runArgs size] whileTrue: [
        callArgs := callArgs copyWith: (runArgs at: i).
        i := i + 1
      ].
      sysCmd := SystemCommands new.
      sysCmd cmdUsage: callArgs.
      0
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]

  "--- Subcommand: plan ----------------------------------------------------"

  classMethod: runPlan: args [
    "`pp plan <file.json>` — read a structured plan from disk and POST
     it to /api/plan. Single positional file argument, no flags."
    | cmd cfg rest |
    cmd := Cli::Command named: 'plan' doc: 'Submit a structured plan from a JSON file'.
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_URL'
      setter: #baseUrl:
      type: #string
      default: 'http://localhost:7777').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_SCOPE'
      setter: #scope:
      type: #string
      default: 'default').
    cmd envBinding: (Cli::EnvBinding
      envName: 'PP_TASK'
      setter: #taskId:
      type: #string
      default: '').

    cfg := PPCliConfig new.

    cmd run: [:runArgs |
      | filePath contents body exitCode |
      exitCode := 0.
      runArgs size < 1 ifTrue: [
        'Usage: pp plan <file.json>' println.
        exitCode := 1
      ] ifFalse: [
        cmd applyEnvBindings: cfg.
        filePath := runArgs at: 0.
        (File exists: filePath) ifFalse: [
          ('File not found: ', filePath) println.
          exitCode := 1
        ] ifTrue: [
          contents := File readFileContents: filePath.
          body := Json decode: contents.
          body at: 'scope' put: cfg scope.
          cfg taskId isEmpty ifFalse: [body at: 'task' put: cfg taskId].
          self postAndPrint: cfg path: '/api/plan' body: body
        ]
      ].
      exitCode
    ].

    rest := args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0].
    cmd setArgs: rest.
    ^[cmd execute] on: Cli::CliError do: [:e | 1]
  ]


  "--- Subcommand: identity ----------------------------------------------"

  classMethod: runIdentity: args [
    "Dispatch `pp identity <init|show|rotate|list> ...` to the matching
     CliIdentity* class. Unknown subcommands print a short usage."
    | sub rest |
    args size < 2 ifTrue: [
      self printIdentityUsage.
      ^1
    ].
    sub := args at: 1.
    rest := args size > 2 ifTrue: [args copyFrom: 2] ifFalse: [Array new: 0].
    sub = 'init'    ifTrue: [^CliIdentityInit run: rest].
    sub = 'show'    ifTrue: [^CliIdentityShow run: rest].
    sub = 'rotate'  ifTrue: [^CliIdentityRotate run: rest].
    sub = 'list'    ifTrue: [^CliIdentityList run: rest].
    ('Unknown identity subcommand: ', sub) println.
    self printIdentityUsage.
    ^1
  ]

  classMethod: printIdentityUsage [
    'Usage: pp identity <init|show|rotate|list> [args...]' println.
    '' println.
    '  init   <name> [--force]   Create a new keypair' println.
    '  show   <name>             Print public key and proquint' println.
    '  rotate <name>             Rotate keypair against /api/user/rotate' println.
    '  list                      List local identities' println
  ]
