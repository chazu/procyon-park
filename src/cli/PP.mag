"The pp CLI — a thin HTTP client for agent-system communication.
 Reads PP_URL, PP_SCOPE, PP_TASK from environment."

PP subclass: CLIBase

  method: runWith: args [
    "Dispatch to the appropriate command based on args."
    | cmd wtArgs i idArg stripped |
    args isEmpty ifTrue: [
      self printUsage.
      ^self
    ].

    "Strip -i <name> / --identity <name> from anywhere in args and apply to this CLI."
    stripped := Array new: 0.
    i := 0.
    [i < args size] whileTrue: [
      idArg := args at: i.
      ((idArg = '-i' or: [idArg = '--identity']) and: [i + 1 < args size]) ifTrue: [
        self overrideIdentity: (args at: i + 1).
        i := i + 2
      ] ifFalse: [
        stripped := stripped copyWith: idArg.
        i := i + 1
      ]
    ].
    args := stripped.
    args isEmpty ifTrue: [self printUsage. ^self].

    cmd := args at: 0.

    cmd = 'observe'   ifTrue: [^self cmdObserve: args].
    cmd = 'decide'    ifTrue: [^self cmdDecide: args].
    cmd = 'event'     ifTrue: [^self cmdEvent: args].
    cmd = 'plan'      ifTrue: [^self cmdPlan: args].
    cmd = 'read'      ifTrue: [^self cmdRead: args].
    cmd = 'notify'    ifTrue: [^self cmdNotify: args].
    cmd = 'dismiss'   ifTrue: [^self cmdDismiss: args].
    cmd = 'workflow'  ifTrue: [^WorkflowCommands new runWith: args].
    cmd = 'watch'     ifTrue: [^WorkflowCommands new cmdWatch: args].
    cmd = 'unwatch'   ifTrue: [^WorkflowCommands new cmdUnwatch: args].
    cmd = 'signal'    ifTrue: [^self cmdSignal: args].
    cmd = 'verdict'   ifTrue: [^self cmdVerdict: args].

    "System commands delegated to SystemCommands"
    cmd = 'gc'        ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'status'    ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'prime'     ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'task'      ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'log'       ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'history'   ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'audit'     ifTrue: [^CliPP runAudit: args].
    cmd = 'dashboard' ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'session'   ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'usage'     ifTrue: [^SystemCommands new runCommand: cmd args: args].
    cmd = 'workitem'  ifTrue: [^WorkItemCLI new runWith: args].
    cmd = 'bbs'       ifTrue: [^CliBBS new runWith: args].
    cmd = 'repo'      ifTrue: [^Repo new runWith: args].
    cmd = 'worktree'  ifTrue: [
      wtArgs := #('repo').
      args do: [:a | wtArgs := wtArgs copyWith: a].
      ^Repo new runWith: wtArgs
    ].
    cmd = 'identity'  ifTrue: [^self cmdIdentity: args].
    cmd = 'worker'    ifTrue: [^self cmdWorker: args].
    cmd = 'user'      ifTrue: [^self cmdUser: args].
    cmd = 'whoami'    ifTrue: [^CliWhoami run: args identityOverride: identityOverride].
    cmd = 'init'      ifTrue: [^CliInit run: (args size > 1 ifTrue: [args copyFrom: 1] ifFalse: [Array new: 0])].
    cmd = 'help'      ifTrue: [^self printUsage].

    ('Unknown command: ', cmd) println.
    self printUsage
  ]

  "--- Commands ---"

  method: cmdObserve: args [
    "pp observe <identity> <detail> [--tags tag1,tag2]"
    | identity detail tags body |
    args size < 3 ifTrue: [
      'Usage: pp observe <identity> <detail> [--tags tag1,tag2]' println.
      ^self
    ].

    identity := args at: 1.
    detail := args at: 2.
    tags := self flagValue: '--tags' in: args.

    body := Dictionary new.
    body at: 'scope' put: scope.
    body at: 'identity' put: identity.
    body at: 'detail' put: detail.
    taskId isEmpty ifFalse: [body at: 'task' put: taskId].
    tags notNil ifTrue: [body at: 'tags' put: (tags split: ',')].

    self post: '/api/observe' body: body
  ]

  method: cmdDecide: args [
    "pp decide <identity> <detail> [--rationale ...]"
    | body rationale |
    args size < 3 ifTrue: [
      'Usage: pp decide <identity> <detail> [--rationale ...]' println.
      ^self
    ].

    body := Dictionary new.
    body at: 'scope' put: scope.
    body at: 'identity' put: (args at: 1).
    body at: 'detail' put: (args at: 2).
    taskId isEmpty ifFalse: [body at: 'task' put: taskId].
    rationale := self flagValue: '--rationale' in: args.
    rationale notNil ifTrue: [body at: 'rationale' put: rationale].

    self post: '/api/decide' body: body
  ]

  method: cmdEvent: args [
    "pp event <identity> [--type T] [--summary S]"
    | body summary eventType |
    args size < 2 ifTrue: [
      'Usage: pp event <identity> [--type T] [--summary S]' println.
      ^self
    ].

    body := Dictionary new.
    body at: 'scope' put: scope.
    body at: 'identity' put: (args at: 1).
    eventType := self flagValue: '--type' in: args.
    body at: 'type' put: (eventType isNil ifTrue: ['generic'] ifFalse: [eventType]).
    summary := self flagValue: '--summary' in: args.
    summary notNil ifTrue: [body at: 'summary' put: summary].

    self post: '/api/event' body: body
  ]

  method: cmdPlan: args [
    "pp plan <file.json>"
    | filePath contents body |
    args size < 2 ifTrue: [
      'Usage: pp plan <file.json>' println.
      ^self
    ].

    filePath := args at: 1.
    (File exists: filePath) ifFalse: [
      ('File not found: ', filePath) println.
      ^self
    ].

    contents := File readFileContents: filePath.
    body := Json decode: contents.
    body at: 'scope' put: scope.
    taskId isEmpty ifFalse: [body at: 'task' put: taskId].

    self post: '/api/plan' body: body
  ]

  method: cmdRead: args [
    "pp read <category> [scope] [identity]"
    | category rdScope rdIdentity body |
    args size < 2 ifTrue: [
      'Usage: pp read <category> [scope] [identity]' println.
      ^self
    ].

    category := args at: 1.
    rdScope := args size > 2 ifTrue: [args at: 2] ifFalse: [scope].
    rdIdentity := args size > 3 ifTrue: [args at: 3] ifFalse: [nil].

    rdIdentity notNil ifTrue: [
      "Read a specific tuple — /api/rdp is intentionally unsigned."
      body := Dictionary new.
      body at: 'category' put: category.
      body at: 'scope' put: rdScope.
      body at: 'identity' put: rdIdentity.
      self unauthedPost: '/api/rdp' body: body
    ] ifFalse: [
      "Scan all in category+scope — /api/scan is intentionally unsigned."
      body := Dictionary new.
      body at: 'category' put: category.
      body at: 'scope' put: rdScope.
      self unauthedPost: '/api/scan' body: body
    ]
  ]

  method: cmdNotify: args [
    "pp notify <message> [--severity info|warn|urgent]"
    | body severity |
    args size < 2 ifTrue: [
      'Usage: pp notify <message> [--severity info|warn|urgent]' println.
      ^self
    ].

    body := Dictionary new.
    body at: 'message' put: (args at: 1).
    body at: 'scope' put: scope.
    severity := self flagValue: '--severity' in: args.
    body at: 'severity' put: (severity isNil ifTrue: ['info'] ifFalse: [severity]).

    self post: '/api/notify' body: body
  ]

  method: cmdDismiss: args [
    "pp dismiss"
    | body |
    taskId isEmpty ifTrue: [
      'No task ID set (PP_TASK env var). Cannot dismiss.' println.
      ^self
    ].

    body := Dictionary new.
    body at: 'task_id' put: taskId.
    body at: 'scope' put: scope.

    self post: '/api/dismiss' body: body
  ]

  "--- Workflow/Signal Commands ---"

  method: cmdSignal: args [
    "pp signal <identity> <key> <value>"
    | body identity key value payload |
    args size < 4 ifTrue: [
      'Usage: pp signal <identity> <key> <value>' println.
      ^self
    ].

    identity := args at: 1.
    key := args at: 2.
    value := args at: 3.

    payload := Dictionary new.
    payload at: key put: value.

    body := Dictionary new.
    body at: 'scope' put: scope.
    body at: 'identity' put: identity.
    body at: 'payload' put: payload.

    self post: '/api/signal' body: body
  ]

  method: cmdVerdict: args [
    "pp verdict <pass|fix|exhausted> [--workflow <id>]
     Shorthand for: pp signal verdict:<workflow-instance> decision <decision>.
     Reads PP_WORKFLOW from env (set by harness for agents). Humans can pass --workflow <id>,
     or if neither is set, the command lists running workflows so the user can pick one."
    | decision wfId wfFlag body payload wfEnv workflows |
    args size < 2 ifTrue: [
      'Usage: pp verdict <pass|fix|exhausted> [--workflow <id>]' println.
      ^self
    ].

    decision := args at: 1.
    (decision = 'pass' or: [decision = 'fix' or: [decision = 'exhausted']]) ifFalse: [
      ('Invalid decision: ', decision, ' (expected pass|fix|exhausted)') println.
      ^self
    ].

    "Resolve workflow instance: --workflow flag > PP_WORKFLOW env"
    wfFlag := self flagValue: '--workflow' in: args.
    wfFlag notNil ifTrue: [wfId := wfFlag] ifFalse: [
      wfEnv := System env: 'PP_WORKFLOW'.
      (wfEnv isNil or: [wfEnv isEmpty])
        ifTrue: [wfId := nil]
        ifFalse: [wfId := wfEnv]
    ].

    wfId isNil ifTrue: [
      'Error: no workflow instance ID.' println.
      'Set PP_WORKFLOW env var or pass --workflow <id>.' println.
      workflows := self safeScan: 'workflow' scope: nil.
      workflows size > 0 ifTrue: [
        '' println.
        'Running workflows:' println.
        workflows do: [:wf |
          | wfp wfStatus wfIdent |
          wfp := wf at: 'payload' ifAbsent: [Dictionary new].
          wfStatus := wfp at: 'status' ifAbsent: ['?'].
          wfIdent := wf at: 'identity' ifAbsent: ['?'].
          wfStatus = 'running' ifTrue: [
            ('  ', wfIdent, '  [', (wfp at: 'template' ifAbsent: ['?']), ']') println
          ]
        ]
      ].
      ^self
    ].

    payload := Dictionary new.
    payload at: 'decision' put: decision.

    body := Dictionary new.
    body at: 'scope' put: scope.
    body at: 'identity' put: 'verdict:', wfId.
    body at: 'payload' put: payload.

    self post: '/api/signal' body: body
  ]

  method: cmdUser: args [
    "pp user <add|revoke> <name> [--pubkey <hex>]
     Admin-only commands that target /api/user/add and /api/user/revoke.
     Both endpoints require an admin-signed request — i.e. the local
     identity's pubkey must appear in [admin].admins of server.toml.
     CliUserAdd / CliUserRevoke handle argparse + signing."
    | sub rest |
    args size < 2 ifTrue: [
      'Usage: pp user <add|revoke> <name> [--pubkey <hex>]' println.
      ^self
    ].
    sub := args at: 1.
    rest := args size > 2 ifTrue: [args copyFrom: 2] ifFalse: [Array new: 0].
    sub = 'add'    ifTrue: [^CliUserAdd run: rest].
    sub = 'revoke' ifTrue: [^CliUserRevoke run: rest].
    ('Unknown user subcommand: ', sub) println.
    'Usage: pp user <add|revoke> <name> [--pubkey <hex>]' println
  ]

  method: cmdWorker: args [
    "pp worker <init|register|drain> <name> [flags...]
     Delegates to the CliWorker* classes."
    | sub rest |
    args size < 2 ifTrue: [
      'Usage: pp worker <init|register|heartbeat|drain> <name> [flags...]' println.
      ^self
    ].
    sub := args at: 1.
    rest := args size > 2 ifTrue: [args copyFrom: 2] ifFalse: [Array new: 0].
    sub = 'init'      ifTrue: [^CliWorkerInit run: rest].
    sub = 'register'  ifTrue: [^CliWorkerRegister run: rest].
    sub = 'heartbeat' ifTrue: [^CliWorkerHeartbeat run: rest].
    sub = 'drain'     ifTrue: [^CliWorkerDrain run: rest].
    ('Unknown worker subcommand: ', sub) println
  ]

  method: cmdIdentity: args [
    "pp identity <init|show|rotate|list|use> ...
     Delegates to the CliIdentity* classes regardless of PP_USE_CLI."
    | sub rest baseUrl |
    args size < 2 ifTrue: [
      'Usage: pp identity <init|show|rotate|list|use|invite|accept> [args...]' println.
      ^self
    ].
    sub := args at: 1.
    rest := args size > 2 ifTrue: [args copyFrom: 2] ifFalse: [Array new: 0].
    sub = 'init'   ifTrue: [^CliIdentityInit run: rest].
    sub = 'show'   ifTrue: [^CliIdentityShow run: rest].
    sub = 'rotate' ifTrue: [^CliIdentityRotate run: rest].
    sub = 'list'   ifTrue: [^CliIdentityList run: rest].
    sub = 'use'    ifTrue: [^CliIdentityUse run: rest].
    sub = 'invite' ifTrue: [^CliIdentityInvite run: rest].
    sub = 'accept' ifTrue: [^CliIdentityAccept run: rest].
    ('Unknown identity subcommand: ', sub) println
  ]

  method: printUsage [
    'Procyon Park CLI' println.
    '' println.
    'Usage: pp <command> [args...]' println.
    '' println.
    'Commands:' println.
    '  observe  <identity> <detail> [--tags t1,t2]     Report an observation' println.
    '  decide   <identity> <detail> [--rationale ...]   Record a decision' println.
    '  event    <identity> [--type T] [--summary S]     Emit an event' println.
    '  plan     <file.json>                             Submit a structured plan' println.
    '  read     <category> [scope] [identity]           Read tuples' println.
    '  notify   <message> [--severity info|warn|urgent] Notify the user' println.
    '  dismiss                                          Signal task completion' println.
    '  verdict  <pass|fix|exhausted> [--workflow <id>]   Write review verdict (uses PP_WORKFLOW)' println.
    '  status                                           Show system status' println.
    '  workflow <template> [--param key=val ...]        Start a workflow' println.
    '  workflow status [<id>]                           Show workflow status' println.
    '  workflow list [--status running|completed|failed] Tabular listing of workflows' println.
    '  workflow cancel <id> [--scope <scope>]           Cancel a running workflow' println.
    '  workflow wait <id> [--timeout <secs>]            Block until workflow completes' println.
    '  watch    <workflow_id>                           Subscribe to workflow lifecycle events' println.
    '  unwatch  <workflow_id>                           Remove a workflow subscription' println.
    '  log      [--follow] [--no-follow] [--since <secs>] Stream notifications' println.
    '  history   [--since S] [--limit N] [--op O] [--category C] [--scope S] [--identity I] Query audit log' println.
    '  audit    (--actor <n> | --worker <id> | --workflow <id>) Roll up provenance by actor/worker/workflow' println.
    '  dashboard                                        Open web dashboard in browser' println.
    '  gc       [--dry-run]                             Garbage-collect finished workflows & branches' println.
    '  session  [<taskId>]                              View Claude Code session logs' println.
    '  usage    [<taskId>]                              Report current session token consumption' println.
    '  identity <init|show|rotate|list|use> [args...]   Manage local keypairs' println.
    '  init     [<name>]                                First-time setup (create identity + config)' println.
    '  worker   init <name> [--force]                  Create a local worker keypair' println.
    '  user     <add|revoke> <name> [--pubkey <hex>]    Admin-gated user registry' println.
    '  whoami                                           Show the active local identity' println.
    '  help                                             Show this help' println.
    '' println.
    'Environment:' println.
    ('  PP_URL   = ', baseUrl) println.
    ('  PP_SCOPE = ', scope) println.
    ('  PP_TASK  = ', taskId) println
  ]
