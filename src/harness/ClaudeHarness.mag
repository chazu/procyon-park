"Claude Code harness — spawns a Claude CLI process with the appropriate
 system prompt, environment, and tools for a given role and task."

ClaudeHarness subclass: Object
  instanceVars: role taskId scope bbs process systemPrompt workDir repoName

  method: initRole: aRole task: aTaskId scope: aScope bbs: aBBS [
    role := aRole.
    taskId := aTaskId.
    scope := aScope.
    bbs := aBBS.
    workDir := File workingDirectory.
    repoName := ''
  ]

  method: workDir: aPath [
    workDir := aPath
  ]

  method: repoName: aName [
    repoName := aName
  ]

  method: role [ ^role ]
  method: taskId [ ^taskId ]

  method: run [
    "Assemble the system prompt, spawn Claude, wait for completion."

    | contextTuples taskTuple taskDescription taskPayload workflowInstance env home sessionsDir outputFile timeoutArgs shellCmd |

    "Read the task description and workflow instance first (needed for context filtering)"
    taskTuple := bbs rdp: 'task' scope: scope identity: taskId.
    taskDescription := taskTuple notNil
      ifTrue: [(taskTuple at: 'payload') at: 'description' ifAbsent: ['No description']]
      ifFalse: ['Task: ', taskId].
    taskPayload := taskTuple notNil
      ifTrue: [taskTuple at: 'payload']
      ifFalse: [Dictionary new].
    workflowInstance := taskPayload at: 'workflow_instance' ifAbsent: [''].

    "Reviewer tasks get an auto-generated git diff summary (files changed,
     insertions, deletions) so the reviewer does not have to discover
     what changed by hand. Only runs when there is a workdir to inspect."
    (role name = 'reviewer' and: [workDir notNil and: [workDir isEmpty not]]) ifTrue: [
      | diffSummary |
      diffSummary := self gitDiffSummaryFor: workDir.
      diffSummary isEmpty ifFalse: [
        taskDescription := taskDescription, '

## What Changed
', diffSummary
      ]
    ].

    "Assemble context filtered to this workflow instance"
    contextTuples := role assembleContext: bbs scope: scope taskId: taskId workflowInstance: workflowInstance.

    "Build the system prompt (with workdir boundary if set)"
    systemPrompt := role primeFor: taskDescription context: contextTuples workDir: workDir repoName: repoName.

    "Spawn Claude"
    ('Starting Claude harness for ', role name, ' task: ', taskId) println.

    "Ensure sessions directory exists for transcript capture"
    home := System env: 'HOME'.
    (home isNil or: [home isEmpty]) ifTrue: [home := '/tmp'].
    sessionsDir := home, '/.pp/sessions'.
    Shell run: 'mkdir -p "', sessionsDir, '"'.
    outputFile := sessionsDir, '/', taskId, '.jsonl'.

    "Environment — agents know their URL, scope, task, repo, and workflow.
     PP_SYSTEM_PROMPT and PP_TASK_DESC are used by the sh -c wrapper below
     to avoid shell-escaping issues with quotes and newlines."
    env := Dictionary new.
    env at: 'PP_URL' put: 'http://localhost:7777'.
    env at: 'PP_SCOPE' put: scope.
    env at: 'PP_TASK' put: taskId.
    env at: 'PP_REPO' put: repoName.
    env at: 'PP_REPO_PATH' put: workDir.
    env at: 'PP_WORKFLOW' put: workflowInstance.
    env at: 'PP_SYSTEM_PROMPT' put: systemPrompt.
    env at: 'PP_TASK_DESC' put: taskDescription.
    env at: 'PP_OUTPUT_FILE' put: outputFile.

    "Build sh -c command that runs claude with stream-json output redirected to file.
     We reference env vars instead of inlining the system prompt to avoid quoting hell."
    shellCmd := 'claude --output-format stream-json --verbose --system-prompt "$PP_SYSTEM_PROMPT" --allowedTools Bash,Read,Write,Edit,Glob,Grep --max-turns 200 -p "$PP_TASK_DESC" > "$PP_OUTPUT_FILE" 2>&1'.

    "Wrap with 30-minute timeout to prevent silent hangs"
    timeoutArgs := Array new: 0.
    timeoutArgs := timeoutArgs copyWith: '1800'.
    timeoutArgs := timeoutArgs copyWith: 'sh'.
    timeoutArgs := timeoutArgs copyWith: '-c'.
    timeoutArgs := timeoutArgs copyWith: shellCmd.
    process := ExternalProcess command: 'timeout'.
    process args: timeoutArgs.
    process env: env.
    process dir: workDir.

    process run.

    "Report output file path"
    ('Session output: ', outputFile) println.

    "Check result"
    process isSuccess ifTrue: [
      ('Harness completed: ', taskId) println
    ] ifFalse: [
      ('Harness failed: ', taskId, ' (exit ', process exitCode printString, ')') println.
      ('stderr: ', process stderr) println
    ]
  ]

  method: gitDiffSummaryFor: aWorkDir [
    "Produce a git diff summary for a worktree so a reviewer can see what
     changed without having to discover it. Diffs the current HEAD against
     main (the standard base for feature worktrees). Stderr is suppressed
     via a subshell so missing-branch errors do not leak into the prompt.
     Returns an empty string if nothing changed or git is unavailable."
    | committed uncommitted commits result |
    committed := Shell capture: '(git -C "', aWorkDir, '" diff --stat main...HEAD 2>/dev/null)'.
    uncommitted := Shell capture: '(git -C "', aWorkDir, '" diff --stat HEAD 2>/dev/null)'.
    commits := Shell capture: '(git -C "', aWorkDir, '" log --oneline main..HEAD 2>/dev/null)'.
    result := ''.
    committed isEmpty ifFalse: [
      result := result, 'Files changed vs main:
', committed, '
'
    ].
    uncommitted isEmpty ifFalse: [
      result := result, '
Uncommitted changes:
', uncommitted, '
'
    ].
    commits isEmpty ifFalse: [
      result := result, '
Commits in this branch:
', commits
    ].
    ^result
  ]

  method: printString [
    ^'ClaudeHarness(', role name, ':', taskId, ')'
  ]
