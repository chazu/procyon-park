"Base role definition for Procyon Park agents.
 Each role defines a system prompt, context constraints, and pp commands."

Role subclass: Object
  instanceVars: name description systemPromptTemplate contextConstraints ppCommands

  "--- Class-side protocol: subclasses override these ---"

  classMethod: roleName [ ^'role' ]
  classMethod: roleDescription [ ^'Override roleDescription in subclass.' ]
  classMethod: rolePpCommands [ ^#() ]
  classMethod: hardCategories [ ^#() ]
  classMethod: softCategories [ ^#() ]
  classMethod: contextBudget [ ^50 ]

  classMethod: new [
    "Template method: builds a Role from class-side protocol overrides."
    | r hard soft constraints |
    r := super new.
    r name: self roleName.
    r description: self roleDescription.
    r ppCommands: self rolePpCommands.

    hard := self buildConstraintSpecs: self hardCategories.
    soft := self buildConstraintSpecs: self softCategories.

    constraints := Dictionary new.
    constraints at: 'hard' put: hard.
    constraints at: 'soft' put: soft.
    constraints at: 'budget' put: self contextBudget.
    r contextConstraints: constraints.

    ^r
  ]

  classMethod: buildConstraintSpecs: categories [
    "Convert an array of category strings into constraint spec dictionaries."
    | specs |
    specs := Array new: 0.
    categories do: [:cat |
      | h |
      h := Dictionary new.
      h at: 'category' put: cat.
      specs := specs copyWith: h
    ].
    ^specs
  ]

  "--- Instance accessors ---"

  method: name [ ^name ]
  method: description [ ^description ]
  method: systemPromptTemplate [ ^systemPromptTemplate ]
  method: contextConstraints [ ^contextConstraints ]
  method: ppCommands [ ^ppCommands ]

  method: name: n [ name := n ]
  method: description: d [ description := d ]
  method: systemPromptTemplate: t [ systemPromptTemplate := t ]
  method: contextConstraints: c [ contextConstraints := c ]
  method: ppCommands: p [ ppCommands := p ]

  method: primeFor: taskDescription context: contextTuples [
    "Backward compat: no workdir boundary."
    ^self primeFor: taskDescription context: contextTuples workDir: nil repoName: nil
  ]

  method: primeFor: taskDescription context: contextTuples workDir: aWorkDir repoName: aRepoName [
    "Assemble the full system prompt for this role, given a task and context."
    | prompt |
    prompt := self systemPromptHeader.

    "Repo and workspace boundary"
    aRepoName notNil ifTrue: [
      prompt := prompt, '

## Repository
You are working in repository: **', aRepoName, '**'
    ].
    aWorkDir notNil ifTrue: [
      prompt := prompt, '
Working directory: ', aWorkDir, '

## WORKSPACE BOUNDARY (ENFORCED)
You MUST only create, modify, or delete files within:
  ', aWorkDir, '

You MUST NOT:
- Modify files outside this directory
- Use absolute paths to write elsewhere
- cd to directories outside your workspace
Violations will be detected and reverted.
'
    ].

    prompt := prompt, '

## Your Task
', taskDescription, '

## Context from the Knowledge Base
'.
    contextTuples do: [:t |
      | cat ident payload |
      cat := t at: 'category' ifAbsent: ['?'].
      ident := t at: 'identity' ifAbsent: ['?'].
      payload := t at: 'payload' ifAbsent: [Dictionary new].
      prompt := prompt, '
### [', cat, '] ', ident, '
', (payload at: 'detail' ifAbsent: [Json encode: payload]), '
'
    ].

    prompt := prompt, '

## Commands
', self commandReference, '

## Rules (in priority order)
1. MUST commit all code changes before dismissing (git add + git commit).
2. MUST NOT modify files outside your working directory.
3. MUST NOT coordinate with other agents directly — all coordination flows through pp.
4. MUST report unexpected findings via pp observe.
5. MUST follow the completion steps below exactly, in order.

## Completion Steps
', self completionInstructions.

    ^prompt
  ]

  method: commandReference [
    | ref |
    ref := ''.
    ppCommands do: [:cmd |
      ref := ref, '  ', cmd, '
'
    ].
    ^ref
  ]

  method: systemPromptHeader [
    ^'You are a ', name, ' agent in the Procyon Park orchestration system.

', description
  ]

  method: completionInstructions [
    "Subclasses override this for role-specific completion behavior."
    ^'1. git add -A && git commit -m "<summary of changes>"
2. pp dismiss'
  ]

  method: assembleContext: bbs scope: scope taskId: taskId [
    "Backward compat: no workflow filtering."
    ^self assembleContext: bbs scope: scope taskId: taskId workflowInstance: ''
  ]

  method: assembleContext: bbs scope: scope taskId: taskId workflowInstance: wfInstance [
    "Assemble context tuples from the BBS based on this role''s constraints.
     When wfInstance is non-empty, tuples with a workflow_instance field are
     filtered to only include those belonging to this workflow.

     Per-category recency cap: instead of including every tuple in a hard
     category (which lets stale observations from earlier pipeline cycles
     crowd out fresh ones), each category contributes only the N most recent
     tuples. The BBS index is append-ordered by monotonic id, so the tail of
     a scan is the most recent slice. N is computed per category from the
     remaining budget so hard and soft categories share fairly."
    | hard soft budget result conventions remaining totalCats perCatHard perCatSoft take |
    hard := contextConstraints at: 'hard' ifAbsent: [#()].
    soft := contextConstraints at: 'soft' ifAbsent: [#()].
    budget := contextConstraints at: 'budget' ifAbsent: [50].
    result := Array new: 0.

    "Always include conventions (global, not workflow-scoped)"
    conventions := bbs scanAll: 'convention'.
    result := result, conventions.

    "Compute per-category recency cap for hard categories.
     Split the post-conventions budget evenly across all constrained categories
     so a few noisy categories (e.g. observation) cannot starve the rest."
    remaining := budget - result size.
    totalCats := hard size + soft size.
    perCatHard := 3.
    (hard size > 0 and: [remaining > 0]) ifTrue: [
      perCatHard := (remaining + totalCats - 1) // totalCats.
      perCatHard < 3 ifTrue: [perCatHard := 3]
    ].

    "Hard constraints — include N most recent per category, filtered by workflow."
    hard do: [:spec |
      | cat tuples recent |
      cat := spec at: 'category'.
      tuples := bbs scan: cat scope: scope.
      tuples := self filterByWorkflow: tuples instance: wfInstance.
      recent := self mostRecent: tuples count: perCatHard.
      result := result, recent
    ].

    "Soft constraints — N most recent per category, bounded by remaining budget."
    remaining := budget - result size.
    (soft size > 0 and: [remaining > 0]) ifTrue: [
      perCatSoft := (remaining + soft size - 1) // soft size.
      perCatSoft < 1 ifTrue: [perCatSoft := 1].
      soft do: [:spec |
        remaining > 0 ifTrue: [
          | cat tuples recent |
          cat := spec at: 'category'.
          tuples := bbs scan: cat scope: scope.
          tuples := self filterByWorkflow: tuples instance: wfInstance.
          take := perCatSoft.
          take > remaining ifTrue: [take := remaining].
          recent := self mostRecent: tuples count: take.
          result := result, recent.
          remaining := budget - result size
        ]
      ]
    ].

    ^result
  ]

  method: mostRecent: tuples count: n [
    "Return the n most recently appended tuples from a scan result.
     The BBS index preserves append order (monotonic id), so recency-descending
     means the last n entries. Returns the input unchanged when it already fits."
    | size start |
    n <= 0 ifTrue: [^Array new: 0].
    size := tuples size.
    size <= n ifTrue: [^tuples].
    start := size - n.
    "copyFrom:to: upper bound is exclusive (Go-style): size yields size-1 inclusive."
    ^tuples copyFrom: start to: size
  ]

  method: filterByWorkflow: tuples instance: wfInstance [
    "Filter tuples: if wfInstance is set, only include tuples that either
     have no workflow_instance field (global) or match this workflow.
     If wfInstance is empty, return all tuples unfiltered."
    wfInstance isEmpty ifTrue: [^tuples].
    ^tuples select: [:t |
      | payload tWf |
      payload := t at: 'payload' ifAbsent: [Dictionary new].
      tWf := payload at: 'workflow_instance' ifAbsent: [''].
      tWf isEmpty or: [tWf = wfInstance]
    ]
  ]
