"""
ProcyonPark entry point.

Loaded by the pp binary on startup.
"""
namespace: 'ProcyonPark'

Main subclass: Object

  """Entry point for procyon-park daemon and CLI."""
  class method: start [
      ^'ProcyonPark v0.1.0'
  ]

  """Return the current version string."""
  class method: version [
      ^'0.1.0'
  ]
