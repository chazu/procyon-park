"Procyon Park — Agent Orchestration System
 Binary: pp
 Usage: pp <command> [args...]"

Main subclass: Object

  classMethod: ppCommands [
    "Commands that route to PP (thin HTTP client)."
    ^#('observe' 'decide' 'event' 'plan' 'read' 'notify' 'dismiss'
       'status' 'prime' 'task' 'workflow' 'signal' 'verdict' 'log' 'history' 'dashboard'
       'workitem' 'gc' 'session' 'usage' 'identity' 'worker' 'user')
  ]

  classMethod: start [
    | args cmd wtArgs |
    args := System args.

    args isEmpty ifTrue: [
      self printUsage.
      ^self
    ].

    cmd := args at: 0.

    "GC (before server to stay within bytecode limit). When PP_USE_CLI
     is active we route to the new framework first; otherwise fall
     through to the legacy dispatcher unchanged."
    cmd = 'gc' ifTrue: [
      (CliPP enabled and: [CliPP handles: args]) ifTrue: [^CliPP runWith: args].
      ^PP new runWith: args
    ].

    "Server"
    cmd = 'serve' ifTrue: [^self startServer: (args copyFrom: 1)].

    "PoC: when PP_USE_CLI=1 is set, route the ported subcommands
     (status, workflow list, log, prime, gc) through the new Maggie
     Cli framework. Everything else falls through to the existing
     dispatcher unchanged."
    (CliPP enabled and: [CliPP handles: args]) ifTrue: [
      ^CliPP runWith: args
    ].

    "Agent communication (thin HTTP client commands)"
    (self ppCommands includes: cmd) ifTrue: [^PP new runWith: args].

    "Repo management"
    cmd = 'repo' ifTrue: [^Repo new runWith: args].
    cmd = 'clean-branches' ifTrue: [
      wtArgs := Array new: 0.
      wtArgs := wtArgs copyWith: 'repo'.
      wtArgs := wtArgs copyWith: 'clean-branches'.
      args size > 1 ifTrue: [
        (args copyFrom: 1) do: [:a | wtArgs := wtArgs copyWith: a]
      ].
      ^Repo new runWith: wtArgs
    ].
    cmd = 'worktree' ifTrue: [
      wtArgs := Array new: 0.
      wtArgs := wtArgs copyWith: 'repo'.
      args do: [:a | wtArgs := wtArgs copyWith: a].
      ^Repo new runWith: wtArgs
    ].

    "Help"
    (cmd = 'help' or: [cmd = '--help' or: [cmd = '-h']])
      ifTrue: [^self printUsage].

    "Version"
    (cmd = 'version' or: [cmd = '--version'])
      ifTrue: [^self printVersion].

    ('Unknown command: ', cmd) println.
    '' println.
    self printUsage
  ]

  classMethod: printVersion [
    'pp v0.1.0 (Procyon Park)' println
  ]

  classMethod: printUsage [
    'pp — Procyon Park Agent Orchestration' println.
    '' println.
    'Usage: pp <command> [args...]' println.
    '' println.
    'Server:' println.
    '  serve [--port 7777]                            Start the Procyon Park server' println.
    '' println.
    'Agent Commands (talk to a running server):' println.
    '  observe  <identity> <detail> [--tags t1,t2]    Report an observation' println.
    '  decide   <identity> <detail> [--rationale ..]  Record a decision' println.
    '  event    <identity> [--type T] [--summary S]   Emit an event' println.
    '  plan     <file.json>                           Submit a structured plan' println.
    '  read     <category> [scope] [identity]         Read tuples' println.
    '  notify   <message> [--severity info|warn|urgent] Notify the user' println.
    '  dismiss                                        Signal task completion' println.
    '  status                                         Show system status' println.
    '  prime    [--role <role>]                        Output agent priming context' println.
    '  task     <id> --role <r> --description <d>     Create a task' println.
    '  workflow <template> [--param key=val ...]       Start a workflow' println.
    '  workflow status [<id>]                         Show workflow status' println.
    '  workflow list [--status running|completed|failed] Tabular listing of workflows' println.
    '  workflow cancel <id> [--scope <scope>]         Cancel a running workflow' println.
    '  workflow wait <id> [--timeout <secs>]          Block until workflow completes' println.
    '  signal   <id> <key> <value>                    Upsert a signal' println.
    '  verdict  <pass|fix|exhausted> [--workflow <id>] Write review verdict (uses PP_WORKFLOW)' println.
    '  repo     add|list|remove|info                  Manage repositories' println.
    '  worktree list|clean                            Manage worktrees' println.
    '  clean-branches [--dry-run] [--all]             Remove stale branches' println.
    '  log      [--since <secs>] [--no-follow]        Tail notification stream' println.
    '  history   [--since S] [--limit N] [--op O] [--category C] [--scope S] [--identity I] Query audit log' println.
    '  dashboard                                      Open web dashboard in browser' println.
    '  workitem create|show|list|update|run|plan|review  Manage work items' println.
    '  gc       [--dry-run]                             Garbage-collect finished workflows & branches' println.
    '  identity <init|show|rotate|list> [args...]     Manage local keypairs' println.
    '  user     <add|revoke> <name> [--pubkey <hex>]   Admin-gated user registry' println.
    '  session  [<taskId>]                              View Claude Code session logs' println.
    '  usage    [<taskId>] [--json]                     Report current session token consumption' println.
    '' println.
    'Other:' println.
    '  help, --help, -h                               Show this help' println.
    '  version, --version                             Show version' println.
    '' println.
    'Environment:' println.
    '  PP_URL    Server URL for agent commands (default: http://localhost:7777)' println.
    '  PP_SCOPE  Default scope for agent commands (default: default)' println.
    '  PP_TASK   Current task ID (set by harness when spawning agents)' println.
    '  PP_PORT   Server port for pp serve (default: 7777)' println
  ]

  "--- Server ---"

  classMethod: startServer: args [
    | bbs api dispatcher harnessFactory port portStr |

    'Procyon Park v0.1.0' println.
    '===================' println.

    "Parse flags"
    port := 7777.
    portStr := self flagValue: '--port' in: args.
    portStr notNil ifTrue: [port := portStr asInteger].

    "Initialize BBS"
    bbs := BBS new.
    'BBS initialized.' println.

    "Seed system conventions and templates (skips if already present from persistence)"
    (bbs scanAll: 'convention') size = 0 ifTrue: [
      self seedConventions: bbs
    ] ifFalse: [
      'System conventions loaded from disk.' println
    ].
    "Always load templates fresh from CUE files (templates are source code, not runtime state)"
    (bbs scanAll: 'template') do: [:t |
      bbs inp: 'template' scope: (t at: 'scope') identity: (t at: 'identity')
    ].
    self seedTemplates: bbs.

    "Initialize harness factory"
    harnessFactory := HarnessFactory new.

    "Initialize dispatcher (8 slots to accommodate foreman + parallel implementers)"
    dispatcher := Dispatcher on: bbs harnessFactory: harnessFactory maxSlots: 8.

    "Initialize HTTP API (with dispatcher reference for workflow endpoints)"
    api := ApiServer on: port bbs: bbs dispatcher: dispatcher.

    "Validate registered repos"
    Repo new validateAll.

    "Start dispatcher (runs in background process)"
    dispatcher start.

    "Start API server (blocks)"
    api start.

    "Reaching here means server stopped"
    dispatcher stop
  ]

  classMethod: flagValue: flag in: args [
    | idx |
    idx := args indexOf: flag.
    (idx >= 0 and: [idx < (args size - 1)])
      ifTrue: [^args at: idx + 1]
      ifFalse: [^nil]
  ]

  classMethod: seedConventions: bbs [
    | payload |

    payload := Dictionary new.
    payload at: 'detail' put: 'All agent communication goes through the pp CLI tool. Do not attempt direct coordination between agents.'.
    bbs outPinned: 'convention' scope: 'system' identity: 'communication' payload: payload.

    payload := Dictionary new.
    payload at: 'detail' put: 'Report unexpected findings as observations using pp observe. These may be promoted to facts if corroborated by multiple agents.'.
    bbs outPinned: 'convention' scope: 'system' identity: 'observations' payload: payload.

    payload := Dictionary new.
    payload at: 'detail' put: 'When your task is done, always run pp dismiss to signal completion. This allows the system to advance workflows and free resources.'.
    bbs outPinned: 'convention' scope: 'system' identity: 'completion' payload: payload.

    payload := Dictionary new.
    payload at: 'detail' put: 'Stay tightly scoped to your assigned task. Do not modify code outside your task boundary unless absolutely necessary.'.
    bbs outPinned: 'convention' scope: 'system' identity: 'scope' payload: payload.

    'System conventions seeded.' println
  ]

  classMethod: seedTemplates: bbs [
    | loader repos |
    loader := TemplateLoader new.
    repos := loader allRepoConfigs.
    loader seedAll: bbs repos: repos
  ]
