"Valid enum values for work item fields.
 Used to validate server-side payloads on /api/workitem/create and similar."

WorkItemFields subclass: Object

  classMethod: validTypes [
    ^#('epic' 'story')
  ]

  classMethod: validStatuses [
    ^#('backlog' 'ready' 'in-progress' 'done' 'blocked' 'cancelled')
  ]

  classMethod: validEstimates [
    ^#('small' 'medium' 'large')
  ]

  classMethod: isValidType: aString [
    ^self validTypes includes: aString
  ]

  classMethod: isValidStatus: aString [
    ^self validStatuses includes: aString
  ]

  classMethod: isValidEstimate: aString [
    ^self validEstimates includes: aString
  ]

  classMethod: validTypesDisplay [
    "Human-readable list of valid types for error messages."
    ^'epic, story'
  ]

  classMethod: validStatusesDisplay [
    "Human-readable list of valid statuses for error messages."
    ^'backlog, ready, in-progress, done, blocked, cancelled'
  ]

  classMethod: validEstimatesDisplay [
    "Human-readable list of valid estimates for error messages."
    ^'small, medium, large'
  ]
