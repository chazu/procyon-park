"Tests for PPDashboardModel — thread-safe polling with fetchDataSnapshot/applySnapshot.
 Verifies:
   - Initial state (empty arrays, connected=false)
   - fetchDataSnapshot returns a snapshot Dictionary
   - applySnapshot populates model fields and sends fine-grained aspects
   - Exception handling in fetchDataSnapshot sets connected=false
   - Recovery after error

 All temp vars at method top. Uses [block] fork not Process fork:."

"--- Mock HTTP Client ---"
MockDashboardHttpClient subclass: Object
  instanceVars: responses shouldFail

  classMethod: new [
    | instance |
    instance := super new.
    instance init.
    ^instance
  ]

  method: init [
    responses := Dictionary new.
    shouldFail := false
  ]

  method: setResponse: url to: body [
    responses at: url put: body
  ]

  method: shouldFail: aBoolean [
    shouldFail := aBoolean
  ]

  method: get: url [
    | resp |
    shouldFail ifTrue: [
      Exception signal: 'Mock HTTP error'
    ].
    resp := responses at: url ifAbsent: [nil].
    resp ifNil: [Exception signal: 'No mock response for: ', url].
    ^resp
  ]

"--- Mock Dependent (to verify changed: notifications) ---"
MockDashboardDependent subclass: Object
  instanceVars: aspects updateCount

  classMethod: new [
    | instance |
    instance := super new.
    instance init.
    ^instance
  ]

  method: init [
    aspects := Array new: 0.
    updateCount := 0
  ]

  method: update: aspect [
    aspects := aspects copyWith: aspect.
    updateCount := updateCount + 1
  ]

  method: aspects [ ^aspects ]
  method: updateCount [ ^updateCount ]

  method: hasAspect: anAspect [
    aspects do: [:a | a = anAspect ifTrue: [^true]].
    ^false
  ]

"--- Test Suite ---"
TestDashboardModel subclass: Object

  classMethod: run: t [
    | model mockClient mockDep dashJson snapshot |

    "--- DM1: Initial state ---"
    model := PPDashboardModel new.
    t assert: model connected = false message: 'DM1a: connected initially false'.
    t assert: model workflows size = 0 message: 'DM1b: workflows initially empty'.
    t assert: model tasks size = 0 message: 'DM1c: tasks initially empty'.
    t assert: model tokens size = 0 message: 'DM1d: tokens initially empty'.
    t assert: model notifications size = 0 message: 'DM1e: notifications initially empty'.
    t assert: model baseUrl = 'http://localhost:7777' message: 'DM1f: baseUrl default'.

    "--- DM2: fetchDataSnapshot returns a snapshot without mutating model ---"
    model := PPDashboardModel new.
    mockClient := MockDashboardHttpClient new.
    model client: mockClient.

    dashJson := '{"workflows":[{"identity":"wf-1"}],"tasks":[{"identity":"t-1"},{"identity":"t-2"}],"tokens":[{"identity":"tok-1"}],"notifications":[{"identity":"n-1"}],"health":{"tuples":42,"uptime":10}}'.
    mockClient setResponse: 'http://localhost:7777/api/dashboard' to: dashJson.

    snapshot := model fetchDataSnapshot.

    "Model should NOT be mutated by fetchDataSnapshot"
    t assert: model workflows size = 0 message: 'DM2a: model workflows still empty after snapshot'.
    t assert: (snapshot at: 'connected' ifAbsent: [false]) = true message: 'DM2b: snapshot connected true'.
    t assert: (snapshot at: 'workflows' ifAbsent: [#()]) size = 1 message: 'DM2c: snapshot has workflows'.
    t assert: (snapshot at: 'tasks' ifAbsent: [#()]) size = 2 message: 'DM2d: snapshot has tasks'.

    "--- DM3: applySnapshot populates model and sends fine-grained aspects ---"
    model := PPDashboardModel new.
    mockDep := MockDashboardDependent new.
    model addDependent: mockDep.

    model applySnapshot: snapshot.

    t assert: model connected = true message: 'DM3a: connected true after apply'.
    t assert: model workflows size = 1 message: 'DM3b: workflows populated'.
    t assert: model tasks size = 2 message: 'DM3c: tasks populated'.
    t assert: model tokens size = 1 message: 'DM3d: tokens populated'.
    t assert: model notifications size = 1 message: 'DM3e: notifications populated'.
    t assert: (mockDep hasAspect: #workflows) message: 'DM3f: #workflows aspect sent'.
    t assert: (mockDep hasAspect: #tasks) message: 'DM3g: #tasks aspect sent'.
    t assert: (mockDep hasAspect: #notifications) message: 'DM3h: #notifications aspect sent'.
    t assert: (mockDep hasAspect: #health) message: 'DM3i: #health aspect sent'.

    "--- DM4: Exception in fetchDataSnapshot sets connected=false ---"
    model := PPDashboardModel new.
    mockClient := MockDashboardHttpClient new.
    model client: mockClient.
    mockClient shouldFail: true.

    snapshot := model fetchDataSnapshot.
    t assert: (snapshot at: 'connected' ifAbsent: [true]) = false message: 'DM4a: snapshot connected false on error'.

    model applySnapshot: snapshot.
    t assert: model connected = false message: 'DM4b: connected false after apply'.

    "--- DM5: Recovery after error ---"
    mockClient shouldFail: false.
    dashJson := '{"workflows":[{"identity":"wf-r"}],"tasks":[],"tokens":[],"notifications":[],"health":{"tuples":1,"uptime":1}}'.
    mockClient setResponse: 'http://localhost:7777/api/dashboard' to: dashJson.

    snapshot := model fetchDataSnapshot.
    model applySnapshot: snapshot.

    t assert: model connected = true message: 'DM5a: connected true after recovery'.
    t assert: model workflows size = 1 message: 'DM5b: workflows populated after recovery'
  ]

"--- Entry Point ---"
TestDashboardModelMain subclass: Object

  classMethod: run [
    | t |
    t := WRT new.
    '=== Dashboard Model Tests ===' println.
    [
      TestDashboardModel run: t
    ] on: Exception do: [:e |
      t assert: false message: ('TestDashboardModel crashed: ', e messageText)
    ].
    t report
  ]
