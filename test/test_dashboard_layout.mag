"Tests for PPDashboardLayout — master-detail layout with keyboard navigation.
 Verifies:
   DL1: q key (keyRune + rune 113) exits app
   DL2: Non-q keyRune does NOT exit app
   DL3: Tab cycles focus across 3 children (header, middleSplit, activityFeed)
   DL4: Arrow keys navigate within focused list
   DL5: Workflow selection updates detail pane

 All temp vars at method top. Uses Array new: 0 and copyWith:."

import: 'Alto'

"--- Mock App for testing ---"
MockDashApp subclass: Object
  instanceVars: stopped

  classMethod: new [
    | instance |
    instance := super new.
    instance init.
    ^instance
  ]

  method: init [
    stopped := false
  ]

  method: stop [
    stopped := true
  ]

  method: stopped [
    ^stopped
  ]

  method: display [
    ^self
  ]

  method: running [
    ^stopped not
  ]

"--- Mock KeyEvent for testing ---"
MockKeyEvt subclass: Object
  instanceVars: key rune

  classMethod: key: aKey rune: aRune [
    | instance |
    instance := super new.
    instance initKey: aKey rune: aRune.
    ^instance
  ]

  method: initKey: aKey rune: aRune [
    key := aKey.
    rune := aRune
  ]

  method: isKey [ ^true ]
  method: isMouse [ ^false ]
  method: key [ ^key ]
  method: rune [ ^rune ]
  method: mod [ ^0 ]

  method: at: aKey ifAbsent: aBlock [
    aKey = 'type' ifTrue: [^'key'].
    aKey = 'key' ifTrue: [^key].
    aKey = 'rune' ifTrue: [^rune].
    aKey = 'mod' ifTrue: [^0].
    ^aBlock value
  ]

  method: at: aKey [
    ^self at: aKey ifAbsent: [nil]
  ]

"--- Test Runner ---"
DLT subclass: Object
  instanceVars: passed failed failures

  classMethod: new [
    | r |
    r := super new.
    r init.
    ^r
  ]

  method: init [
    passed := 0.
    failed := 0.
    failures := Array new: 0
  ]

  method: assert: condition message: msg [
    condition ifTrue: [
      passed := passed + 1
    ] ifFalse: [
      failed := failed + 1.
      failures := failures copyWith: msg.
      ('FAIL: ', msg) println
    ]
  ]

  method: assertEqual: actual to: expected message: msg [
    | fullMsg |
    (actual = expected) ifTrue: [
      passed := passed + 1
    ] ifFalse: [
      failed := failed + 1.
      fullMsg := msg, ' (expected: ', expected printString, ', got: ', actual printString, ')'.
      failures := failures copyWith: fullMsg.
      ('FAIL: ', fullMsg) println
    ]
  ]

  method: report [
    '' println.
    ('Dashboard Layout Tests: ', passed printString, ' passed, ', failed printString, ' failed') println.
    failed > 0 ifTrue: [
      'Failures:' println.
      failures do: [:f | ('  - ', f) println]
    ]
  ]


"--- Helper to build a test layout matching the new master-detail structure ---"
TestDashLayoutHelper subclass: Object

  classMethod: buildTestLayout [
    "Build a PPDashboardLayout with the new 3-pane structure and return a dictionary of refs."
    | layout mockApp header masterList detailList activityList middleSplit model workflowHelper refs |
    mockApp := MockDashApp new.

    header := Alto::Label new.
    header text: 'Test Header | q to quit'.

    masterList := Alto::ListView items: #() onSelect: [:item | ].
    detailList := Alto::ListView items: #('(select a workflow)') onSelect: [:item | ].
    activityList := Alto::ListView items: #() onSelect: [:item | ].

    "Middle horizontal split"
    middleSplit := Alto::BoxLayout horizontal.
    middleSplit addChild: masterList weight: 2.
    middleSplit addChild: detailList weight: 3.

    layout := PPDashboardLayout vertical.
    layout addChild: header weight: 1.
    layout addChild: middleSplit weight: 7.
    layout addChild: activityList weight: 3.

    layout app: mockApp.

    model := PPDashboardModel new.
    layout model: model.

    workflowHelper := PPWorkflowHelper setupMaster: masterList detail: detailList model: model.
    layout workflowHelper: workflowHelper.

    refs := Dictionary new.
    refs at: 'layout' put: layout.
    refs at: 'app' put: mockApp.
    refs at: 'header' put: header.
    refs at: 'masterList' put: masterList.
    refs at: 'detailList' put: detailList.
    refs at: 'activityList' put: activityList.
    refs at: 'middleSplit' put: middleSplit.
    refs at: 'model' put: model.
    refs at: 'workflowHelper' put: workflowHelper.
    ^refs
  ]


"--- Tests ---"

TestDashboardLayout subclass: Object

  classMethod: run [
    | t |
    t := DLT new.
    self testQKeyExitsApp: t.
    self testNonQRuneDoesNotExit: t.
    self testTabCyclesFocus: t.
    self testArrowKeysNavigateMasterList: t.
    self testWorkflowSelectionUpdatesDetail: t.
    t report
  ]

  classMethod: testQKeyExitsApp: t [
    "DL1: q key (keyRune=256, rune=113) should call app stop."
    | refs layout mockApp evt |
    refs := TestDashLayoutHelper buildTestLayout.
    layout := refs at: 'layout'.
    mockApp := refs at: 'app'.
    evt := MockKeyEvt key: 256 rune: 113.
    layout handleEvent: evt.
    t assert: mockApp stopped message: 'DL1: q key should stop app'
  ]

  classMethod: testNonQRuneDoesNotExit: t [
    "DL2: A non-q rune key (e.g. 'a' = rune 97) should NOT stop app."
    | refs layout mockApp evt |
    refs := TestDashLayoutHelper buildTestLayout.
    layout := refs at: 'layout'.
    mockApp := refs at: 'app'.
    evt := MockKeyEvt key: 256 rune: 97.
    layout handleEvent: evt.
    t assert: mockApp stopped not message: 'DL2: non-q rune should not stop app'
  ]

  classMethod: testTabCyclesFocus: t [
    "DL3: Tab key cycles focusedIndex through 0,1,2,0 (header, middle, activity)."
    | refs layout tabEvt idx0 idx1 idx2 idx3 |
    refs := TestDashLayoutHelper buildTestLayout.
    layout := refs at: 'layout'.
    tabEvt := MockKeyEvt key: 9 rune: 0.
    idx0 := layout focusedIndex.
    layout handleEvent: tabEvt.
    idx1 := layout focusedIndex.
    layout handleEvent: tabEvt.
    idx2 := layout focusedIndex.
    layout handleEvent: tabEvt.
    idx3 := layout focusedIndex.
    t assertEqual: idx0 to: 0 message: 'DL3: initial focus at 0'.
    t assertEqual: idx1 to: 1 message: 'DL3: first Tab goes to 1 (middle split)'.
    t assertEqual: idx2 to: 2 message: 'DL3: second Tab goes to 2 (activity feed)'.
    t assertEqual: idx3 to: 0 message: 'DL3: third Tab wraps to 0'
  ]

  classMethod: testArrowKeysNavigateMasterList: t [
    "DL4: Arrow keys navigate within the workflow master list."
    | refs layout masterList tabEvt downEvt wfItem1 wfItem2 items p1 p2 |
    refs := TestDashLayoutHelper buildTestLayout.
    layout := refs at: 'layout'.
    masterList := refs at: 'masterList'.

    "Add two workflow items"
    p1 := Dictionary new.
    p1 at: 'status' put: 'running'.
    p1 at: 'template' put: 'tmpl-a'.
    wfItem1 := Dictionary new.
    wfItem1 at: 'identity' put: 'wf-a'.
    wfItem1 at: 'payload' put: p1.

    p2 := Dictionary new.
    p2 at: 'status' put: 'done'.
    p2 at: 'template' put: 'tmpl-b'.
    wfItem2 := Dictionary new.
    wfItem2 at: 'identity' put: 'wf-b'.
    wfItem2 at: 'payload' put: p2.

    items := Array new: 0.
    items := items copyWith: wfItem1.
    items := items copyWith: wfItem2.
    masterList items: items.

    "Tab to middleSplit (index 1), then arrow down navigates master list inside it"
    tabEvt := MockKeyEvt key: 9 rune: 0.
    layout handleEvent: tabEvt.

    t assertEqual: masterList selectedIndex to: 0 message: 'DL4: initial selection at 0'.

    downEvt := MockKeyEvt key: 258 rune: 0.
    layout handleEvent: downEvt.
    t assertEqual: masterList selectedIndex to: 1 message: 'DL4: down arrow moves to 1'
  ]

  classMethod: testWorkflowSelectionUpdatesDetail: t [
    "DL5: Selecting a workflow updates the detail pane."
    | refs model workflowHelper detailList wfItem payload dashJson mockClient snapshot |
    refs := TestDashLayoutHelper buildTestLayout.
    model := refs at: 'model'.
    workflowHelper := refs at: 'workflowHelper'.
    detailList := refs at: 'detailList'.

    "Set up model with workflow data"
    mockClient := MockDashboardHttpClient new.
    model client: mockClient.
    dashJson := '{"workflows":[{"identity":"wf-1","payload":{"status":"running","template":"review"}}],"tasks":[{"identity":"t-1","payload":{"role":"scout","status":"active","workflow":"wf-1"}}],"tokens":[{"identity":"tok-1","payload":{"status":"active","workflow":"wf-1"}}],"notifications":[],"health":{"tuples":5,"uptime":10}}'.
    mockClient setResponse: 'http://localhost:7777/api/dashboard' to: dashJson.
    snapshot := model fetchDataSnapshot.
    model applySnapshot: snapshot.

    "Detail should have content now (since workflow is selected by rebuildMasterList)"
    t assert: detailList items size > 1 message: 'DL5: detail pane has content after workflow data loaded'
  ]


"--- Entry Point ---"
TestDashboardLayoutMain subclass: Object
  classMethod: run [
    'Running Dashboard Layout Tests...' println.
    TestDashboardLayout run
  ]
