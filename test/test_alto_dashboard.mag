"Comprehensive tests for Alto TUI Dashboard — refactored architecture.
 Tests from spec, not implementation. Verifies what the code should do.

 Stories covered:
   Story 1: PPDashboardModel — data model with fetchDataSnapshot/applySnapshot
   Story 2: PPHeaderUpdater — header status bar with summary counts
   Story 3: PPWorkflowHelper — master list + detail pane binding
   Story 4: PPActivityFeed — notification formatting
   Story 5: PPDashboardLayout — keyboard navigation

 All temp vars at method top. Uses [block] fork not Process fork:.
 Uses Array new: 0 and copyWith: for array building."

import: 'Alto'

"=== Test Runner (shared across all test classes) ==="
ADT subclass: Object
  instanceVars: passed failed failures

  classMethod: new [
    | r |
    r := super new.
    r init.
    ^r
  ]

  method: init [
    passed := 0.
    failed := 0.
    failures := Array new: 0
  ]

  method: assert: condition message: msg [
    condition ifTrue: [
      passed := passed + 1
    ] ifFalse: [
      failed := failed + 1.
      failures := failures copyWith: msg.
      ('  FAIL: ', msg) println
    ]
  ]

  method: assertEqual: actual to: expected message: msg [
    | fullMsg |
    (actual = expected) ifTrue: [
      passed := passed + 1
    ] ifFalse: [
      failed := failed + 1.
      fullMsg := msg, ' (expected: ', expected printString, ', got: ', actual printString, ')'.
      failures := failures copyWith: fullMsg.
      ('  FAIL: ', fullMsg) println
    ]
  ]

  method: report [
    '' println.
    ('=== Alto Dashboard Tests: ', passed printString, ' passed, ', failed printString, ' failed ===') println.
    (failed > 0) ifTrue: [
      'Failures:' println.
      failures do: [:f | ('  - ', f) println]
    ].
    (failed = 0)
      ifTrue: [ 'ALL TESTS PASSED' println ]
      ifFalse: [ 'SOME TESTS FAILED' println ]
  ]

  method: passed [ ^passed ]
  method: failed [ ^failed ]


"=== Mock HTTP Client ==="
ADTMockHttpClient subclass: Object
  instanceVars: responses shouldFail

  classMethod: new [
    | instance |
    instance := super new.
    instance init.
    ^instance
  ]

  method: init [
    responses := Dictionary new.
    shouldFail := false
  ]

  method: setResponse: url to: body [
    responses at: url put: body
  ]

  method: shouldFail: aBoolean [
    shouldFail := aBoolean
  ]

  method: get: url [
    shouldFail ifTrue: [
      Exception signal: 'Mock HTTP error'
    ].
    ^responses at: url ifAbsent: [nil]
  ]


"=== Mock Dependent (tracks changed: notifications) ==="
ADTMockDependent subclass: Object
  instanceVars: aspects updateCount

  classMethod: new [
    | instance |
    instance := super new.
    instance init.
    ^instance
  ]

  method: init [
    aspects := Array new: 0.
    updateCount := 0
  ]

  method: update: aspect [
    aspects := aspects copyWith: aspect.
    updateCount := updateCount + 1
  ]

  method: aspects [ ^aspects ]
  method: updateCount [ ^updateCount ]

  method: hasAspect: anAspect [
    aspects do: [:a | a = anAspect ifTrue: [^true]].
    ^false
  ]


"=== Mock Label ==="
ADTMockLabel subclass: Object
  instanceVars: text style

  classMethod: new [
    | instance |
    instance := super new.
    instance initMock.
    ^instance
  ]

  method: initMock [
    text := ''.
    style := nil
  ]

  method: text [ ^text ]
  method: text: aString [ text := aString ]
  method: style [ ^style ]
  method: style: aStyle [ style := aStyle ]


"=== Mock Model (for header/helper/feed tests) ==="
ADTMockModel subclass: Object
  instanceVars: dependents connectedFlag healthDict workflowData taskData tokenData notificationData

  classMethod: new [
    | instance |
    instance := super new.
    instance initMock.
    ^instance
  ]

  method: initMock [
    dependents := Array new: 0.
    connectedFlag := false.
    healthDict := Dictionary new.
    workflowData := #().
    taskData := #().
    tokenData := #().
    notificationData := #()
  ]

  method: addDependent: obj [ dependents := dependents copyWith: obj ]
  method: dependents [ ^dependents ]
  method: connected [ ^connectedFlag ]
  method: connected: aBool [ connectedFlag := aBool ]
  method: health [ ^healthDict ]
  method: health: aDict [ healthDict := aDict ]
  method: workflows [ ^workflowData ]
  method: workflows: a [ workflowData := a ]
  method: tasks [ ^taskData ]
  method: tasks: a [ taskData := a ]
  method: tokens [ ^tokenData ]
  method: tokens: a [ tokenData := a ]
  method: notifications [ ^notificationData ]
  method: notifications: a [ notificationData := a ]

  method: changed: aspect [
    dependents do: [:dep | dep update: aspect]
  ]


"=== Mock ListView ==="
ADTMockListView subclass: Object
  instanceVars: items labelBlock onSelectBlock

  classMethod: new [
    | instance |
    instance := super new.
    instance initMock.
    ^instance
  ]

  method: initMock [
    items := #().
    labelBlock := nil.
    onSelectBlock := nil
  ]

  method: items: newItems [ items := newItems ]
  method: updateItems: newItems [ items := newItems ]
  method: items [ ^items ]
  method: labelBlock: aBlock [ labelBlock := aBlock ]
  method: labelBlock [ ^labelBlock ]
  method: onSelect: aBlock [ onSelectBlock := aBlock ]
  method: onSelectBlock [ ^onSelectBlock ]
  method: selectedIndex: i [ ]


"=== Mock App ==="
ADTMockApp subclass: Object
  instanceVars: stopped

  classMethod: new [
    | instance |
    instance := super new.
    instance init.
    ^instance
  ]

  method: init [ stopped := false ]
  method: stop [ stopped := true ]
  method: stopped [ ^stopped ]
  method: display [ ^self ]
  method: running [ ^stopped not ]


"=== Mock Key Event ==="
ADTMockKeyEvt subclass: Object
  instanceVars: key rune

  classMethod: key: aKey rune: aRune [
    | instance |
    instance := super new.
    instance initKey: aKey rune: aRune.
    ^instance
  ]

  method: initKey: aKey rune: aRune [
    key := aKey.
    rune := aRune
  ]

  method: isKey [ ^true ]
  method: isMouse [ ^false ]
  method: key [ ^key ]
  method: rune [ ^rune ]
  method: mod [ ^0 ]


"=== ADTSafeHeaderUpdater — subclass of PPHeaderUpdater that skips Go::Terminal ==="
ADTSafeHeaderUpdater subclass: PPHeaderUpdater

  method: applyStyle [
    "No-op: skip Go::Terminal in tests"
  ]


"=== Helper: BBS tuple builder ==="
ADTTupleBuilder subclass: Object

  classMethod: workflow: identity status: status template: template [
    | payload tuple |
    payload := Dictionary new.
    payload at: 'status' put: status.
    payload at: 'template' put: template.
    tuple := Dictionary new.
    tuple at: 'identity' put: identity.
    tuple at: 'payload' put: payload.
    ^tuple
  ]

  classMethod: task: identity role: role status: status workflow: wf [
    | payload tuple |
    payload := Dictionary new.
    payload at: 'role' put: role.
    payload at: 'status' put: status.
    payload at: 'workflow' put: wf.
    tuple := Dictionary new.
    tuple at: 'identity' put: identity.
    tuple at: 'payload' put: payload.
    ^tuple
  ]

  classMethod: token: identity status: tokenStatus workflow: wf [
    | payload tuple |
    payload := Dictionary new.
    payload at: 'status' put: tokenStatus.
    payload at: 'workflow' put: wf.
    tuple := Dictionary new.
    tuple at: 'identity' put: identity.
    tuple at: 'payload' put: payload.
    ^tuple
  ]

  classMethod: notification: severity message: message [
    | payload tuple |
    payload := Dictionary new.
    payload at: 'severity' put: severity.
    payload at: 'message' put: message.
    tuple := Dictionary new.
    tuple at: 'payload' put: payload.
    ^tuple
  ]


"========================================================
 STORY 1 TESTS: PPDashboardModel (fetchDataSnapshot / applySnapshot)
 ========================================================"
TestADTModel subclass: Object

  classMethod: run: t [
    '--- Story 1: PPDashboardModel ---' println.
    self testInitialState: t.
    self testFetchDataSnapshotReturnsSnapshot: t.
    self testApplySnapshotPopulatesModel: t.
    self testFineGrainedAspects: t.
    self testExceptionSetsDisconnected: t.
    self testRecoveryAfterError: t.
    self testClientInjection: t.
    self testDefaultBaseUrl: t
  ]

  classMethod: testInitialState: t [
    | model |
    model := PPDashboardModel new.
    t assert: model connected = false message: 'S1-1a: connected initially false'.
    t assert: model workflows size = 0 message: 'S1-1b: workflows initially empty'.
    t assert: model tasks size = 0 message: 'S1-1c: tasks initially empty'.
    t assert: model tokens size = 0 message: 'S1-1d: tokens initially empty'.
    t assert: model notifications size = 0 message: 'S1-1e: notifications initially empty'
  ]

  classMethod: testFetchDataSnapshotReturnsSnapshot: t [
    | model mockClient dashJson snapshot |
    model := PPDashboardModel new.
    mockClient := ADTMockHttpClient new.
    model client: mockClient.
    dashJson := '{"workflows":[{"identity":"wf-1"}],"tasks":[{"identity":"t-1"}],"tokens":[{"identity":"tok-1"}],"notifications":[{"identity":"n-1"}],"health":{"tuples":42,"uptime":10}}'.
    mockClient setResponse: 'http://localhost:7777/api/dashboard' to: dashJson.
    snapshot := model fetchDataSnapshot.
    "Model should NOT be mutated"
    t assert: model workflows size = 0 message: 'S1-2a: model unchanged after snapshot'.
    t assert: (snapshot at: 'connected' ifAbsent: [false]) = true message: 'S1-2b: snapshot connected'.
    t assert: (snapshot at: 'workflows' ifAbsent: [#()]) size = 1 message: 'S1-2c: snapshot workflows'
  ]

  classMethod: testApplySnapshotPopulatesModel: t [
    | model mockClient dashJson snapshot |
    model := PPDashboardModel new.
    mockClient := ADTMockHttpClient new.
    model client: mockClient.
    dashJson := '{"workflows":[{"identity":"wf-1"}],"tasks":[{"identity":"t-1"},{"identity":"t-2"}],"tokens":[{"identity":"tok-1"}],"notifications":[{"identity":"n-1"}],"health":{"tuples":42,"uptime":10}}'.
    mockClient setResponse: 'http://localhost:7777/api/dashboard' to: dashJson.
    snapshot := model fetchDataSnapshot.
    model applySnapshot: snapshot.
    t assert: model connected = true message: 'S1-3a: connected true'.
    t assert: model workflows size = 1 message: 'S1-3b: workflows populated'.
    t assert: model tasks size = 2 message: 'S1-3c: tasks populated'.
    t assert: model tokens size = 1 message: 'S1-3d: tokens populated'.
    t assert: model notifications size = 1 message: 'S1-3e: notifications populated'
  ]

  classMethod: testFineGrainedAspects: t [
    | model mockClient mockDep dashJson snapshot |
    model := PPDashboardModel new.
    mockClient := ADTMockHttpClient new.
    model client: mockClient.
    mockDep := ADTMockDependent new.
    model addDependent: mockDep.
    dashJson := '{"workflows":[{"identity":"wf-1"}],"tasks":[{"identity":"t-1"}],"tokens":[],"notifications":[{"identity":"n-1"}],"health":{"tuples":5,"uptime":1}}'.
    mockClient setResponse: 'http://localhost:7777/api/dashboard' to: dashJson.
    snapshot := model fetchDataSnapshot.
    model applySnapshot: snapshot.
    t assert: (mockDep hasAspect: #workflows) message: 'S1-4a: #workflows aspect sent'.
    t assert: (mockDep hasAspect: #tasks) message: 'S1-4b: #tasks aspect sent'.
    t assert: (mockDep hasAspect: #notifications) message: 'S1-4c: #notifications aspect sent'.
    t assert: (mockDep hasAspect: #health) message: 'S1-4d: #health aspect sent'.
    t assert: mockDep updateCount > 0 message: 'S1-4e: dependent was notified'
  ]

  classMethod: testExceptionSetsDisconnected: t [
    | model mockClient snapshot |
    model := PPDashboardModel new.
    mockClient := ADTMockHttpClient new.
    model client: mockClient.
    mockClient shouldFail: true.
    snapshot := model fetchDataSnapshot.
    model applySnapshot: snapshot.
    t assert: model connected = false message: 'S1-5a: connected false on error'
  ]

  classMethod: testRecoveryAfterError: t [
    | model mockClient dashJson snapshot |
    model := PPDashboardModel new.
    mockClient := ADTMockHttpClient new.
    model client: mockClient.
    mockClient shouldFail: true.
    snapshot := model fetchDataSnapshot.
    model applySnapshot: snapshot.
    t assert: model connected = false message: 'S1-6a: disconnected after error'.
    mockClient shouldFail: false.
    dashJson := '{"workflows":[{"identity":"wf-r"}],"tasks":[],"tokens":[],"notifications":[],"health":{"tuples":1,"uptime":1}}'.
    mockClient setResponse: 'http://localhost:7777/api/dashboard' to: dashJson.
    snapshot := model fetchDataSnapshot.
    model applySnapshot: snapshot.
    t assert: model connected = true message: 'S1-6b: connected after recovery'.
    t assert: model workflows size = 1 message: 'S1-6c: data populated after recovery'
  ]

  classMethod: testClientInjection: t [
    | model mockClient |
    model := PPDashboardModel new.
    mockClient := ADTMockHttpClient new.
    model client: mockClient.
    t assert: model client = mockClient message: 'S1-7: client injection works'
  ]

  classMethod: testDefaultBaseUrl: t [
    | model |
    model := PPDashboardModel new.
    t assert: model baseUrl = 'http://localhost:7777' message: 'S1-8: default baseUrl'
  ]


"========================================================
 STORY 2 TESTS: PPHeaderUpdater
 ========================================================"
TestADTHeader subclass: Object

  classMethod: run: t [
    '--- Story 2: PPHeaderUpdater ---' println.
    self testDisconnectedHeader: t.
    self testConnectedHeader: t.
    self testSummaryCountsInHeader: t
  ]

  classMethod: testDisconnectedHeader: t [
    | label model updater |
    label := ADTMockLabel new.
    model := ADTMockModel new.
    model connected: false.
    updater := ADTSafeHeaderUpdater new.
    updater initLabel: label model: model.
    t assert: (label text includesSubstring: 'DISCONNECTED') message: 'S2-1: disconnected shows DISCONNECTED'
  ]

  classMethod: testConnectedHeader: t [
    | label model health updater |
    label := ADTMockLabel new.
    model := ADTMockModel new.
    health := Dictionary new.
    health at: 'tuples' put: 42.
    health at: 'uptime' put: 10.
    model connected: true.
    model health: health.
    model workflows: #().
    model tasks: #().
    updater := ADTSafeHeaderUpdater new.
    updater initLabel: label model: model.
    t assert: (label text includesSubstring: '42') message: 'S2-2a: header shows tuple count'.
    t assert: (label text includesSubstring: '10') message: 'S2-2b: header shows uptime'
  ]

  classMethod: testSummaryCountsInHeader: t [
    | label model health updater wf1 wf2 |
    label := ADTMockLabel new.
    model := ADTMockModel new.
    health := Dictionary new.
    health at: 'tuples' put: 5.
    health at: 'uptime' put: 1.
    model connected: true.
    model health: health.
    wf1 := ADTTupleBuilder workflow: 'wf-a' status: 'running' template: 'tmpl'.
    wf2 := ADTTupleBuilder workflow: 'wf-b' status: 'done' template: 'tmpl'.
    model workflows: (Array new: 0) copyWith: wf1 copyWith: wf2.
    model tasks: (Array new: 0) copyWith: (ADTTupleBuilder task: 't-1' role: 'scout' status: 'active' workflow: 'wf-a').
    updater := ADTSafeHeaderUpdater new.
    updater initLabel: label model: model.
    t assert: (label text includesSubstring: '2 workflows') message: 'S2-3a: header shows workflow count'.
    t assert: (label text includesSubstring: '1 active') message: 'S2-3b: header shows active count'.
    t assert: (label text includesSubstring: '1 tasks') message: 'S2-3c: header shows task count'
  ]


"========================================================
 STORY 3 TESTS: PPWorkflowHelper
 ========================================================"
TestADTWorkflowHelper subclass: Object

  classMethod: run: t [
    '--- Story 3: PPWorkflowHelper ---' println.
    self testWorkflowLabelFormat: t.
    self testMasterListPopulation: t.
    self testDetailBuildsFromSelection: t
  ]

  classMethod: testWorkflowLabelFormat: t [
    | masterList detailList model helper wf label |
    masterList := ADTMockListView new.
    detailList := ADTMockListView new.
    model := ADTMockModel new.
    helper := PPWorkflowHelper setupMaster: masterList detail: detailList model: model.
    wf := ADTTupleBuilder workflow: 'wf-1' status: 'running' template: 'code-review'.
    label := masterList labelBlock value: wf.
    t assert: (label includesSubstring: 'wf-1') message: 'S3-1a: label includes identity'.
    t assert: (label includesSubstring: 'running') message: 'S3-1b: label includes status'.
    t assert: (label includesSubstring: 'code-review') message: 'S3-1c: label includes template'
  ]

  classMethod: testMasterListPopulation: t [
    | masterList detailList model helper workflows |
    masterList := ADTMockListView new.
    detailList := ADTMockListView new.
    model := ADTMockModel new.
    helper := PPWorkflowHelper setupMaster: masterList detail: detailList model: model.
    workflows := Array new: 0.
    workflows := workflows copyWith: (ADTTupleBuilder workflow: 'wf-a' status: 'running' template: 'tmpl').
    workflows := workflows copyWith: (ADTTupleBuilder workflow: 'wf-b' status: 'done' template: 'tmpl').
    model workflows: workflows.
    helper update: #workflows.
    t assertEqual: masterList items size to: 2 message: 'S3-2: master list has 2 workflows'
  ]

  classMethod: testDetailBuildsFromSelection: t [
    | masterList detailList model helper wf tasks tokens items foundWorkflow foundTask foundToken |
    masterList := ADTMockListView new.
    detailList := ADTMockListView new.
    model := ADTMockModel new.
    helper := PPWorkflowHelper setupMaster: masterList detail: detailList model: model.
    wf := ADTTupleBuilder workflow: 'wf-1' status: 'running' template: 'code-review'.
    tasks := Array new: 0.
    tasks := tasks copyWith: (ADTTupleBuilder task: 't-1' role: 'scout' status: 'active' workflow: 'wf-1').
    tokens := Array new: 0.
    tokens := tokens copyWith: (ADTTupleBuilder token: 'tok-1' status: 'active' workflow: 'wf-1').
    model tasks: tasks.
    model tokens: tokens.
    "Simulate selecting a workflow"
    masterList onSelectBlock value: wf.
    "Detail should have content"
    items := detailList items.
    foundWorkflow := false.
    foundTask := false.
    foundToken := false.
    items do: [:line |
      (line includesSubstring: 'wf-1') ifTrue: [foundWorkflow := true].
      (line includesSubstring: 't-1') ifTrue: [foundTask := true].
      (line includesSubstring: 'tok-1') ifTrue: [foundToken := true]
    ].
    t assert: foundWorkflow message: 'S3-3a: detail includes workflow identity'.
    t assert: foundTask message: 'S3-3b: detail includes task data'.
    t assert: foundToken message: 'S3-3c: detail includes token data'
  ]


"========================================================
 STORY 4 TESTS: PPActivityFeed
 ========================================================"
TestADTActivityFeed subclass: Object

  classMethod: run: t [
    '--- Story 4: PPActivityFeed ---' println.
    self testNotificationFormatting: t.
    self testEmptyNotifications: t
  ]

  classMethod: testNotificationFormatting: t [
    | listView model feed notifs |
    listView := ADTMockListView new.
    model := ADTMockModel new.
    feed := PPActivityFeed for: listView model: model.
    notifs := Array new: 0.
    notifs := notifs copyWith: (ADTTupleBuilder notification: 'warn' message: 'Scout timed out').
    notifs := notifs copyWith: (ADTTupleBuilder notification: 'info' message: 'Task completed').
    model notifications: notifs.
    feed update: #notifications.
    t assertEqual: listView items size to: 2 message: 'S4-1a: 2 formatted items'.
    t assertEqual: (listView items at: 0) to: '[warn] Scout timed out' message: 'S4-1b: first notification format'.
    t assertEqual: (listView items at: 1) to: '[info] Task completed' message: 'S4-1c: second notification format'
  ]

  classMethod: testEmptyNotifications: t [
    | listView model feed |
    listView := ADTMockListView new.
    model := ADTMockModel new.
    feed := PPActivityFeed for: listView model: model.
    model notifications: #().
    feed update: #notifications.
    t assertEqual: listView items size to: 0 message: 'S4-2: empty notifications produces empty list'
  ]


"========================================================
 STORY 5 TESTS: PPDashboardLayout (keyboard navigation)
 ========================================================"
TestADTLayout subclass: Object

  classMethod: run: t [
    '--- Story 5: PPDashboardLayout ---' println.
    self testQKeyExitsApp: t.
    self testNonQRuneDoesNotExit: t
  ]

  classMethod: testQKeyExitsApp: t [
    | layout mockApp evt |
    layout := PPDashboardLayout vertical.
    mockApp := ADTMockApp new.
    layout app: mockApp.
    evt := ADTMockKeyEvt key: 256 rune: 113.
    layout handleEvent: evt.
    t assert: mockApp stopped message: 'S5-1: q key stops app'
  ]

  classMethod: testNonQRuneDoesNotExit: t [
    | layout mockApp evt |
    layout := PPDashboardLayout vertical.
    mockApp := ADTMockApp new.
    layout app: mockApp.
    evt := ADTMockKeyEvt key: 256 rune: 97.
    layout handleEvent: evt.
    t assert: mockApp stopped not message: 'S5-2: non-q rune does not stop app'
  ]


"=== Entry Point ==="
TestAltoDashboardMain subclass: Object

  classMethod: run [
    | t |
    t := ADT new.
    [TestADTModel run: t] on: Exception do: [:e |
      t assert: false message: ('Story 1 crashed: ', e messageText)
    ].
    [TestADTHeader run: t] on: Exception do: [:e |
      t assert: false message: ('Story 2 crashed: ', e messageText)
    ].
    [TestADTWorkflowHelper run: t] on: Exception do: [:e |
      t assert: false message: ('Story 3 crashed: ', e messageText)
    ].
    [TestADTActivityFeed run: t] on: Exception do: [:e |
      t assert: false message: ('Story 4 crashed: ', e messageText)
    ].
    [TestADTLayout run: t] on: Exception do: [:e |
      t assert: false message: ('Story 5 crashed: ', e messageText)
    ].
    t report
  ]
